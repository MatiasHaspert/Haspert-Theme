{% comment %}
  Renders the header drawer menu (NUMEN) — acordeón mobile-first.

  Conserva el custom element <header-drawer> y el <details>/<summary> de la
  hamburguesa (global.js abre/cierra la hoja). El drill-down de Dawn se reemplaza
  por acordeón vía assets/numen-drawer-accordion.js (mata onSummaryClick en los
  summaries del nav). Presentación en assets/component-numen-menu-drawer.css.

  Contenido: el menú vive en Admin → Navegación (section.settings.menu). Contadores
  reales por colección (link.object.products_count). Ítem destacado (Autenticidad)
  y textos por settings de sección — nada hardcodeado.

  Usage:
  {% render 'header-drawer' %}
{% endcomment %}

{%- liquid
  # WhatsApp global: ignorar el placeholder con X para no generar un link roto.
  assign wa_num = settings.whatsapp_number
  if wa_num contains 'X' or wa_num contains 'x'
    assign wa_num = ''
  endif
  assign highlight_title = section.settings.highlight_link_title

  assign show_wa = false
  if wa_num != blank and section.settings.drawer_wa_label != blank
    assign show_wa = true
  endif
  assign show_legal = false
  if section.settings.drawer_legal_1 != blank or section.settings.drawer_legal_2 != blank
    assign show_legal = true
  endif
  assign show_foot = false
  if show_wa or show_legal or shop.customer_accounts_enabled
    assign show_foot = true
  endif
-%}

<header-drawer data-breakpoint="{% if section.settings.menu_type_desktop == 'drawer' %}desktop{% else %}tablet{% endif %}">
  <details id="Details-menu-drawer-container" class="menu-drawer-container">
    <summary
      class="header__icon header__icon--menu header__icon--summary link focus-inset"
      aria-label="{{ 'sections.header.menu' | t }}"
    >
      <span>
        {{- 'icon-hamburger.svg' | inline_asset_content -}}
        {{- 'icon-close.svg' | inline_asset_content -}}
      </span>
    </summary>

    {%- comment -%} Scrim: es <button> → lo cierra el onCloseButtonClick nativo de Dawn. {%- endcomment -%}
    <button type="button" class="mdrawer__scrim" aria-label="{{ 'accessibility.close' | t }}" tabindex="-1"></button>

    <div id="menu-drawer" class="gradient menu-drawer motion-reduce color-{{ section.settings.menu_color_scheme }}">
      <div class="menu-drawer__inner-container">
        <div class="menu-drawer__navigation-container mdrawer">
          {%- comment -%} Head: marca + cerrar {%- endcomment -%}
          <div class="mdrawer__head">
            <span class="mdrawer__brand">{{ shop.name }}</span>
            <button type="button" class="mdrawer__close" aria-label="{{ 'accessibility.close' | t }}">
              {{- 'icon-close.svg' | inline_asset_content -}}
            </button>
          </div>

          {%- comment -%} Body: grupos acordeón + links directos {%- endcomment -%}
          <nav class="menu-drawer__navigation mdrawer__body" aria-label="{{ 'sections.header.menu' | t }}">
            {%- assign group_idx = 0 -%}
            {%- for link in section.settings.menu.links -%}
              {%- if link.links != blank -%}
                {%- assign group_idx = group_idx | plus: 1 -%}
                <details class="mgroup"{% if group_idx == 1 %} open data-numen-open{% endif %}>
                  <summary
                    class="mgroup__head"
                    aria-expanded="{% if group_idx == 1 %}true{% else %}false{% endif %}"
                  >
                    <span class="mgroup__title">{{ link.title | escape }}</span>
                    <svg class="mgroup__chev" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                      <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                  </summary>
                  <div class="mgroup__panel">
                    <div class="mgroup__wrap">
                      <div class="mgroup__links">
                        {%- for childlink in link.links -%}
                          <a
                            href="{{ childlink.url }}"
                            class="mlink{% if childlink.url == link.url %} mlink--all{% endif %}"
                            {% if childlink.current %}aria-current="page"{% endif %}
                          >
                            <span class="mlink__t">{{ childlink.title | escape }}</span>
                            {%- comment -%} Contador sólo con stock de catálogo: un "0" delata catálogo incompleto. {%- endcomment -%}
                            {%- if childlink.type == 'collection_link' and childlink.object.products_count > 0 -%}
                              <span class="mlink__n">{{ childlink.object.products_count }}</span>
                            {%- endif -%}
                          </a>
                        {%- endfor -%}
                      </div>
                    </div>
                  </div>
                </details>
              {%- else -%}
                {%- if highlight_title != blank and link.title == highlight_title -%}
                  <a href="{{ link.url }}" class="mdirect"{% if link.current %} aria-current="page"{% endif %}>
                    <span class="mdirect__icon">{%- render 'icon-line', icon: 'shield' -%}</span>
                    <span class="mdirect__title">{{ link.title | escape }}</span>
                    {%- if section.settings.highlight_link_badge != blank -%}
                      <span class="mdirect__badge">{{ section.settings.highlight_link_badge }}</span>
                    {%- endif -%}
                  </a>
                {%- else -%}
                  <a href="{{ link.url }}" class="mdirect"{% if link.current %} aria-current="page"{% endif %}>
                    <span class="mdirect__title">{{ link.title | escape }}</span>
                  </a>
                {%- endif -%}
              {%- endif -%}
            {%- endfor -%}
          </nav>

          {%- comment -%} Foot: WhatsApp + cuenta (si aplica) + legales {%- endcomment -%}
          {%- if show_foot -%}
          <div class="mdrawer__foot">
            {%- if show_wa -%}
              <a class="mdrawer__wa" href="https://wa.me/{{ wa_num }}" target="_blank" rel="noopener">
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 00-8.5 15.2L2 22l4.9-1.4A10 10 0 1012 2zm0 18a8 8 0 01-4.1-1.1l-.3-.2-2.9.8.8-2.8-.2-.3A8 8 0 1112 20zm4.4-6c-.2-.1-1.4-.7-1.6-.8s-.4-.1-.5.1-.6.8-.8.9-.3.2-.5 0a6.5 6.5 0 01-1.9-1.2 7 7 0 01-1.3-1.6c-.1-.2 0-.4.1-.5l.4-.4.2-.4v-.4l-.7-1.7c-.2-.5-.4-.4-.5-.4h-.5a.9.9 0 00-.7.3 2.8 2.8 0 00-.9 2.1c0 1.2.9 2.4 1 2.6s1.8 2.8 4.4 3.9c1.6.7 2.2.7 3 .6.5 0 1.4-.6 1.6-1.1s.2-1 .1-1.1l-.4-.2z"/></svg>
                {{ section.settings.drawer_wa_label }}
              </a>
            {%- endif -%}

            {%- if shop.customer_accounts_enabled -%}
              <a
                href="{% if customer %}{{ routes.account_url }}{% else %}{%- render 'login-url' -%}{% endif %}"
                class="mdrawer__account"
                rel="nofollow"
              >
                {{- 'icon-account.svg' | inline_asset_content -}}
                {%- if customer -%}{{ 'customer.account_fallback' | t }}{%- else -%}{{ 'customer.log_in' | t }}{%- endif -%}
              </a>
            {%- endif -%}

            {%- if show_legal -%}
              <div class="mdrawer__legal">
                {%- if section.settings.drawer_legal_1 != blank -%}
                  <a href="{{ section.settings.drawer_legal_1 }}">{{ section.settings.drawer_legal_1_label | default: 'Botón de arrepentimiento' }}</a>
                {%- endif -%}
                {%- if section.settings.drawer_legal_2 != blank -%}
                  <a href="{{ section.settings.drawer_legal_2 }}">{{ section.settings.drawer_legal_2_label | default: 'Términos' }}</a>
                {%- endif -%}
              </div>
            {%- endif -%}
          </div>
          {%- endif -%}
        </div>
      </div>
    </div>
  </details>
</header-drawer>
