{%- comment -%}
  Cuerpo del empty state Numen (compartido por el drawer y /cart). Textos desde locale.
  CTA a la colección configurada (cart_drawer_collection) o a todos los productos. Sin emojis.
  IMPORTANTE: contiene el <a> que el foco del drawer espera cuando el carrito queda vacío
  (cart.js: trapFocus sobre .drawer__inner-empty → primer <a>).
{%- endcomment -%}
{%- liquid
  if settings.cart_drawer_collection != blank
    assign empty_url = settings.cart_drawer_collection.url
  else
    assign empty_url = routes.all_products_collection_url
  endif
-%}
<div class="nc-empty__body">
  <span class="nc-empty__glyph">
    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
      <path d="M9 3.5h6M10 3.5V6c0 .5-.2 1-.5 1.4L7 11v8.5A1.5 1.5 0 0 0 8.5 21h7a1.5 1.5 0 0 0 1.5-1.5V11l-2.5-3.6A2.4 2.4 0 0 1 14 6V3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M7.5 14.5h9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    </svg>
  </span>
  <p class="nc-empty__title">{{ 'sections.cart.empty_title' | t }}</p>
  <p class="nc-empty__text">{{ 'sections.cart.empty_text' | t }}</p>
  <a href="{{ empty_url }}" class="nc-empty__cta">{{ 'sections.cart.empty_cta' | t }}</a>
  <div class="nc-empty__hints">
    <span class="nc-empty__hint">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
        <path d="M12 2l8 3v6c0 5-3.5 8.5-8 11-4.5-2.5-8-6-8-11V5l8-3z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
      </svg>
      {{ 'sections.cart.trust_original' | t }}
    </span>
    <span class="nc-empty__hint">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
        <rect x="2" y="7" width="13" height="10" rx="1.5" stroke="currentColor" stroke-width="1.5"/>
        <path d="M15 10h3.5l2.5 3v4H15z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
        <circle cx="6.5" cy="18" r="1.6" stroke="currentColor" stroke-width="1.5"/>
        <circle cx="17" cy="18" r="1.6" stroke="currentColor" stroke-width="1.5"/>
      </svg>
      {{ 'sections.cart.empty_shipping' | t }}
    </span>
  </div>
</div>
