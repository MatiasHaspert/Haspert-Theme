{%- comment -%}
  Main product (PDP) — Perfumería
  Reconstruye la sección main-product de Sense usando el stack JS intacto
  (product-info.js, product-form.js, media-gallery.js, global.js > variant-selects)
  y suma la ficha olfativa desde metafields custom.* + ladder de presentaciones ($/ml)
  + garantía de originalidad. Precios SIEMPRE desde Shopify (variant.price | money).
{%- endcomment -%}

{%- liquid
  assign product_form_id = 'product-form-' | append: section.id
  assign variant_images = product.images | where: 'attached_to_variant?', true | map: 'src'
  if section.settings.media_position == 'right'
    assign media_position = 'right'
  else
    assign media_position = 'left'
  endif

  # Dorado de marca para texto/ícono/borde con contraste AA: oscurece sólo sobre fondos claros.
  assign accent = section.settings.accent_color
  assign scheme_bg = section.settings.color_scheme.settings.background
  assign bg_bright = scheme_bg | color_brightness
  assign accent_ink = accent
  if scheme_bg == blank or bg_bright > 140
    assign accent_ink = accent | color_darken: 22
  endif
-%}

<product-info
  id="MainProduct-{{ section.id }}"
  class="section-{{ section.id }}-padding"
  data-section="{{ section.id }}"
  data-product-id="{{ product.id }}"
  data-url="{{ product.url }}"
  data-update-url="true"
  {% if section.settings.image_zoom == 'hover' %}
    data-zoom-on-hover
  {% endif %}
>
  {{ 'section-main-product.css' | asset_url | stylesheet_tag }}
  {{ 'component-price.css' | asset_url | stylesheet_tag }}
  {{ 'component-installments.css' | asset_url | stylesheet_tag }}
  {{ 'component-slider.css' | asset_url | stylesheet_tag }}
  {{ 'component-rating.css' | asset_url | stylesheet_tag }}
  {{ 'component-deferred-media.css' | asset_url | stylesheet_tag }}
  {%- unless product.has_only_default_variant -%}
    {{ 'component-product-variant-picker.css' | asset_url | stylesheet_tag }}
    {{ 'component-swatch.css' | asset_url | stylesheet_tag }}
    {{ 'component-swatch-input.css' | asset_url | stylesheet_tag }}
  {%- endunless -%}

  {%- style -%}
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    }
    @media screen and (min-width: 750px) {
      .section-{{ section.id }}-padding {
        padding-top: {{ section.settings.padding_top }}px;
        padding-bottom: {{ section.settings.padding_bottom }}px;
      }
    }
    #MainProduct-{{ section.id }} {
      --perfume-accent: {{ section.settings.accent_color }};
      --perfume-accent-rgb: {{ accent.red }}, {{ accent.green }}, {{ accent.blue }};
      --perfume-accent-ink: {{ accent_ink }};

      /* Motion: curvas reales (reemplazan los `ease` planos) */
      --perfume-ease-select: cubic-bezier(0.23, 1, 0.32, 1);
      --perfume-ease-drawer: cubic-bezier(0.32, 0.72, 0, 1);
      --perfume-dur-select: 200ms;
      --perfume-dur-tap: 140ms;
      --perfume-dur-sticky: 260ms;

      /* Verde de transferencia (sobrio, no compite con el precio ni el ATC) */
      --perfume-ok: #246A45;
      --perfume-ok-bg: #EDF4EE;
      --perfume-ok-line: #CFE3D5;
      --perfume-alert: #b5471f;
      --perfume-alert-bg: #fae9df;
      --perfume-alert-line: #e7c3ac;

      /* Cream/paper cálido para chips de acento de la ficha (sin oro metálico) */
      --perfume-soft-bg: #F6EFDD;
      --perfume-soft-line: #E7D9B6;
    }
  {%- endstyle -%}

  <script src="{{ 'product-info.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'perfume-variant-ui.js' | asset_url }}" defer="defer"></script>
  {%- if section.settings.show_sticky_atc -%}
    <script src="{{ 'sticky-atc.js' | asset_url }}" defer="defer"></script>
  {%- endif -%}
  {%- if product.media.size > 0 -%}
    <script src="{{ 'media-gallery.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'product-modal.js' | asset_url }}" defer="defer"></script>
  {%- endif -%}
  {%- if section.settings.image_zoom == 'hover' -%}
    <script id="EnableZoomOnHover" src="{{ 'magnify.js' | asset_url }}" defer="defer"></script>
  {%- endif -%}
  {%- if request.design_mode -%}
    <script src="{{ 'theme-editor.js' | asset_url }}" defer="defer"></script>
  {%- endif -%}

  <section class="color-{{ section.settings.color_scheme }} gradient">
    <div class="page-width">
      <div class="product product--{{ section.settings.media_size }} grid grid--1-col product--{{ media_position }}{% if product.media.size > 0 %} grid--2-col-tablet{% else %} product--no-media{% endif %}">
        {%- comment -%} ---------- Media ---------- {%- endcomment -%}
        <div class="grid__item product__media-wrapper">
          {%- if product.media.size > 0 -%}
            {% render 'product-media-gallery', product: product, variant_images: variant_images %}
          {%- else -%}
            <div class="product__media-item">
              <div class="product-media-container global-media-settings gradient" style="--ratio: 1.0; --preview-ratio: 1.0;">
                {{ 'product-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
            </div>
          {%- endif -%}
        </div>

        {%- comment -%} ---------- Info ---------- {%- endcomment -%}
        <div class="product__info-wrapper grid__item{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
          <section
            id="ProductInfo-{{ section.id }}"
            class="product__info-container"
            data-section="{{ section.id }}"
            data-url="{{ product.url }}"
          >
            {%- if product.vendor != blank -%}
              <a class="perfume-vendor caption-with-letter-spacing" href="{{ routes.collections_url }}/vendors?q={{ product.vendor | url_encode }}">
                {{- product.vendor -}}
              </a>
            {%- endif -%}

            <h1 class="product__title perfume-title">{{ product.title | escape }}</h1>

            <div id="price-{{ section.id }}" role="status">
              {%- assign sel_variant = product.selected_or_first_available_variant -%}
              <div class="perfume-price-row">
                {%- render 'price',
                  product: product,
                  use_variant: true,
                  show_badges: true,
                  price_class: 'price--large'
                -%}
                {%- capture sel_ml -%}{% render 'perfume-ml', variant: sel_variant, product: product %}{%- endcapture -%}
                {%- assign sel_ml = sel_ml | plus: 0 -%}
                {%- if sel_ml > 0 -%}
                  <span class="perfume-perml">{{ sel_variant.price | divided_by: sel_ml | money }}/ml</span>
                {%- endif -%}
              </div>

              {%- comment -%} Transferencia: descuento informativo (Camino A), nunca tachando el precio de lista. {%- endcomment -%}
              {%- if section.settings.transfer_discount_enabled and section.settings.transfer_discount_pct > 0 -%}
                {%- assign transfer_factor = 100 | minus: section.settings.transfer_discount_pct -%}
                {%- assign transfer_price = sel_variant.price | times: transfer_factor | divided_by: 100 -%}
                <div class="perfume-transfer">
                  <span class="perfume-transfer__chip">
                    <b>{{ transfer_price | money }}</b>
                    <span>{{ section.settings.transfer_label }} · {{ section.settings.transfer_discount_pct }}% OFF</span>
                  </span>
                </div>
                {%- if section.settings.transfer_microcopy != blank -%}
                  <p class="perfume-transfer__microcopy">{{ section.settings.transfer_microcopy }}</p>
                {%- endif -%}
              {%- endif -%}

              <p class="perfume-cuotas">
                {%- render 'installments', price: sel_variant.price, layout: 'pdp' -%}
              </p>
            </div>

            {%- if shop.shipping_policy.body != blank -%}
              <div class="product__tax caption rte">
                {{ 'products.product.shipping_policy_html' | t: link: shop.shipping_policy.url }}
              </div>
            {%- endif -%}

            {%- comment -%} ---------- Selector de presentación fusionado (radio-cards + $/ml) ---------- {%- endcomment -%}
            {%- unless product.has_only_default_variant -%}
              {%- assign picker_type = section.settings.picker_type -%}
              <variant-selects id="variant-selects-{{ section.id }}" data-section="{{ section.id }}">
                {%- if product.options_with_values.size == 1 and picker_type == 'button' -%}
                  {%- assign sel_option = product.options_with_values.first -%}
                  {%- comment -%} Menor $/ml para el badge calculado "Mejor $/ml". {%- endcomment -%}
                  {%- assign best_perml = 0 -%}
                  {%- assign best_vid = 0 -%}
                  {%- for v in product.variants -%}
                    {%- comment -%} El tester se excluye del cálculo de "Mejor $/ml": su $/ml es el más bajo (≈ original −10%) pero no es la presentación protagonista. Así el badge cae en el frasco sellado. {%- endcomment -%}
                    {%- assign v_tipo = v.metafields.custom.tipo_presentacion.value -%}
                    {%- if v_tipo == 'Tester' -%}{%- continue -%}{%- endif -%}
                    {%- capture v_ml -%}{% render 'perfume-ml', variant: v, product: product %}{%- endcapture -%}
                    {%- assign v_ml = v_ml | plus: 0 -%}
                    {%- if v_ml > 0 and v.price > 0 -%}
                      {%- assign v_perml = v.price | divided_by: v_ml -%}
                      {%- if best_perml == 0 or v_perml < best_perml -%}
                        {%- assign best_perml = v_perml -%}
                        {%- assign best_vid = v.id -%}
                      {%- endif -%}
                    {%- endif -%}
                  {%- endfor -%}

                  <fieldset class="js perfume-selector">
                    <legend class="form__label perfume-selector__legend">
                      {{ section.settings.selector_heading | default: sel_option.name }}
                    </legend>
                    {%- for value in sel_option.values -%}
                      {%- capture vname -%}{{ value }}{%- endcapture -%}
                      {%- assign card_variant = product.variants | where: 'option1', vname | first -%}
                      {%- if card_variant == blank -%}{%- continue -%}{%- endif -%}
                      {%- assign card_tipo = card_variant.metafields.custom.tipo_presentacion.value -%}
                      {%- capture c_ml -%}{% render 'perfume-ml', variant: card_variant, product: product %}{%- endcapture -%}
                      {%- assign c_ml = c_ml | plus: 0 -%}
                      {%- assign input_id = section.id | append: '-presentacion-' | append: forloop.index0 -%}
                      <input
                        type="radio"
                        id="{{ input_id }}"
                        class="perfume-card__input visually-hidden{% unless value.available %} disabled{% endunless %}"
                        name="{{ sel_option.name }}-{{ sel_option.position }}"
                        value="{{ value | escape }}"
                        form="{{ product_form_id }}"
                        data-option-value-id="{{ value.id }}"
                        data-product-url="{{ value.product_url }}"
                        {% if value.selected %}checked{% endif %}
                      >
                      <label class="perfume-card" for="{{ input_id }}">
                        <span class="perfume-card__radio" aria-hidden="true"><i></i></span>
                        <span class="perfume-card__body">
                          <span class="perfume-card__name">
                            {{ card_variant.title }}
                            {%- if card_variant.metafields.custom.badge_variante.value != blank -%}
                              <span class="perfume-badge perfume-badge--top">{{ card_variant.metafields.custom.badge_variante.value }}</span>
                            {%- elsif card_variant.id == best_vid and best_vid != 0 -%}
                              <span class="perfume-badge perfume-badge--ml">{{ section.settings.best_perml_label }}</span>
                            {%- endif -%}
                          </span>
                          {%- if card_variant.metafields.custom.nota_variante.value != blank -%}
                            <span class="perfume-card__sub">{{ card_variant.metafields.custom.nota_variante.value }}</span>
                          {%- endif -%}
                          {%- unless value.available -%}
                            <span class="perfume-card__sub perfume-card__sub--out">{{ 'products.product.sold_out' | t }}</span>
                          {%- endunless -%}
                        </span>
                        <span class="perfume-card__price">
                          <b>{{ card_variant.price | money }}</b>
                          {%- if c_ml > 0 -%}
                            <span class="perfume-card__perml{% if card_variant.id == best_vid and best_vid != 0 %} is-best{% elsif card_tipo == 'Decant' %} is-muted{% endif %}">{{ card_variant.price | divided_by: c_ml | money }}/ml</span>
                          {%- endif -%}
                        </span>
                      </label>
                    {%- endfor -%}
                  </fieldset>

                  {%- comment -%} Nota legal decant: sólo si la variante seleccionada es Decant. {%- endcomment -%}
                  {%- assign sel_tipo = product.selected_or_first_available_variant.metafields.custom.tipo_presentacion.value -%}
                  {%- if sel_tipo == 'Decant' and section.settings.decant_legal_text != blank -%}
                    <div class="perfume-decant-note rte">{{ section.settings.decant_legal_text }}</div>
                  {%- endif -%}
                {%- else -%}
                  {%- comment -%} Fallback legacy (multi-opción o picker dropdown): pills/select de Dawn. {%- endcomment -%}
                  {%- for option in product.options_with_values -%}
                    {%- if picker_type == 'dropdown' -%}
                      <div class="product-form__input product-form__input--dropdown">
                        <label class="form__label" for="Option-{{ section.id }}-{{ forloop.index0 }}">{{ option.name }}</label>
                        <div class="select">
                          <select
                            id="Option-{{ section.id }}-{{ forloop.index0 }}"
                            class="select__select"
                            name="options[{{ option.name | escape }}]"
                            form="{{ product_form_id }}"
                          >
                            {% render 'product-variant-options', product: product, option: option, picker_type: 'dropdown' %}
                          </select>
                          <span class="svg-wrapper">{{- 'icon-caret.svg' | inline_asset_content -}}</span>
                        </div>
                      </div>
                    {%- else -%}
                      <fieldset class="js product-form__input product-form__input--pill">
                        <legend class="form__label">{{ option.name }}</legend>
                        {% render 'product-variant-options', product: product, option: option, picker_type: 'button' %}
                      </fieldset>
                    {%- endif -%}
                  {%- endfor -%}
                {%- endif -%}

                <script type="application/json" data-selected-variant>
                  {{ product.selected_or_first_available_variant | json }}
                </script>
              </variant-selects>
            {%- endunless -%}

            {%- comment -%} ---------- Buy buttons ---------- {%- endcomment -%}
            <product-form class="product-form" data-section-id="{{ section.id }}">
              <div class="product-form__error-message-wrapper" role="alert" hidden>
                <span class="svg-wrapper">
                  {{- 'icon-error.svg' | inline_asset_content -}}
                </span>
                <span class="product-form__error-message"></span>
              </div>

              {%- form 'product',
                product,
                id: product_form_id,
                class: 'form',
                novalidate: 'novalidate',
                data-type: 'add-to-cart-form'
              -%}
                <input
                  type="hidden"
                  name="id"
                  value="{{ product.selected_or_first_available_variant.id }}"
                  {% if product.selected_or_first_available_variant.available == false %}disabled{% endif %}
                  class="product-variant-id"
                >
                <div class="product-form__buttons">
                  <button
                    id="ProductSubmitButton-{{ section.id }}"
                    type="submit"
                    name="add"
                    {%- comment -%} ATC = acción PRIMARIA siempre (terracota sólido). Invierte el patrón de Dawn que lo degrada a button--secondary cuando hay dynamic checkout; acá el "Comprar ahora" es el secundario (ver {% stylesheet %}). {%- endcomment -%}
                    class="product-form__submit button button--full-width button--primary"
                    {% if product.selected_or_first_available_variant.available == false %}disabled{% endif %}
                  >
                    <span>
                      {%- if product.selected_or_first_available_variant == null -%}
                        {{ 'products.product.unavailable' | t }}
                      {%- elsif product.selected_or_first_available_variant.available == false -%}
                        {{ 'products.product.sold_out' | t }}
                      {%- else -%}
                        {{ 'products.product.add_to_cart' | t }}
                      {%- endif -%}
                    </span>
                    {%- render 'loading-spinner' -%}
                  </button>
                  {%- if section.settings.show_dynamic_checkout -%}
                    {{ form | payment_button }}
                  {%- endif -%}
                </div>
              {%- endform -%}
            </product-form>

            {%- comment -%} ---------- Línea de reaseguro de pago (Mercado Pago) ---------- {%- endcomment -%}
            {%- if section.settings.pay_reassurance_text != blank -%}
              <p class="perfume-pay">{{ section.settings.pay_reassurance_text }}</p>
            {%- endif -%}

            {%- comment -%} ---------- Tira de confianza (variante-aware §4.4) ---------- {%- endcomment -%}
            {%- if section.settings.show_trust -%}
              {%- assign trust_tipo = product.selected_or_first_available_variant.metafields.custom.tipo_presentacion.value -%}
              {%- liquid
                case trust_tipo
                  when 'Decant'
                    assign trust_title = section.settings.trust_decant_title
                    assign trust_text = section.settings.trust_decant_text
                  when 'Tester'
                    assign trust_title = section.settings.trust_tester_title
                    assign trust_text = section.settings.trust_tester_text
                  else
                    assign trust_title = section.settings.trust_sealed_title
                    assign trust_text = section.settings.trust_sealed_text
                endcase
              -%}
              <div class="perfume-trust" id="PerfumeTrust-{{ section.id }}" data-tipo="{{ trust_tipo | escape }}">
                <span class="perfume-trust__icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" width="18" height="18"><path d="M12 3l7 3v5c0 4.5-3 8.2-7 9-4-.8-7-4.5-7-9V6l7-3z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/><path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </span>
                <div class="perfume-trust__body">
                  {%- if trust_title != blank -%}<p class="perfume-trust__title">{{ trust_title }}</p>{%- endif -%}
                  {%- if trust_text != blank -%}<p class="perfume-trust__text">{{ trust_text }}</p>{%- endif -%}
                </div>
              </div>
            {%- endif -%}

            {%- comment -%} ---------- Envío (§4.5): umbral global + barra viva + Rosario/nacional ---------- {%- endcomment -%}
            {%- if section.settings.show_shipping -%}
              <div class="perfume-ship">
                <div class="perfume-ship__row">
                  <span class="perfume-ship__icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" width="20" height="20"><path d="M3 7h11v8H3zM14 10h4l3 3v2h-7z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><circle cx="7" cy="17" r="1.6" stroke="currentColor" stroke-width="1.5"/><circle cx="17.5" cy="17" r="1.6" stroke="currentColor" stroke-width="1.5"/></svg>
                  </span>
                  <div class="perfume-ship__body">
                    {%- if settings.free_ship_threshold > 0 and section.settings.free_ship_label != blank -%}
                      <p class="perfume-ship__title">{{ section.settings.free_ship_label }} {{ settings.free_ship_threshold | times: 100 | money }}</p>
                    {%- endif -%}
                    {% render 'free-shipping-bar' %}
                  </div>
                </div>
                {%- if section.settings.envio_rosario_hoy and section.settings.envio_rosario_text != blank -%}
                  <div class="perfume-ship__row">
                    <span class="perfume-ship__icon" aria-hidden="true">
                      <svg viewBox="0 0 24 24" fill="none" width="20" height="20"><path d="M12 21s7-5.5 7-11a7 7 0 10-14 0c0 5.5 7 11 7 11z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><circle cx="12" cy="10" r="2.4" stroke="currentColor" stroke-width="1.5"/></svg>
                    </span>
                    <div class="perfume-ship__body"><p class="perfume-ship__text">{{ section.settings.envio_rosario_text }}</p></div>
                  </div>
                {%- endif -%}
                {%- if section.settings.envio_nacional_text != blank -%}
                  <div class="perfume-ship__row">
                    <span class="perfume-ship__icon" aria-hidden="true">
                      <svg viewBox="0 0 24 24" fill="none" width="20" height="20"><path d="M3 8l9-5 9 5v8l-9 5-9-5V8z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/><path d="M3 8l9 5 9-5M12 13v8" stroke="currentColor" stroke-width="1.4"/></svg>
                    </span>
                    <div class="perfume-ship__body"><p class="perfume-ship__text">{{ section.settings.envio_nacional_text }}</p></div>
                  </div>
                {%- endif -%}
              </div>
            {%- endif -%}

            {%- comment -%} ---------- Ficha olfativa: chips + medidores (§4.6) ---------- {%- endcomment -%}
            {%- if section.settings.show_facts -%}
              {%- assign m_familia = product.metafields.custom.familia_olfativa.value -%}
              {%- assign m_genero = product.metafields.custom.genero.value -%}
              {%- assign m_conc = product.metafields.custom.concentracion.value -%}
              {%- assign m_longev = product.metafields.custom.longevidad.value -%}
              {%- assign m_estela = product.metafields.custom.estela.value -%}
              {%- assign m_ocasion = product.metafields.custom.ocasion.value -%}
              {%- assign m_estacion = product.metafields.custom.estacion.value -%}
              {%- assign n_salida = product.metafields.custom.notas_salida.value -%}
              {%- assign n_corazon = product.metafields.custom.notas_corazon.value -%}
              {%- assign n_fondo = product.metafields.custom.notas_fondo.value -%}
              {%- if m_familia != blank or m_genero != blank or m_conc != blank or m_longev != blank or m_estela != blank or m_ocasion != blank or m_estacion != blank or n_salida != blank or n_corazon != blank or n_fondo != blank -%}
                <div class="perfume-ficha">
                  {%- if section.settings.facts_heading != blank -%}
                    <p class="perfume-section-title">{{ section.settings.facts_heading }}</p>
                  {%- endif -%}

                  {%- if m_familia != blank or m_conc != blank or m_genero != blank -%}
                    <ul class="perfume-chips list-unstyled">
                      {%- if m_familia != blank -%}{%- for f in m_familia -%}<li class="perfume-chip perfume-chip--accent">{{ f }}</li>{%- endfor -%}{%- endif -%}
                      {%- if m_conc != blank -%}<li class="perfume-chip">{{ m_conc }}</li>{%- endif -%}
                      {%- if m_genero != blank -%}<li class="perfume-chip">{{ m_genero }}</li>{%- endif -%}
                    </ul>
                  {%- endif -%}

                  {%- assign all_notas = '' | split: '' -%}
                  {%- if n_salida != blank -%}{%- assign all_notas = all_notas | concat: n_salida -%}{%- endif -%}
                  {%- if n_corazon != blank -%}{%- assign all_notas = all_notas | concat: n_corazon -%}{%- endif -%}
                  {%- if n_fondo != blank -%}{%- assign all_notas = all_notas | concat: n_fondo -%}{%- endif -%}
                  {%- if all_notas.size > 0 -%}
                    <div class="perfume-ficha__group">
                      {%- if section.settings.notes_label != blank -%}<p class="perfume-ficha__label">{{ section.settings.notes_label }}</p>{%- endif -%}
                      <ul class="perfume-chips list-unstyled">
                        {%- for nota in all_notas -%}<li class="perfume-note">{{ nota }}</li>{%- endfor -%}
                      </ul>
                    </div>
                  {%- endif -%}

                  {%- if m_longev != blank or m_estela != blank or m_ocasion != blank or m_estacion != blank -%}
                    <div class="perfume-meters">
                      {%- if m_longev != blank -%}
                        {%- assign lvl = 3 -%}
                        {%- case m_longev -%}
                          {%- when 'Baja (2–4h)' -%}{%- assign lvl = 1 -%}
                          {%- when 'Moderada (4–6h)' -%}{%- assign lvl = 2 -%}
                          {%- when 'Larga (6–8h)' -%}{%- assign lvl = 3 -%}
                          {%- when 'Muy larga (8–12h)' -%}{%- assign lvl = 4 -%}
                          {%- when 'Eterna (12h+)' -%}{%- assign lvl = 5 -%}
                        {%- endcase -%}
                        <div class="perfume-meter">
                          {%- if section.settings.longevity_label != blank -%}<p class="perfume-ficha__label">{{ section.settings.longevity_label }}</p>{%- endif -%}
                          <div class="perfume-meter__bar">
                            <span class="perfume-bars" aria-hidden="true">{%- for i in (1..5) -%}<i class="{% if i <= lvl %}on{% endif %}"></i>{%- endfor -%}</span>
                            <span class="perfume-meter__v">{{ m_longev }}</span>
                          </div>
                        </div>
                      {%- endif -%}
                      {%- if m_estela != blank -%}
                        {%- assign lvl = 3 -%}
                        {%- case m_estela -%}
                          {%- when 'Íntima' -%}{%- assign lvl = 2 -%}
                          {%- when 'Moderada' -%}{%- assign lvl = 3 -%}
                          {%- when 'Notable' -%}{%- assign lvl = 4 -%}
                          {%- when 'Enorme' -%}{%- assign lvl = 5 -%}
                        {%- endcase -%}
                        <div class="perfume-meter">
                          {%- if section.settings.sillage_label != blank -%}<p class="perfume-ficha__label">{{ section.settings.sillage_label }}</p>{%- endif -%}
                          <div class="perfume-meter__bar">
                            <span class="perfume-bars" aria-hidden="true">{%- for i in (1..5) -%}<i class="{% if i <= lvl %}on{% endif %}"></i>{%- endfor -%}</span>
                            <span class="perfume-meter__v">{{ m_estela }}</span>
                          </div>
                        </div>
                      {%- endif -%}
                      {%- if m_ocasion != blank or m_estacion != blank -%}
                        <div class="perfume-meter">
                          {%- if section.settings.occasion_label != blank -%}<p class="perfume-ficha__label">{{ section.settings.occasion_label }}</p>{%- endif -%}
                          <div class="perfume-occ">
                            {%- if m_ocasion != blank -%}{%- for o in m_ocasion -%}<span>{{ o }}</span>{%- endfor -%}{%- endif -%}
                            {%- if m_estacion != blank -%}{%- for e in m_estacion -%}<span>{{ e }}</span>{%- endfor -%}{%- endif -%}
                          </div>
                        </div>
                      {%- endif -%}
                    </div>
                  {%- endif -%}
                </div>
              {%- endif -%}
            {%- endif -%}

            {%- comment -%} ---------- Pirámide olfativa ---------- {%- endcomment -%}
            {%- if section.settings.show_pyramid -%}
              {%- assign p_salida = product.metafields.custom.notas_salida.value -%}
              {%- assign p_corazon = product.metafields.custom.notas_corazon.value -%}
              {%- assign p_fondo = product.metafields.custom.notas_fondo.value -%}
              {%- if p_salida != blank or p_corazon != blank or p_fondo != blank -%}
                <div class="perfume-pyramid">
                  {%- if section.settings.pyramid_heading != blank -%}
                    <p class="perfume-section-title">{{ section.settings.pyramid_heading }}</p>
                  {%- endif -%}
                  {%- if p_salida != blank -%}
                    <div class="perfume-pyramid__tier">
                      <span class="perfume-pyramid__label">{{ section.settings.label_top }}</span>
                      <span class="perfume-pyramid__notes">{{ p_salida | join: ' · ' }}</span>
                    </div>
                  {%- endif -%}
                  {%- if p_corazon != blank -%}
                    <div class="perfume-pyramid__tier">
                      <span class="perfume-pyramid__label">{{ section.settings.label_heart }}</span>
                      <span class="perfume-pyramid__notes">{{ p_corazon | join: ' · ' }}</span>
                    </div>
                  {%- endif -%}
                  {%- if p_fondo != blank -%}
                    <div class="perfume-pyramid__tier">
                      <span class="perfume-pyramid__label">{{ section.settings.label_base }}</span>
                      <span class="perfume-pyramid__notes">{{ p_fondo | join: ' · ' }}</span>
                    </div>
                  {%- endif -%}
                </div>
              {%- endif -%}
            {%- endif -%}

            {%- if product.description != blank -%}
              <div class="perfume-description rte">{{ product.description }}</div>
            {%- endif -%}

            {%- comment -%} ---------- "Inspirado en" (gate árabe doble: metafield + colección/tag) ---------- {%- endcomment -%}
            {%- if product.metafields.custom.inspirado_en.value != blank -%}
              {%- assign arabic_handle = section.settings.arabic_collection_handle -%}
              {%- assign is_arabic = false -%}
              {%- if arabic_handle != blank -%}
                {%- if product.tags contains arabic_handle -%}{%- assign is_arabic = true -%}{%- endif -%}
                {%- for c in product.collections -%}
                  {%- if c.handle == arabic_handle -%}{%- assign is_arabic = true -%}{%- break -%}{%- endif -%}
                {%- endfor -%}
              {%- endif -%}
              {%- if is_arabic -%}
                <div class="perfume-inspired">
                  <p class="perfume-inspired__text">{{ section.settings.inspired_prefix }} {{ product.metafields.custom.inspirado_en.value }}.</p>
                  {%- if section.settings.inspired_legal != blank -%}
                    <span class="perfume-inspired__legal">{{ section.settings.inspired_legal }}</span>
                  {%- endif -%}
                </div>
              {%- endif -%}
            {%- endif -%}

          </section>
        </div>
      </div>
      {% render 'product-media-modal', product: product, variant_images: variant_images %}

      {%- comment -%} App blocks full-width debajo del producto (ej. Judge.me Review Widget) {%- endcomment -%}
      {%- if section.blocks.size > 0 -%}
        <div class="product-app-blocks">
          {%- for block in section.blocks -%}
            {%- if block.type == '@app' -%}
              {% render block %}
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </section>

  <script type="application/ld+json">
    {{ product | structured_data }}
  </script>

  {%- if section.settings.show_sticky_atc -%}
    {% render 'sticky-atc', product: product, product_form_id: product_form_id, section_id: section.id %}
  {%- endif -%}
</product-info>

{% stylesheet %}
.sticky-atc {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 4;
  transform: translateY(110%);
  transition: transform var(--perfume-dur-sticky, 260ms) var(--perfume-ease-drawer, var(--ease-drawer));
  background: rgb(var(--color-background));
  border-top: 0.1rem solid rgba(var(--color-foreground), 0.1);
  box-shadow: 0 -0.4rem 1.4rem rgba(0, 0, 0, 0.07);
  padding-bottom: env(safe-area-inset-bottom);
}
.sticky-atc--visible {
  transform: translateY(0);
}
.sticky-atc__inner {
  display: flex;
  align-items: center;
  gap: 1rem;
  padding: 0.8rem 1.5rem;
}
.sticky-atc__media {
  flex-shrink: 0;
  width: 4.4rem;
  height: 4.4rem;
}
.sticky-atc__media img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 0.4rem;
}
.sticky-atc__info {
  display: flex;
  flex-direction: column;
  flex: 1 1 auto;
  min-width: 0;
}
.sticky-atc__title {
  font-size: 1.3rem;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  opacity: 0.75;
}
.sticky-atc__price .price {
  font-weight: 600;
}
.sticky-atc__price .price__container {
  justify-content: flex-start;
}
.sticky-atc__button {
  flex-shrink: 0;
  width: auto;
  min-width: 12rem;
  margin: 0;
  transition: transform var(--perfume-dur-tap, 140ms) var(--perfume-ease-select, var(--ease-select)),
              background-color var(--perfume-dur-select, 200ms) var(--perfume-ease-select, var(--ease-select));
}
.sticky-atc__button:active { transform: scale(0.97); }
@media screen and (min-width: 750px) {
  .sticky-atc {
    display: none;
  }
}

/* =====================================================================
   1 · FOTO REAL PROTAGONISTA — estage marfil parejo + sombra de apoyo.
   El frasco "flota" parejo sin importar el shot de origen. Pensado para
   fotos sobre fondo blanco de estudio (lo habitual del catálogo).
   ===================================================================== */
.product__media-wrapper .product__media {
  position: relative;
  background: radial-gradient(135% 108% at 50% 40%,
    #FFFFFF 0%, #FFFEFC 50%, #F5F0E6 86%, #EFE9DD 100%);
  border: 0.1rem solid rgba(var(--color-foreground), 0.10);
  border-radius: 1.4rem;
  overflow: hidden;
}
@media screen and (max-width: 749px) {
  .product__media-wrapper .product__media-item .product__media {
    aspect-ratio: 4 / 5;
    display: grid;
    place-items: center;
    padding: 3.6rem 3.4rem 4.6rem;
  }
}
.product__media-wrapper .product__media img {
  object-fit: contain;
  transition: transform 0.5s var(--perfume-ease-select, var(--ease-select)),
              opacity 0.35s var(--perfume-ease-select, var(--ease-select));
}
.product__media-wrapper .product__media-item .product__media::after {
  content: "";
  position: absolute; left: 50%; bottom: 4.2rem; transform: translateX(-50%);
  width: 46%; height: 2.4rem; border-radius: 50%;
  background: radial-gradient(ellipse at center,
    rgba(27, 21, 16, 0.20), rgba(27, 21, 16, 0) 70%);
  filter: blur(5px); z-index: 0; pointer-events: none;
}
.product__media-wrapper .product__media img { position: relative; z-index: 1; }
/* OPCIONAL — fotos con fondos off-white/dispares: descomentá para fundir el
   fondo claro contra el estage marfil. `multiply` tiñe frascos muy claros;
   probá por familia olfativa antes de dejarlo global.
   .product__media-wrapper .product__media img { mix-blend-mode: multiply; } */

.perfume-vendor {
  display: inline-block;
  margin-bottom: 0.6rem;
  text-decoration: none;
  opacity: 0.75;
}
.perfume-vendor:hover { opacity: 1; }
.perfume-title { margin: 0 0 1rem; }
.product-app-blocks { margin-top: 3.6rem; }
.perfume-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 0.7rem;
  margin: 0;
  padding: 0;
}
.perfume-chip {
  font-size: 1.1rem;
  font-weight: 600;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  line-height: 1.2;
  padding: 0.6rem 1.1rem;
  border: 0.1rem solid rgba(var(--color-foreground), 0.14);
  border-radius: 999px;
  color: rgba(var(--color-foreground), 0.78);
  background: rgb(var(--color-background));
}
.perfume-chip--accent {
  border-color: var(--perfume-soft-line);
  color: var(--perfume-accent-ink);
  background: var(--perfume-soft-bg);
}
/* Overline de sección: Montserrat 600, mayúscula, tracking abierto. */
.perfume-section-title {
  font-family: var(--font-body, var(--font-body-family));
  text-transform: uppercase;
  color: rgba(var(--color-foreground), 0.6);
  font-size: 1.15rem; font-weight: 600; letter-spacing: 0.14em; margin: 0 0 1.4rem;
}
/* Label de grupo/medidor de ficha: suave, minúscula, NO compite con la overline (= mockup). */
.perfume-ficha__label {
  font-family: var(--font-body, var(--font-body-family));
  font-size: 1.1rem; font-weight: 400; letter-spacing: 0.02em;
  color: rgba(var(--color-foreground), 0.62); margin: 0 0 0.8rem;
}
.perfume-pyramid { margin-top: 2.4rem; }
.perfume-pyramid__tier {
  display: grid;
  grid-template-columns: 8.4rem 1fr;
  gap: 1.4rem;
  align-items: baseline;
  padding: 1.1rem 0;
  border-bottom: 0.1rem solid rgba(var(--color-foreground), 0.08);
}
.perfume-pyramid__tier:last-child { border-bottom: none; }
.perfume-pyramid__label {
  font-family: var(--font-body, var(--font-body-family));
  font-size: 1.1rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--perfume-accent-ink);
}
.perfume-pyramid__notes {
  font-family: var(--font-accent);
  font-style: italic;
  font-size: 1.6rem;
  line-height: 1.4;
  color: rgb(var(--color-foreground));
}
/* ---- price block · jerarquía: el precio de lista MANDA ---- */
.perfume-price-row { display: flex; align-items: baseline; flex-wrap: wrap; gap: 1rem; }
.perfume-price-row .price { margin: 0; }
.perfume-perml {
  font-family: var(--font-display);
  font-size: 1.5rem; letter-spacing: 0.04em;
  color: var(--perfume-accent-ink);
  font-variant-numeric: tabular-nums;
}

/* Transferencia = beneficio SECUNDARIO (verde sobrio, no compite). */
.perfume-transfer { margin-top: 1.1rem; }
.perfume-transfer__chip {
  display: inline-flex; align-items: center; gap: 0.8rem;
  background: var(--perfume-ok-bg);
  border: 0.1rem solid var(--perfume-ok-line);
  border-radius: 999px;
  padding: 0.5rem 0.7rem 0.5rem 1.2rem;
}
.perfume-transfer__chip b {
  font-family: var(--font-display); font-weight: 400;
  font-size: 1.7rem; letter-spacing: 0.02em; line-height: 1;
  color: var(--perfume-ok); font-variant-numeric: tabular-nums;
}
.perfume-transfer__chip span {
  font-size: 1.05rem; font-weight: 600; letter-spacing: 0.04em; text-transform: uppercase;
  color: var(--perfume-ok);
  background: rgba(36, 106, 69, 0.10);
  border-radius: 999px; padding: 0.3rem 0.9rem;
}
.perfume-transfer__microcopy { margin: 0.6rem 0 0; font-size: 1.15rem; color: rgba(var(--color-foreground), 0.55); }

/* Cuotas: gris, discretas. */
.perfume-cuotas { margin: 1.1rem 0 0; font-size: 1.3rem; line-height: 1.4; color: rgba(var(--color-foreground), 0.6); }
.perfume-cuotas .installments__amount { color: rgba(var(--color-foreground), 0.85); font-weight: 600; }
.perfume-cuotas .installments__more { color: rgba(var(--color-foreground), 0.6); }

/* ---- selector radio-cards · selección clarísima + $/ml jerárquico ---- */
.perfume-selector { border: 0; padding: 0; margin: 2.4rem 0 0; min-width: 0; }
.perfume-selector__legend {
  font-family: var(--font-body, var(--font-body-family));
  font-size: 1.15rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase;
  color: rgba(var(--color-foreground), 0.6);
  margin: 0 0 1.1rem; padding: 0;
}
.perfume-card {
  display: flex; align-items: center; gap: 1.3rem;
  border: 0.15rem solid rgba(var(--color-foreground), 0.14);
  border-radius: 1rem; padding: 1.3rem 1.4rem; margin-bottom: 0.9rem;
  background: rgb(var(--color-background));
  cursor: pointer;
  transition: border-color var(--perfume-dur-select) var(--perfume-ease-select),
              background   var(--perfume-dur-select) var(--perfume-ease-select),
              box-shadow   var(--perfume-dur-select) var(--perfume-ease-select),
              transform    var(--perfume-dur-tap)    var(--perfume-ease-select);
}
.perfume-card:active { transform: scale(0.97); }
.perfume-card__input:checked + .perfume-card {
  border-color: var(--perfume-accent);
  background: #FCF7EF;
  box-shadow: 0 6px 18px rgba(143, 67, 41, 0.10);
}
.perfume-card__input:focus-visible + .perfume-card {
  outline: 0.2rem solid var(--perfume-accent-ink); outline-offset: 0.2rem;
}
.perfume-card__input.disabled + .perfume-card { opacity: 0.5; }
.perfume-card__radio {
  width: 2rem; height: 2rem; border-radius: 50%;
  border: 0.2rem solid #C7BBA6; flex: none; display: grid; place-items: center;
  transition: border-color var(--perfume-dur-select) var(--perfume-ease-select),
              background    var(--perfume-dur-select) var(--perfume-ease-select);
}
.perfume-card__input:checked + .perfume-card .perfume-card__radio {
  border-color: var(--perfume-accent); background: var(--perfume-accent);
}
.perfume-card__radio i {
  width: 0.7rem; height: 0.4rem; margin-top: -0.1rem;
  border-left: 0.2rem solid #fff; border-bottom: 0.2rem solid #fff;
  transform: rotate(-45deg) scale(0); transform-origin: center;
  transition: transform var(--perfume-dur-select) var(--perfume-ease-select);
}
.perfume-card__input:checked + .perfume-card .perfume-card__radio i { transform: rotate(-45deg) scale(1); }
.perfume-card__body { flex: 1 1 auto; min-width: 0; }
.perfume-card__name { font-weight: 600; font-size: 1.45rem; display: flex; align-items: center; flex-wrap: wrap; gap: 0.5rem; }
.perfume-card__sub { display: block; font-size: 1.2rem; color: rgba(var(--color-foreground), 0.6); margin-top: 0.2rem; }
.perfume-card__sub--out { color: var(--perfume-alert); font-weight: 600; }
.perfume-card__price { text-align: right; flex: none; }
.perfume-card__price b {
  display: block; font-family: var(--font-display); font-weight: 400;
  font-size: 2.3rem; line-height: 1; letter-spacing: 0.02em; font-variant-numeric: tabular-nums;
}
.perfume-card__perml { font-family: var(--font-display); font-size: 1.25rem; letter-spacing: 0.04em; color: var(--perfume-accent-ink); }
.perfume-card__perml.is-muted { color: rgba(var(--color-foreground), 0.45); font-size: 1.15rem; }
.perfume-card__perml.is-best  { color: var(--perfume-ok); }
.perfume-badge {
  font-size: 0.95rem; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase;
  border-radius: 0.4rem; padding: 0.2rem 0.7rem; white-space: nowrap; line-height: 1.4;
}
.perfume-badge--top { color: var(--perfume-accent-ink); background: rgba(var(--perfume-accent-rgb), 0.12); border: 0.1rem solid rgba(var(--perfume-accent-rgb), 0.40); }
.perfume-badge--ml  { color: var(--perfume-ok); background: var(--perfume-ok-bg); border: 0.1rem solid var(--perfume-ok-line); }
.perfume-decant-note {
  font-size: 1.2rem; color: var(--perfume-alert);
  background: var(--perfume-alert-bg); border: 0.1rem solid var(--perfume-alert-line);
  border-radius: 0.8rem; padding: 0.9rem 1.2rem; margin-top: 0.4rem; line-height: 1.45;
}
.perfume-decant-note > :first-child { margin-top: 0; }
.perfume-decant-note > :last-child { margin-bottom: 0; }

/* ---- ATC buttons: tipografía Bebas (como el mockup) + feedback de tap ---- */
/* `font-size`/`font-weight` con !important para ganarle al bloque global heredado
   (base.css → `.button,button[type="submit"]{font-size:1rem!important;font-weight:600!important}`).
   El payment button ("Comprar ahora") = .shopify-payment-button__button--unbranded. */
.product-form__buttons .button,
.product-form__buttons .shopify-payment-button__button--unbranded {
  font-family: var(--font-display);
  font-weight: 400 !important;
  font-size: 2.1rem !important;
  letter-spacing: 0.06em;
  transition: transform var(--perfume-dur-tap) var(--perfume-ease-select),
              background-color var(--perfume-dur-select) var(--perfume-ease-select),
              box-shadow var(--perfume-dur-select) var(--perfume-ease-select);
}
.product-form__buttons .button:active,
.product-form__buttons .shopify-payment-button__button--unbranded:active { transform: scale(0.97); }
/* "Comprar ahora" (checkout dinámico) NO entra en el flex-center de base.css
   (esa regla excluye .shopify-payment-button__button--unbranded), y como el botón
   es flex por el spinner, el texto cae a la izquierda → lo centro acá. */
.product-form__buttons .shopify-payment-button__button--unbranded {
  display: flex;
  align-items: center;
  justify-content: center;
}
/* "Comprar ahora" (dynamic checkout) = acción SECUNDARIA en la paleta Paper/Terracota:
   borde terracota + texto tinta + fondo papel, jerárquicamente debajo del ATC sólido.
   Sense lo pinta con --color-button (oscuro/casi negro); lo neutralizamos. !important
   para ganarle a section-main-product.css, y matamos los anillos ::before/::after de Dawn
   (que dibujan el borde/sombra con el color de botón oscuro). */
.product-form__buttons .shopify-payment-button__button--unbranded {
  background: rgb(var(--color-background)) !important;
  color: rgb(var(--color-foreground)) !important;
  border: 0.15rem solid var(--perfume-accent-ink) !important;
}
.product-form__buttons .shopify-payment-button__button--unbranded::before { box-shadow: none !important; }
.product-form__buttons .shopify-payment-button__button--unbranded::after { display: none !important; }
.product-form__buttons .shopify-payment-button__button--unbranded:hover,
.product-form__buttons .shopify-payment-button__button--unbranded:hover:not([disabled]) {
  background: rgba(var(--perfume-accent-rgb), 0.06) !important;
}

/* ---- pay reassurance ---- */
.perfume-pay { margin: 1.2rem 0 0; font-size: 1.1rem; color: rgba(var(--color-foreground), 0.55); text-align: center; letter-spacing: 0.02em; }

/* ---- trust strip ---- */
.perfume-trust {
  display: flex; gap: 1.1rem; align-items: flex-start;
  margin-top: 2rem; padding: 1.3rem 1.4rem;
  border: 0.1rem solid rgba(var(--color-foreground), 0.12);
  border-radius: 0.8rem; background: rgb(var(--color-background));
}
.perfume-trust__icon {
  flex: none; width: 3.4rem; height: 3.4rem; border-radius: 0.8rem;
  background: rgba(var(--perfume-accent-rgb), 0.12); color: var(--perfume-accent-ink);
  display: grid; place-items: center;
}
.perfume-trust__title { font-size: 1.3rem; font-weight: 600; margin: 0; }
.perfume-trust__text { font-size: 1.2rem; opacity: 0.7; margin: 0.2rem 0 0; line-height: 1.45; }

/* ---- shipping ---- */
.perfume-ship {
  margin-top: 2.4rem; border: 0.1rem solid rgba(var(--color-foreground), 0.12);
  border-radius: 0.8rem; overflow: hidden;
}
.perfume-ship__row { display: flex; gap: 1.1rem; align-items: flex-start; padding: 1.2rem 1.4rem; }
.perfume-ship__row + .perfume-ship__row { border-top: 0.1rem solid rgba(var(--color-foreground), 0.1); }
.perfume-ship__icon { flex: none; color: var(--perfume-accent-ink); }
.perfume-ship__body { flex: 1 1 auto; min-width: 0; }
.perfume-ship__title { font-weight: 600; font-size: 1.3rem; margin: 0; }
.perfume-ship__text { font-size: 1.25rem; opacity: 0.8; margin: 0; line-height: 1.4; }
.perfume-ship__body .free-ship { margin: 0.6rem 0 0; }
.perfume-ship__body .free-ship__text { text-align: left; margin-bottom: 0.5rem; font-size: 1.2rem; }

/* ---- ficha: notes + meters ---- */
.perfume-ficha { margin-top: 2.4rem; }
.perfume-note {
  font-size: 1.25rem; font-weight: 400; color: rgba(var(--color-foreground), 0.78);
  background: rgb(var(--color-background));
  border: 0.1rem solid rgba(var(--color-foreground), 0.14);
  border-radius: 0.4rem; padding: 0.6rem 1.1rem; line-height: 1.2;
}
.perfume-ficha__group { margin-top: 1.6rem; }
.perfume-meters {
  display: flex; flex-wrap: wrap; gap: 2rem 2.4rem;
  margin-top: 1.8rem; padding-top: 1.8rem;
  border-top: 0.1rem solid rgba(var(--color-foreground), 0.08);
}
.perfume-meter__bar { display: flex; align-items: center; gap: 0.9rem; }
.perfume-bars { display: inline-flex; gap: 0.4rem; }
.perfume-bars i { width: 2rem; height: 0.6rem; border-radius: 0.3rem; background: #E2D8C4; }
.perfume-bars i.on { background: var(--perfume-accent); }
.perfume-meter__v { font-weight: 600; font-size: 1.25rem; color: rgba(var(--color-foreground), 0.78); }
.perfume-occ { display: flex; flex-wrap: wrap; gap: 0.7rem; }
.perfume-occ span {
  display: inline-flex; align-items: center; gap: 0.6rem; font-size: 1.25rem;
  color: rgba(var(--color-foreground), 0.78); background: rgb(var(--color-background));
  border: 0.1rem solid rgba(var(--color-foreground), 0.14); border-radius: 0.4rem; padding: 0.6rem 1rem;
}

/* ---- description (aroma en Fraunces itálica) + inspired ---- */
.perfume-description { margin-top: 2.4rem; }
.perfume-description p {
  font-family: var(--font-accent); font-style: italic; font-weight: 400;
  font-size: 1.8rem; line-height: 1.5; color: rgb(var(--color-foreground)); margin: 0;
}
.perfume-description p + p { margin-top: 1.3rem; }
.perfume-inspired { margin-top: 1.6rem; border-left: 0.2rem solid var(--perfume-accent); padding-left: 1.2rem; }
.perfume-inspired__text { font-size: 1.3rem; color: rgba(var(--color-foreground), 0.8); margin: 0; line-height: 1.5; }
.perfume-inspired__legal { display: block; margin-top: 0.5rem; font-size: 1.1rem; color: rgba(var(--color-foreground), 0.55); line-height: 1.5; }
/* Precio de lista domina (Bebas). El tachado (compare-at) queda chico. */
.product__info-container .price .price-item {
  font-family: var(--font-display);
  font-variant-numeric: tabular-nums;
  letter-spacing: 0.02em;
}
.product__info-container .price--large .price__regular .price-item,
.product__info-container .price--large .price__sale .price-item--sale {
  font-size: clamp(4.6rem, 13vw, 5.6rem);
  line-height: 0.9;
}

/* ---- Foco visible AA ---- */
.product__info-container a:focus-visible,
.product__info-container .button:focus-visible,
.thumbnail:focus-visible,
.sticky-atc__button:focus-visible {
  outline: 0.2rem solid var(--perfume-accent); outline-offset: 0.2rem;
}
@media (prefers-reduced-motion: reduce) {
  .perfume-card, .perfume-card__radio, .perfume-card__radio i,
  .product-form__buttons .button, .product-form__buttons .shopify-payment-button__button--unbranded,
  .sticky-atc, .sticky-atc__button,
  .product__media-wrapper .product__media img { transition: none; }
  .perfume-card:active, .product-form__buttons .button:active,
  .product-form__buttons .shopify-payment-button__button--unbranded:active,
  .sticky-atc__button:active { transform: none; }
}
{% endstylesheet %}

