{% comment %}
  Hero Calmi – Solo Video (versión final optimizada)
{% endcomment %}

{{ 'component-deferred-media.css' | asset_url | stylesheet_tag }}

{% style %}

/* --- ROOT --- */
.hero-{{ section.id }} {
  position: relative;
  padding-top: {{ section.settings.padding_top }}px;
  padding-bottom: {{ section.settings.padding_bottom }}px;
}

/* --- DESKTOP LAYOUT --- */
.hero-{{ section.id }}__inner {
  max-width: {{ settings.page_width }}px;
  margin: 0 auto;
  padding: 0 20px;
  display: grid;
  grid-template-columns: 1.1fr 1fr;
  gap: 40px;
  align-items: center;
}

.hero-{{ section.id }}__content {
  text-align: left;
}

.hero-{{ section.id }}__badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 4px 10px;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.7);
  font-size: 12px;
  margin-bottom: 10px;
}

.hero-{{ section.id }}__title {
  margin-bottom: 8px;
}

.hero-{{ section.id }}__subtitle {
  margin-bottom: 18px;
  font-size: 1.6rem;
  line-height: 1.5;
  opacity: 0.9;
}

.hero-{{ section.id }}__buttons {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  margin-bottom: 16px;
}

.hero-{{ section.id }}__buttons .button {
  min-width: 160px;
}

.hero-{{ section.id }}__benefits {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  opacity: 0.85;
  font-size: .9rem;
}

.hero-{{ section.id }}__benefit {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 4px 12px;
  border-radius: 999px;
  background: rgba(0,0,0,.05);
}

/* VIDEO WRAPPER */
.hero-{{ section.id }}__media-wrapper {
  border-radius: 20px;
  overflow: hidden;
  box-shadow: 0 18px 40px rgba(15,23,42,.28);
}

/* --- MOBILE FIX --- */
@media screen and (max-width: 749px) {

  .hero-{{ section.id }} {
    padding-top: {{ section.settings.padding_top | times: 0.55 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.55 | round: 0 }}px;
  }

  /* MOBILE LAYOUT: VIDEO ARRIBA */
  .hero-{{ section.id }}__inner {
    display: flex !important;
    flex-direction: column !important;
    gap: 24px;
    padding: 0 !important;
  }

  .hero-{{ section.id }}__media {
    padding: 0 16px; /* agrega aire lateral al video */
  }

  .hero-{{ section.id }}__media {
    order: 1;
    width: 100%;
  }

  .hero-{{ section.id }}__media-wrapper {
    border-radius: 14px;
    margin: 0 auto;
    width: 100%;
  }

  video, iframe {
    width: 100%;
    height: auto;
    display: block;
  }

  .hero-{{ section.id }}__content {
    order: 2;
    text-align: center !important;
    width: 100%;
    padding: 0 16px;
  }

  .hero-{{ section.id }}__title {
    font-size: 1.85rem !important;
    line-height: 1.22;
    margin-bottom: 8px;
  }

  .hero-{{ section.id }}__subtitle {
    font-size: 1.28rem;
    line-height: 1.42;
    margin-bottom: 18px;
  }

  .hero-{{ section.id }}__buttons {
    flex-direction: column;
    width: 100%;
    gap: 12px;
  }

  .hero-{{ section.id }}__buttons .button {
    width: 100%;
    padding: 14px;
    font-size: 1.2rem;
    border-radius: 10px;
  }

  /* BENEFITS SCROLL */
  .hero-{{ section.id }}__benefits {
    overflow-x: auto;
    flex-wrap: nowrap;
    gap: 10px;
    padding-bottom: 8px;
    -webkit-overflow-scrolling: touch;
  }

  .hero-{{ section.id }}__benefit {
    white-space: nowrap;
    padding: 6px 16px;
  }
}

{% endstyle %}

{%- liquid
  assign video_id = section.settings.video.id | default: section.settings.video_url.id
  assign alt = section.settings.description | default: section.settings.heading | escape
-%}

<section class="hero-{{ section.id }} color-{{ section.settings.color_scheme }} gradient">

  <div class="hero-{{ section.id }}__inner">

    <div class="hero-{{ section.id }}__content page-width">

      {% if section.settings.show_badge %}
        <div class="hero-{{ section.id }}__badge">
          <span class="hero-{{ section.id }}__badge-main">{{ section.settings.badge_main }}</span>
          {% if section.settings.badge_sub %}
            <span class="hero-{{ section.id }}__badge-sub">{{ section.settings.badge_sub }}</span>
          {% endif %}
        </div>
      {% endif %}

      {% unless section.settings.heading == blank %}
        <h1 class="hero-{{ section.id }}__title inline-richtext {{ section.settings.heading_size }}">
          {{ section.settings.heading }}
        </h1>
      {% endunless %}

      {% unless section.settings.subheading == blank %}
        <div class="hero-{{ section.id }}__subtitle rte">{{ section.settings.subheading }}</div>
      {% endunless %}

      {% if section.settings.button_label_1 or section.settings.button_label_2 %}
        <div class="hero-{{ section.id }}__buttons">

          {% if section.settings.button_label_1 %}
            <a class="button button--primary" href="{{ section.settings.button_link_1 | default: '#' }}">
              {{ section.settings.button_label_1 }}
            </a>
          {% endif %}

          {% if section.settings.button_label_2 %}
            <a class="button button--secondary" href="{{ section.settings.button_link_2 | default: '#' }}">
              {{ section.settings.button_label_2 }}
            </a>
          {% endif %}

        </div>
      {% endif %}

      {% if section.settings.benefit_1 or section.settings.benefit_2 or section.settings.benefit_3 %}
        <div class="hero-{{ section.id }}__benefits">

          {% if section.settings.benefit_1 %}
            <div class="hero-{{ section.id }}__benefit">{{ section.settings.benefit_1 }}</div>
          {% endif %}

          {% if section.settings.benefit_2 %}
            <div class="hero-{{ section.id }}__benefit">{{ section.settings.benefit_2 }}</div>
          {% endif %}

          {% if section.settings.benefit_3 %}
            <div class="hero-{{ section.id }}__benefit">{{ section.settings.benefit_3 }}</div>
          {% endif %}

        </div>
      {% endif %}

    </div>

    <div class="hero-{{ section.id }}__media">

      {% if section.settings.video %}
        <div class="hero-{{ section.id }}__media-wrapper">
          {{ section.settings.video | video_tag: autoplay: true, loop: true, muted: true, controls: false, playsinline: true }}
        </div>

      {% else %}
        <deferred-media class="hero-{{ section.id }}__media-wrapper deferred-media" data-media-id="{{ video_id }}">
          <button type="button" class="media deferred-media__poster" aria-label="{{ alt }}">
            <span class="deferred-media__poster-button motion-reduce">
              <span class="svg-wrapper">{{ 'icon-play.svg' | inline_asset_content }}</span>
            </span>
          </button>

          <template>
            {% assign loop = section.settings.enable_video_looping %}
            {% if section.settings.video_url.type == 'youtube' %}
              <iframe
                src="https://www.youtube.com/embed/{{ video_id }}?autoplay=1&mute=1{% if loop %}&loop=1&playlist={{ video_id }}{% endif %}"
                allow="autoplay; encrypted-media" allowfullscreen title="{{ alt }}">
              </iframe>
            {% else %}
              <iframe
                src="https://player.vimeo.com/video/{{ video_id }}?autoplay=1&muted=1{% if loop %}&loop=1{% endif %}"
                allow="autoplay; encrypted-media" allowfullscreen title="{{ alt }}">
              </iframe>
            {% endif %}
          </template>
        </deferred-media>
      {% endif %}

    </div>

  </div>

</section>

{% schema %}
{
  "name": "Hero Calmi (Solo Video)",
  "settings": [
    { "type": "checkbox", "id": "show_badge", "label": "Mostrar badge", "default": true },
    { "type": "text", "id": "badge_main", "label": "Badge principal", "default": "+4.8★ mamás y familias felices" },
    { "type": "text", "id": "badge_sub", "label": "Badge secundario", "default": "Respiración real + latidos calmantes" },

    { "type": "inline_richtext", "id": "heading", "label": "Título", "default": "El peluche con respiración real que calma de verdad." },
    { "type": "select", "id": "heading_size", "label": "Tamaño del título", "options": [
      { "value": "h2", "label": "H2" },
      { "value": "h1", "label": "H1" },
      { "value": "h0", "label": "H0" }
    ], "default": "h1" },
    { "type": "richtext", "id": "subheading", "label": "Subtítulo", "default": "<p>Simula respiración real para relajar y acompañar.</p>" },

    { "type": "header", "content": "Botones" },
    { "type": "text", "id": "button_label_1", "label": "Botón principal", "default": "Ver línea Bebés" },
    { "type": "url", "id": "button_link_1", "label": "Link botón 1" },
    { "type": "text", "id": "button_label_2", "label": "Botón secundario", "default": "Ver línea Mascotas" },
    { "type": "url", "id": "button_link_2", "label": "Link botón 2" },

    { "type": "header", "content": "Beneficios" },
    { "type": "text", "id": "benefit_1", "label": "Beneficio 1", "default": "40% OFF lanzamiento" },
    { "type": "text", "id": "benefit_2", "label": "Beneficio 2", "default": "Envío gratis a todo el país" },
    { "type": "text", "id": "benefit_3", "label": "Beneficio 3", "default": "30 días de prueba o reembolso" },

    { "type": "header", "content": "Video" },
    { "type": "video", "id": "video", "label": "Video subido" },
    { "type": "video_url", "id": "video_url", "label": "URL YouTube/Vimeo", "accept": ["youtube","vimeo"] },
    { "type": "text", "id": "description", "label": "Texto alternativo", "default": "Video demostración" },
    { "type": "checkbox", "id": "enable_video_looping", "label": "Loop", "default": true },

    { "type": "header", "content": "Diseño" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Esquema de color", "default": "scheme-1" },
    { "type": "range", "id": "padding_top", "label": "Padding superior", "min": 0, "max": 120, "step": 4, "default": 60 },
    { "type": "range", "id": "padding_bottom", "label": "Padding inferior", "min": 0, "max": 120, "step": 4, "default": 60 }
  ],
  "presets": [{ "name": "Hero Calmi (Solo Video)" }]
}
{% endschema %}
