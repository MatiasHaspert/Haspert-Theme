        {
          "type": "item",
          "settings": {
            "question": "¿Lo puedo lavar?",
            "answer": "<p>Sí. Solo tenés que retirar el módulo interno y podés lavar el peluche en lavarropas con ciclo delicado.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}