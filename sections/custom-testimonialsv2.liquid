{% comment %}
  SECCIÓN SHOPIFY: Testimonios estilo "Chat Screenshot"
  Corregida para theme-check (width + height en imágenes)
{% endcomment %}

<style>
  .chat-testimonials {
    max-width: 1000px;
    margin: 0 auto;
    padding: 3rem 1rem;
  }

  .chat-testimonials__wrapper {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .chat-bubble {
    display: flex;
    gap: 1.2rem;
    padding: 1.4rem 1.6rem;
    border-radius: 18px;
    background: #fff;
    box-shadow: 0 4px 15px rgba(0,0,0,0.08);
    max-width: 85%;
    position: relative;
    align-items: flex-start;
  }

  .chat-bubble--right {
    margin-left: auto;
    background: #f6f3ff;
  }

  .chat-bubble__quote {
    position: absolute;
    top: 1rem;
    right: 1.2rem;
    color: #b25a3c;
    opacity: 0.18;
    pointer-events: none;
  }

  .chat-bubble__quote svg {
    width: 2.8rem;
    height: 2.8rem;
    display: block;
  }

  .chat-bubble__avatar {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }

  .chat-bubble__content {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .chat-bubble__name {
    font-weight: 600;
    font-size: 1.5rem;
  }

  .chat-bubble__text {
    font-size: 1.45rem;
    line-height: 1.45;
    opacity: 0.85;
  }

  .chat-bubble__stars {
    width: 90px;
    height: 18px;
    margin-top: 0.3rem;
  }

  @media (max-width: 768px) {
    .chat-bubble {
      max-width: 95%;
    }
  }
</style>

<div class="chat-testimonials">
  {% if section.settings.title != blank %}
    <h2 class="center" style="margin-bottom: 2rem; font-size: 2.4rem; font-weight: 700;">{{ section.settings.title }}</h2>
  {% endif %}

  <div class="chat-testimonials__wrapper">
    {% for block in section.blocks %}
      <div class="chat-bubble {% if block.settings.align == 'right' %}chat-bubble--right{% endif %}">
        {%- if section.settings.icon != 'none' -%}
          <span class="chat-bubble__quote" aria-hidden="true">{%- render 'icon-line', icon: section.settings.icon -%}</span>
        {%- endif -%}
        {% if block.settings.person_image != blank %}
          {%- comment -%}
            Usamos image_url para generar src y añadimos width/height requeridos por theme-check.
            Mostramos la imagen a 52x52 en CSS; aquí ponemos width/height HTML iguales.
          {%- endcomment -%}
          <img
            src="{{ block.settings.person_image | image_url: width: 104 }}"
            width="52"
            height="52"
            class="chat-bubble__avatar"
            alt="{{ block.settings.name | escape }}"
            loading="lazy"
          >
        {% endif %}

        <div class="chat-bubble__content">
          {% if block.settings.name != blank %}
            <span class="chat-bubble__name">{{ block.settings.name }}</span>
          {% endif %}

          {% if block.settings.rating_image != blank %}
            {%- comment -%}
              Para la imagen de estrellas usamos un tamaño fijo visual (90x18).
              El src se genera con una resolucion mayor (x2) por si se muestra en pantallas retina.
            {%- endcomment -%}
            <div class="testimonial-rating" style="display:flex; gap:4px; margin-bottom:8px;">
                {% for i in (1..5) %}
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="#f6c94c" xmlns="http://www.w3.org/2000/svg">
                    <path d="M12 .587l3.668 7.568L24 9.748l-6 5.848L19.335 24 12 19.897 4.665 24 6 15.596 0 9.748l8.332-1.593z"/>
                    </svg>
                {% endfor %}
            </div>


          {% endif %}

          {% if block.settings.text != blank %}
            <p class="chat-bubble__text">{{ block.settings.text }}</p>
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Testimonios Premium",
  "tag": "section",
  "class": "section",

  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "Lo que dicen nuestros clientes"
    },
    {
      "type": "select",
      "id": "icon",
      "label": "Ícono decorativo",
      "options": [
        { "value": "none", "label": "Sin ícono" },
        { "value": "quote", "label": "Comillas" },
        { "value": "sparkle", "label": "Destello" },
        { "value": "shield", "label": "Garantía" }
      ],
      "default": "quote"
    }
  ],

  "blocks": [
    {
      "type": "testimonial_chat",
      "name": "Mensaje de chat",
      "settings": [
        {
          "type": "select",
          "id": "align",
          "label": "Alineación del mensaje",
          "default": "left",
          "options": [
            {"value": "left", "label": "Izquierda"},
            {"value": "right", "label": "Derecha"}
          ]
        },
        {
          "type": "image_picker",
          "id": "person_image",
          "label": "Foto de la persona"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Nombre",
          "default": "Nombre de la persona"
        },
        {
          "type": "image_picker",
          "id": "rating_image",
          "label": "Imagen de estrellas (opcional)"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Mensaje",
          "default": "¡Escribí acá el testimonio!"
        }
      ]
    }
  ],

  "presets": [
    {
      "name": "Testimonios Chat Screenshot",
      "blocks": [
        {"type": "testimonial_chat"},
        {"type": "testimonial_chat"},
        {"type": "testimonial_chat"}
      ]
    }
  ]
}
{% endschema %}
