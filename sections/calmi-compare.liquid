{% style %}

  /* ======================================================
     🎨 SISTEMA DE COLORES DINÁMICOS — COMPARATIVA
     ====================================================== */
  .calmi-compare-{{ section.id }} {
    --cmp-bg: {{ section.settings.bg_color }};

    --cmp-title: {{ section.settings.title_color }};
    --cmp-subtitle: {{ section.settings.subtitle_color }};

    --cmp-badge-bg: {{ section.settings.badge_bg }};
    --cmp-badge-text: {{ section.settings.badge_text_color }};

    --cmp-table-bg: {{ section.settings.table_bg }};
    --cmp-table-border: {{ section.settings.table_border }};
    --cmp-row-bg: {{ section.settings.row_bg }};
    --cmp-row-alt-bg: {{ section.settings.row_alt_bg }};

    --cmp-calmi-bg: {{ section.settings.calmi_bg }};
    --cmp-calmi-border: {{ section.settings.calmi_border }};
    --cmp-calmi-shadow: {{ section.settings.calmi_shadow }};

    --cmp-icon-yes-bg: {{ section.settings.icon_yes_bg }};
    --cmp-icon-yes-text: {{ section.settings.icon_yes_text }};
    --cmp-icon-yes-border: {{ section.settings.icon_yes_border }};

    --cmp-icon-no-bg: {{ section.settings.icon_no_bg }};
    --cmp-icon-no-text: {{ section.settings.icon_no_text }};
    --cmp-icon-no-border: {{ section.settings.icon_no_border }};
  }

  /* --- LAYOUT GENERAL --- */
  .calmi-compare-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background: var(--cmp-bg);
  }

  .calmi-compare-{{ section.id }}__inner {
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 20px;
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(0, 1fr);
    gap: 48px;
    align-items: flex-start;
  }

  /* --- TEXTOS Y BADGES --- */
  .calmi-compare-{{ section.id }}__badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 12px;
    border-radius: 999px;
    background: var(--cmp-badge-bg);
    color: var(--cmp-badge-text);
    font-size: 0.9rem;
    margin-bottom: 12px;
  }

  .calmi-compare-{{ section.id }}__badge-icon {
    font-size: 1.1rem;
  }

  .calmi-compare-{{ section.id }}__badge-text {
    font-weight: 600;
  }

  .calmi-compare-{{ section.id }}__title {
    font-size: 2.3rem;
    font-weight: 700;
    margin-bottom: 10px;
    color: var(--cmp-title);
  }

  .calmi-compare-{{ section.id }}__subtitle {
    font-size: 1.3rem;
    opacity: 0.92;
    margin-bottom: 22px;
    max-width: 560px;
    color: var(--cmp-subtitle);
  }

  .calmi-compare-{{ section.id }}__closing {
    margin-top: 20px;
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--cmp-title);
  }

  /* --- TABLA (DESKTOP) --- */
  .calmi-compare-{{ section.id }}__table-wrapper {
    border-radius: 16px;
    overflow: hidden;
    background: var(--cmp-table-bg);
    box-shadow: 0 10px 28px rgba(15,23,42,0.08);
    border: 1px solid var(--cmp-table-border);
  }

  .calmi-compare-{{ section.id }}__table-inner {
    width: 100%;
  }

  .calmi-compare-{{ section.id }}__row {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr;
    align-items: stretch;
    background: var(--cmp-row-bg);
  }

  .calmi-compare-{{ section.id }}__row--header {
    background: var(--cmp-row-alt-bg);
    font-weight: 600;
    font-size: 0.95rem;
  }

  .calmi-compare-{{ section.id }}__cell {
    padding: 12px 14px;
    border-bottom: 1px solid var(--cmp-table-border);
    font-size: 0.95rem;
  }

  /* Quitamos borde en la última fila */
  .calmi-compare-{{ section.id }}__row:last-child .calmi-compare-{{ section.id }}__cell {
    border-bottom: none;
  }

  .calmi-compare-{{ section.id }}__cell--feature {
    font-weight: 600;
    color: var(--cmp-title);
  }

  .calmi-compare-{{ section.id }}__cell--peluche {
    background: var(--cmp-table-bg);
  }

  /* --- COLUMNA DESTACADA (PREMIUM) --- */
  .calmi-compare-{{ section.id }}__cell--calmi {
    background: var(--cmp-calmi-bg);
    border-left: 4px solid var(--cmp-calmi-border);
    border-radius: 4px;
    box-shadow: var(--cmp-calmi-shadow);
    position: relative;
  }

  /* Borde interno sutil */
  .calmi-compare-{{ section.id }}__cell--calmi::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 4px;
    pointer-events: none;
    box-shadow: inset 0 0 0 1px var(--cmp-calmi-border);
  }

  /* Ajustes de bordes para primera y última celda destacada */
  .calmi-compare-{{ section.id }}__row:first-child .calmi-compare-{{ section.id }}__cell--calmi {
    border-top: 1px solid var(--cmp-calmi-border) !important;
  }

  .calmi-compare-{{ section.id }}__row:last-child .calmi-compare-{{ section.id }}__cell--calmi {
    border-bottom: 1px solid var(--cmp-calmi-border) !important;
  }

  /* --- ICONOS (Check / Cross) --- */
  .calmi-compare-{{ section.id }}__icon-label {
    display: inline-flex;
    align-items: center;
    gap: 6px !important;
  }

  .calmi-compare-{{ section.id }}__icon {
    width: 20px !important;
    height: 20px !important;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 13px !important;
    font-weight: 700;
    margin-right: 4px !important;
  }

  .calmi-compare-{{ section.id }}__icon--yes {
    background: var(--cmp-icon-yes-bg) !important;
    color: var(--cmp-icon-yes-text) !important;
    border: 1px solid var(--cmp-icon-yes-border);
  }

  .calmi-compare-{{ section.id }}__icon--no {
    background: var(--cmp-icon-no-bg) !important;
    color: var(--cmp-icon-no-text) !important;
    border: 1px solid var(--cmp-icon-no-border);
  }

  .calmi-compare-{{ section.id }}__value-text {
    font-size: 0.95rem;
  }

  /* --- MEDIA SIDE (Imagen/Video) --- */
  .calmi-compare-{{ section.id }}__media {
    width: 100%;
  }

  .calmi-compare-{{ section.id }}__media img,
  .calmi-compare-{{ section.id }}__media video {
    width: 100%;
    border-radius: 16px;
    object-fit: cover;
    box-shadow: 0 12px 28px rgba(15,23,42,0.12);
  }

  /* --- ESTADOS MÓVIL POR DEFECTO (Ocultos en Desktop) --- */
  .calmi-compare-{{ section.id }}__mobile-cards,
  .calmi-compare-{{ section.id }}__toggle-btn {
    display: none;
  }

  /* ============================================
     MOBILE / RESPONSIVE (Cards en vez de Tabla)
     ============================================ */
  @media (max-width: 749px) {

    /* Mostrar elementos móviles y ocultar tabla clásica */
    .calmi-compare-{{ section.id }}__mobile-cards,
    .calmi-compare-{{ section.id }}__toggle-btn {
      display: block;
    }

    .calmi-compare-{{ section.id }}__table-inner {
      display: none;
    }

    /* Contenedor de las cards */
    .calmi-compare-{{ section.id }}__mobile-cards {
      display: flex;
      flex-direction: column;
      gap: 18px;
      margin-top: 20px;
    }

    /* Estilo de Card Móvil */
    .calmi-compare-{{ section.id }}__mobile-card {
      background: var(--cmp-table-bg);
      border-radius: 16px;
      padding: 18px 16px;
      box-shadow: 0 6px 20px rgba(0,0,0,0.08);
      border: 1px solid var(--cmp-table-border);
      transition: all 0.25s ease;
    }

    .calmi-compare-{{ section.id }}__mobile-card.hidden-card {
      display: none;
    }

    /* Feature title */
    .calmi-compare-{{ section.id }}__mobile-feature {
      font-size: 1.15rem;
      font-weight: 700;
      margin-bottom: 12px;
      color: var(--cmp-title);
    }

    /* Fila dentro de la card */
    .calmi-compare-{{ section.id }}__mobile-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 10px;
    }

    /* Fila destacada (Calmi) */
    .calmi-compare-{{ section.id }}__mobile-row--calmi {
      padding: 8px 10px;
      background: var(--cmp-calmi-bg);
      border-left: 4px solid var(--cmp-calmi-border);
      border-radius: 6px;
      margin-top: 8px;
    }

    /* Textos y etiquetas móvil */
    .calmi-compare-{{ section.id }}__mobile-label {
      font-size: 0.95rem;
      font-weight: 600;
      color: var(--cmp-subtitle);
    }

    /* Ajuste de Iconos en móvil */
    .calmi-compare-{{ section.id }}__icon {
      font-size: 12px !important;
    }

    /* Botón "Ver más / Ver menos" */
    .calmi-compare-{{ section.id }}__toggle-btn {
      margin: 14px auto 0 auto;
      display: inline-block;
      padding: 10px 16px;
      font-size: 1rem;
      font-weight: 600;
      border-radius: 8px;
      background: #EEE6FF;
      color: #5A00A8;
      border: 1px solid #D7C6FF;
      text-align: center;
      cursor: pointer;
      user-select: none;
    }
  }

{% endstyle %}

<section class="calmi-compare-{{ section.id }}">
  <div class="calmi-compare-{{ section.id }}__inner">

    <!-- TEXT + TABLE -->
    <div>

      {% if section.settings.badge_text != blank %}
        <div class="calmi-compare-{{ section.id }}__badge">
          <span class="calmi-compare-{{ section.id }}__badge-icon">✨</span>
          <span class="calmi-compare-{{ section.id }}__badge-text">
            {{ section.settings.badge_text }}
          </span>
        </div>
      {% endif %}

      <h2 class="calmi-compare-{{ section.id }}__title">
        {{ section.settings.title }}
      </h2>

      <p class="calmi-compare-{{ section.id }}__subtitle">
        {{ section.settings.subtitle }}
      </p>

      <div class="calmi-compare-{{ section.id }}__table-wrapper">
        <div class="calmi-compare-{{ section.id }}__table-inner">

          <!-- HEADER ROW -->
          <div class="calmi-compare-{{ section.id }}__row calmi-compare-{{ section.id }}__row--header">
            <div class="calmi-compare-{{ section.id }}__cell calmi-compare-{{ section.id }}__cell--feature">
              {{ section.settings.col_feature_label }}
            </div>
            <div class="calmi-compare-{{ section.id }}__cell calmi-compare-{{ section.id }}__cell--peluche">
              {{ section.settings.col_peluche_label }}
            </div>
            <div class="calmi-compare-{{ section.id }}__cell calmi-compare-{{ section.id }}__cell--calmi">
              {{ section.settings.col_calmi_label }}
            </div>
          </div>

          <!-- DATA ROWS -->
          {% for block in section.blocks %}
            <div class="calmi-compare-{{ section.id }}__row" {{ block.shopify_attributes }}>
              <div class="calmi-compare-{{ section.id }}__cell calmi-compare-{{ section.id }}__cell--feature">
                {{ block.settings.feature }}
              </div>

              <!-- Peluche común -->
              <div class="calmi-compare-{{ section.id }}__cell calmi-compare-{{ section.id }}__cell--peluche">
                <div class="calmi-compare-{{ section.id }}__icon-label">
                  {% if block.settings.peluche_has %}
                    <span class="calmi-compare-{{ section.id }}__icon calmi-compare-{{ section.id }}__icon--yes">✔</span>
                  {% else %}
                    <span class="calmi-compare-{{ section.id }}__icon calmi-compare-{{ section.id }}__icon--no">✘</span>
                  {% endif %}
                  {% if block.settings.peluche_text != blank %}
                    <span class="calmi-compare-{{ section.id }}__value-text">
                      {{ block.settings.peluche_text }}
                    </span>
                  {% endif %}
                </div>
              </div>

              <!-- Calmi -->
              <div class="calmi-compare-{{ section.id }}__cell calmi-compare-{{ section.id }}__cell--calmi">
                <div class="calmi-compare-{{ section.id }}__icon-label">
                  {% if block.settings.calmi_has %}
                    <span class="calmi-compare-{{ section.id }}__icon calmi-compare-{{ section.id }}__icon--yes">✔</span>
                  {% else %}
                    <span class="calmi-compare-{{ section.id }}__icon calmi-compare-{{ section.id }}__icon--no">✘</span>
                  {% endif %}
                  {% if block.settings.calmi_text != blank %}
                    <span class="calmi-compare-{{ section.id }}__value-text">
                      {{ block.settings.calmi_text }}
                    </span>
                  {% endif %}
                </div>
              </div>
            </div>
          {% endfor %}

        </div>
      </div>

      <!-- MOBILE CARDS VERSION -->
      <div class="calmi-compare-{{ section.id }}__mobile-cards">
        {% for block in section.blocks %}
          <div class="calmi-compare-{{ section.id }}__mobile-card {% if forloop.index > 4 %}hidden-card{% endif %}">

            <!-- Feature -->
            <div class="calmi-compare-{{ section.id }}__mobile-feature">
              {{ block.settings.feature }}
            </div>

            <!-- Peluche común -->
            <div class="calmi-compare-{{ section.id }}__mobile-row">
              <span class="calmi-compare-{{ section.id }}__mobile-label">
                {{ section.settings.col_peluche_label }}
              </span>

              {% if block.settings.peluche_has %}
                <span class="calmi-compare-{{ section.id }}__icon calmi-compare-{{ section.id }}__icon--yes">✔</span>
              {% else %}
                <span class="calmi-compare-{{ section.id }}__icon calmi-compare-{{ section.id }}__icon--no">✘</span>
              {% endif %}
            </div>

            <!-- Calmi row -->
            <div class="calmi-compare-{{ section.id }}__mobile-row calmi-compare-{{ section.id }}__mobile-row--calmi">
              <span class="calmi-compare-{{ section.id }}__mobile-label">
                {{ section.settings.col_calmi_label }}
              </span>

              {% if block.settings.calmi_has %}
                <span class="calmi-compare-{{ section.id }}__icon calmi-compare-{{ section.id }}__icon--yes">✔</span>
              {% else %}
                <span class="calmi-compare-{{ section.id }}__icon calmi-compare-{{ section.id }}__icon--no">✘</span>
              {% endif %}
            </div>

          </div>
        {% endfor %}
      </div>
      
      <!-- Toggle button -->
      <div 
        class="calmi-compare-{{ section.id }}__toggle-btn"
        data-toggle-btn
      >
        Mostrar más
      </div>



      {% if section.settings.closing_text != blank %}
        <p class="calmi-compare-{{ section.id }}__closing">
          {{ section.settings.closing_text }}
        </p>
      {% endif %}

    </div>

    <!-- MEDIA SIDE -->
    <div class="calmi-compare-{{ section.id }}__media">
      {% if section.settings.video != blank %}
        {{ section.settings.video
          | video_tag:
            autoplay: true,
            loop: true,
            muted: true,
            playsinline: true
        }}
      {% elsif section.settings.image != blank %}
        {{ section.settings.image
          | image_url: width: 900
          | image_tag:
            width: 900,
            height: 600,
            loading: 'lazy',
            alt: section.settings.title
        }}
      {% endif %}
    </div>

  </div>
</section>


<script>
document.addEventListener("DOMContentLoaded", function() {
  const btn = document.querySelector('[data-toggle-btn]');
  const cards = document.querySelectorAll('.calmi-compare-{{ section.id }}__mobile-card.hidden-card');

  if (!btn) return;

  btn.addEventListener('click', () => {
    const isHidden = cards[0].style.display === "none" || cards[0].style.display === "";

    cards.forEach(c => {
      c.style.display = isHidden ? "block" : "none";
    });

    btn.textContent = isHidden ? "Mostrar menos" : "Mostrar más";
  });
});
</script>


