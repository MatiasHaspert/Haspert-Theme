{% comment %}
  Announcement Marquee Bar – Custom Section
  - Scroll infinito automático
  - Blocks ilimitados
  - CSS-only (sin JavaScript)
  - OS 2.0 compliant
{% endcomment %}

{% style %}

.announcement-{{ section.id }} {
  /* Sistema de colores dinámico */
  --ann-bg: {{ section.settings.bg_color }};
  --ann-text: {{ section.settings.text_color }};
  --ann-gap: 40px;
  --ann-fade: {{ section.settings.edge_fade }}px;

  background: var(--ann-bg);
  padding-top: {{ section.settings.padding_top }}px;
  padding-bottom: {{ section.settings.padding_bottom }}px;
  overflow: hidden;
  width: 100%;
}

/* Contenedor del marquee: recorta el scroll y separa los dos grupos.
   La máscara difumina el texto en los extremos para una entrada/salida suave. */
.announcement-{{ section.id }}__marquee {
  display: flex;
  gap: var(--ann-gap);
  width: 100%;
  overflow: hidden;
  -webkit-mask-image: linear-gradient(to right, transparent 0, #000 var(--ann-fade), #000 calc(100% - var(--ann-fade)), transparent 100%);
          mask-image: linear-gradient(to right, transparent 0, #000 var(--ann-fade), #000 calc(100% - var(--ann-fade)), transparent 100%);
}

/*
  Cada grupo contiene la tanda completa de frases.
  min-width: 100% garantiza que un solo grupo SIEMPRE cubra el viewport,
  evitando el hueco en blanco antes del reinicio. Con dos grupos idénticos
  desplazándose -100% - gap, el loop cierra sin salto ni costura.
*/
.announcement-{{ section.id }}__group {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: space-around;
  gap: var(--ann-gap);
  min-width: 100%;
  white-space: nowrap;
  animation: marquee-{{ section.id }} {{ section.settings.speed }}s linear infinite;
  will-change: transform;
}

.announcement-{{ section.id }}__item {
  display: inline-flex;
  align-items: center;
  gap: 0.5em;
  font-size: {{ section.settings.font_size }}px;
  font-weight: 600;
  color: var(--ann-text);
  white-space: nowrap;
}

/* Ícono SVG inline: hereda el color del texto vía currentColor */
.announcement-{{ section.id }}__icon {
  display: inline-flex;
  flex: 0 0 auto;
}

.announcement-{{ section.id }}__icon svg {
  display: block;
  width: 1.15em;
  height: 1.15em;
}

.announcement-{{ section.id }}__item a {
  color: inherit;
  text-decoration: none;
}

/* Pausa al hacer hover (por si alguien quiere leer tranquilo) */
.announcement-{{ section.id }}__marquee:hover .announcement-{{ section.id }}__group {
  animation-play-state: paused;
}

@keyframes marquee-{{ section.id }} {
  from { transform: translateX(0); }
  to   { transform: translateX(calc(-100% - var(--ann-gap))); }
}

/* Respeto a usuarios con reducción de movimiento: sin scroll, una sola tanda centrada */
@media (prefers-reduced-motion: reduce) {
  .announcement-{{ section.id }}__group {
    animation: none;
    justify-content: center;
  }

  .announcement-{{ section.id }}__group[aria-hidden="true"] {
    display: none;
  }
}

@media (max-width: 600px) {
  .announcement-{{ section.id }} {
    --ann-gap: 24px;
    --ann-fade: min({{ section.settings.edge_fade }}px, 24px);
  }

  .announcement-{{ section.id }}__group {
    animation-duration: {{ section.settings.speed_mobile }}s;
  }

  .announcement-{{ section.id }}__item {
    font-size: {{ section.settings.font_size | minus: 1 }}px;
  }
}

{% endstyle %}

<div class="announcement-{{ section.id }}">
  <div class="announcement-{{ section.id }}__marquee">

    {% comment %}
      Dos grupos idénticos. El primero es el "real" (lleva shopify_attributes
      para el editor); el segundo es la copia para el loop sin costura y se marca
      aria-hidden para que los lectores de pantalla no lean las frases dos veces.
    {% endcomment %}
    {%- for pass in (1..2) -%}
      <div class="announcement-{{ section.id }}__group"{% if pass == 2 %} aria-hidden="true"{% endif %}>
        {%- for block in section.blocks -%}
          <div class="announcement-{{ section.id }}__item"{% if pass == 1 %} {{ block.shopify_attributes }}{% endif %}>
            {%- if block.settings.icon != 'none' -%}
              <span class="announcement-{{ section.id }}__icon" aria-hidden="true">{%- render 'icon-line', icon: block.settings.icon -%}</span>
            {%- endif -%}
            <span class="announcement-{{ section.id }}__text">
              {%- if block.settings.link != blank -%}
                <a href="{{ block.settings.link }}">{{ block.settings.text | escape }}</a>
              {%- else -%}
                {{ block.settings.text | escape }}
              {%- endif -%}
            </span>
          </div>
        {%- endfor -%}
      </div>
    {%- endfor -%}

  </div>
</div>

{% schema %}
{
  "name": "Banda de Anuncios",
  "tag": "section",
  "class": "announcement-marquee-section",
  "max_blocks": 50,
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Color de fondo",
      "default": "#14161A"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Color del texto",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Tamaño del texto (px)",
      "min": 12,
      "max": 28,
      "step": 1,
      "default": 16
    },
    {
      "type": "range",
      "id": "speed",
      "label": "Velocidad desktop (segundos por ciclo)",
      "min": 5,
      "max": 60,
      "step": 1,
      "default": 20
    },
    {
      "type": "range",
      "id": "speed_mobile",
      "label": "Velocidad mobile (segundos por ciclo)",
      "min": 5,
      "max": 60,
      "step": 1,
      "default": 15
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding superior",
      "min": 0,
      "max": 40,
      "step": 5,
      "default": 10
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding inferior",
      "min": 0,
      "max": 40,
      "step": 5,
      "default": 10
    },
    {
      "type": "range",
      "id": "edge_fade",
      "label": "Desvanecido en los bordes (px)",
      "info": "Suaviza la entrada y salida del texto en los extremos. 0 = sin desvanecido.",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Anuncio",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Ícono",
          "options": [
            { "value": "none", "label": "Sin ícono" },
            { "value": "shield", "label": "Originalidad / Garantía" },
            { "value": "truck", "label": "Envío" },
            { "value": "card", "label": "Cuotas / Pago" },
            { "value": "lock", "label": "Pago seguro" },
            { "value": "return", "label": "Cambios / Devolución" },
            { "value": "sparkle", "label": "Novedad / Exclusivo" }
          ],
          "default": "none"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Texto del anuncio",
          "default": "Envío gratis a todo el país"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Enlace opcional"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Banda de Anuncios (Scrolling)",
      "category": "Texto",
      "blocks": [
        { "type": "item", "settings": { "icon": "sparkle", "text": "40% OFF por tiempo limitado" } },
        { "type": "item", "settings": { "icon": "truck", "text": "Envío gratis a todo el país" } },
        { "type": "item", "settings": { "icon": "card", "text": "Hasta 6 cuotas sin interés" } },
        { "type": "item", "settings": { "icon": "shield", "text": "Garantía de originalidad" } }
      ]
    }
  ]
}
{% endschema %}
