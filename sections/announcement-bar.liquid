{% comment %}
  Announcement Marquee Bar – Custom Section
  - Scroll infinito automático
  - Blocks ilimitados
  - CSS-only (sin JavaScript)
  - OS 2.0 compliant
{% endcomment %}

{% style %}

.announcement-{{ section.id }} {
  /* Sistema de colores dinámico */
  --ann-bg: {{ section.settings.bg_color }};
  --ann-text: {{ section.settings.text_color }};

  background: var(--ann-bg);
  padding-top: {{ section.settings.padding_top }}px;
  padding-bottom: {{ section.settings.padding_bottom }}px;
  overflow: hidden;
  width: 100%;
}

.announcement-{{ section.id }}__track-wrapper {
  width: 100%;
  overflow: hidden;
  position: relative;
}

.announcement-{{ section.id }}__track {
  display: inline-flex;
  gap: 40px;
  white-space: nowrap;
  animation: marquee-{{ section.id }} {{ section.settings.speed }}s linear infinite;
}

.announcement-{{ section.id }}__item {
  font-size: {{ section.settings.font_size }}px;
  font-weight: 600;
  color: var(--ann-text);
  white-space: nowrap;
  display: inline-block;
}

.announcement-{{ section.id }}__item a {
  color: inherit;
  text-decoration: none;
}

/* Pausa al hacer hover (por si alguien quiere leer tranquilo) */
.announcement-{{ section.id }}__track:hover {
  animation-play-state: paused;
}

@keyframes marquee-{{ section.id }} {
  from { transform: translateX(0); }
  to   { transform: translateX(-50%); }
}

/* Respeto a usuarios con reducción de movimiento */
@media (prefers-reduced-motion: reduce) {
  .announcement-{{ section.id }}__track {
    animation: none;
    transform: translateX(0);
  }
}

@media (max-width: 600px) {
  .announcement-{{ section.id }}__track {
    animation-duration: {{ section.settings.speed_mobile }}s;
    gap: 24px;
  }

  .announcement-{{ section.id }}__item {
    font-size: {{ section.settings.font_size | minus: 1 }}px;
  }
}

{% endstyle %}

<div class="announcement-{{ section.id }}">
  <div class="announcement-{{ section.id }}__track-wrapper">
    <div class="announcement-{{ section.id }}__track">

      {% comment %}
        Primera pasada: todos los bloques
      {% endcomment %}
      {%- for block in section.blocks -%}
        <div class="announcement-{{ section.id }}__item" {{ block.shopify_attributes }}>
          {% if block.settings.link != blank %}
            <a href="{{ block.settings.link }}">{{ block.settings.text | escape }}</a>
          {% else %}
            {{ block.settings.text | escape }}
          {% endif %}
        </div>
      {%- endfor -%}

      {% comment %}
        Segunda pasada: duplicación para loop perfecto
      {% endcomment %}
      {%- for block in section.blocks -%}
        <div class="announcement-{{ section.id }}__item">
          {% if block.settings.link != blank %}
            <a href="{{ block.settings.link }}">{{ block.settings.text | escape }}</a>
          {% else %}
            {{ block.settings.text | escape }}
          {% endif %}
        </div>
      {%- endfor -%}

    </div>
  </div>
</div>

{% schema %}
{
  "name": "Banda de Anuncios",
  "tag": "section",
  "class": "announcement-marquee-section",
  "max_blocks": 50,
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Color de fondo",
      "default": "#FFEAEA"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Color del texto",
      "default": "#B81F24"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Tamaño del texto (px)",
      "min": 12,
      "max": 28,
      "step": 1,
      "default": 16
    },
    {
      "type": "range",
      "id": "speed",
      "label": "Velocidad desktop (segundos por ciclo)",
      "min": 5,
      "max": 60,
      "step": 1,
      "default": 20
    },
    {
      "type": "range",
      "id": "speed_mobile",
      "label": "Velocidad mobile (segundos por ciclo)",
      "min": 5,
      "max": 60,
      "step": 1,
      "default": 15
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding superior",
      "min": 0,
      "max": 40,
      "step": 5,
      "default": 10
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding inferior",
      "min": 0,
      "max": 40,
      "step": 5,
      "default": 10
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Anuncio",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Texto del anuncio",
          "default": "🔥 40% OFF por tiempo limitado"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Enlace opcional"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Banda de Anuncios (Scrolling)",
      "category": "Texto",
      "blocks": [
        { "type": "item", "settings": { "text": "🔥 40% OFF" } },
        { "type": "item", "settings": { "text": "🚚 Envío gratis" } },
        { "type": "item", "settings": { "text": "⏳ Stock limitado" } },
        { "type": "item", "settings": { "text": "🔒 Garantía 30 días" } }
      ]
    }
  ]
}
{% endschema %}
