{%- comment -%}
  Hero de la home (Numen) — foto protagonista (mockup numen-home-mockup.html).
  Mobile (<990px): imagen full-bleed 4:5 con fundido inferior hacia el fondo del
  esquema y contenido solapado (~-34px) debajo: eyebrow → H1 → sub → CTAs apiladas.
  Desktop (≥990px): grid lado a lado (contenido izquierda, media derecha), como
  el ciclo anterior. La imagen es el LCP → eager + fetchpriority high.
  100% editable por theme editor; sin precios ni textos hardcodeados.
  Nota: el padding superior sólo aplica en desktop (en mobile la foto va al ras).
{%- endcomment -%}

{%- liquid
  assign hero_alt = section.settings.image.alt | default: section.settings.heading
-%}

<div class="hero-home color-{{ section.settings.color_scheme }} gradient">
  <div class="hero-home__grid section-{{ section.id }}-padding{% if section.settings.image == blank %} hero-home__grid--no-image{% endif %}">
    {%- if section.settings.image != blank -%}
      <div class="hero-home__media">
        {{
          section.settings.image
          | image_url: width: 1400
          | image_tag:
            loading: 'eager',
            fetchpriority: 'high',
            sizes: '(min-width: 990px) 46vw, 100vw',
            widths: '400, 600, 800, 1000, 1200, 1400',
            class: 'hero-home__image',
            alt: hero_alt
        }}
      </div>
    {%- endif -%}

    <div class="hero-home__content">
      {%- if section.settings.eyebrow != blank -%}
        <p class="hero-home__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h1 class="hero-home__title">{{ section.settings.heading | escape }}</h1>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="hero-home__subtitle">{{ section.settings.subheading | escape }}</p>
      {%- endif -%}
      {%- if section.settings.cta1_label != blank or section.settings.cta2_label != blank -%}
        <div class="hero-home__ctas">
          {%- if section.settings.cta1_label != blank -%}
            <a
              class="button button--primary hero-home__cta"
              {% if section.settings.cta1_link != blank %}href="{{ section.settings.cta1_link }}"{% else %}role="link" aria-disabled="true"{% endif %}
            >{{ section.settings.cta1_label | escape }}</a>
          {%- endif -%}
          {%- if section.settings.cta2_label != blank -%}
            <a
              class="button button--secondary hero-home__cta"
              {% if section.settings.cta2_link != blank %}href="{{ section.settings.cta2_link }}"{% else %}role="link" aria-disabled="true"{% endif %}
            >{{ section.settings.cta2_label | escape }}</a>
          {%- endif -%}
        </div>
      {%- endif -%}
      {%- if section.settings.microcopy != blank -%}
        <p class="hero-home__microcopy">{{ section.settings.microcopy | escape }}</p>
      {%- endif -%}
    </div>
  </div>
</div>

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: 0;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 990px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{% stylesheet %}
/* Mobile-first: foto full-bleed 4:5 + fundido inferior + contenido solapado */
.hero-home__media {
  position: relative;
  aspect-ratio: 4 / 5;
  max-height: 72vh;
  overflow: hidden;
}
.hero-home__media::after {
  content: "";
  position: absolute;
  inset: auto 0 0 0;
  height: 38%;
  background: linear-gradient(180deg, transparent, rgba(var(--color-background), 0.94));
  pointer-events: none;
}
.hero-home__image {
  display: block;
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.hero-home__content {
  position: relative;
  z-index: 1;
  margin-top: -3.4rem;
  padding: 0 1.5rem;
  max-width: 56rem;
}
.hero-home__grid--no-image .hero-home__content {
  margin-top: 0;
  padding-top: 3rem;
}
.hero-home__eyebrow {
  font-family: var(--font-body-family);
  font-weight: 600;
  font-size: 1.2rem;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--accent-ink);
  margin: 0 0 0.6rem;
}
.hero-home__title {
  margin: 0 0 1rem;
}
@media screen and (max-width: 989px) {
  .hero-home__title {
    font-size: 4.6rem;
    line-height: 0.92;
    letter-spacing: 0.01em;
  }
}
.hero-home__subtitle {
  font-family: var(--font-accent);
  font-style: italic;
  font-weight: var(--font-accent-weight, 500);
  font-size: clamp(1.7rem, 2.4vw, 2.4rem);
  line-height: 1.4;
  opacity: 0.9;
  margin: 0 0 1.8rem;
  max-width: 32ch;
}
.hero-home__ctas {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}
.hero-home__cta {
  margin: 0;
  width: 100%;
}
.hero-home__microcopy {
  font-size: 1.3rem;
  opacity: 0.75;
  margin: 1.6rem 0 0;
}
@media screen and (min-width: 750px) {
  .hero-home__content {
    padding: 0 5rem;
  }
}
@media screen and (min-width: 990px) {
  .hero-home__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    max-width: var(--page-width);
    margin: 0 auto;
    padding-left: 5rem;
    padding-right: 5rem;
  }
  .hero-home__grid--no-image {
    grid-template-columns: 1fr;
  }
  .hero-home__media {
    order: 2;
    aspect-ratio: auto;
    max-height: none;
    overflow: visible;
  }
  .hero-home__media::after {
    content: none;
  }
  .hero-home__image {
    height: auto;
    object-fit: contain;
    border-radius: var(--media-radius, 0.4rem);
  }
  .hero-home__content {
    order: 1;
    margin-top: 0;
    padding: 0;
    max-width: none;
  }
  .hero-home__ctas {
    flex-direction: row;
    flex-wrap: wrap;
  }
  .hero-home__cta {
    width: auto;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Hero home",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Esquema de color", "default": "scheme-1" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Perfumería curada" },
    { "type": "text", "id": "heading", "label": "Título", "default": "Originales que podés verificar frasco por frasco" },
    { "type": "text", "id": "subheading", "label": "Subtítulo (cursiva)", "default": "Importados árabes, de diseñador y nicho. Lote visible, video del frasco antes de comprar." },
    { "type": "header", "content": "Botones" },
    { "type": "text", "id": "cta1_label", "label": "CTA primario", "default": "Ver perfumes" },
    { "type": "url", "id": "cta1_link", "label": "Link CTA primario" },
    { "type": "text", "id": "cta2_label", "label": "CTA secundario", "default": "Cómo verificamos originalidad" },
    { "type": "url", "id": "cta2_link", "label": "Link CTA secundario" },
    { "type": "header", "content": "Imagen y microcopy" },
    { "type": "image_picker", "id": "image", "label": "Foto hero", "info": "Se muestra 4:5 en mobile (recorte centrado). Es el LCP: subí una foto real optimizada (~1400px de ancho)." },
    { "type": "text", "id": "microcopy", "label": "Microcopy (garantía / reseñas)", "default": "Garantía de originalidad · Devolución sin vueltas" },
    { "type": "header", "content": "Espaciado" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Padding superior (solo desktop)", "default": 64 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Padding inferior", "default": 40 }
  ],
  "presets": [
    { "name": "Hero home" }
  ]
}
{% endschema %}
