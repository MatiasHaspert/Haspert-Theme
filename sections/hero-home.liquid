{%- comment -%}
  Hero de la home (Numen) — ángulo confianza/originalidad ("Hero B").
  Mobile-first, fondo claro. La imagen es el LCP → eager + fetchpriority high.
  100% editable por theme editor; sin precios ni textos hardcodeados.
{%- endcomment -%}

{%- liquid
  assign hero_alt = section.settings.image.alt | default: section.settings.heading
-%}

<div class="hero-home color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width section-{{ section.id }}-padding">
    <div class="hero-home__grid{% if section.settings.image == blank %} hero-home__grid--no-image{% endif %}">
      <div class="hero-home__content">
        {%- if section.settings.eyebrow != blank -%}
          <p class="hero-home__eyebrow">{{ section.settings.eyebrow | escape }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h1 class="hero-home__title">{{ section.settings.heading | escape }}</h1>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="hero-home__subtitle">{{ section.settings.subheading | escape }}</p>
        {%- endif -%}
        {%- if section.settings.cta1_label != blank or section.settings.cta2_label != blank -%}
          <div class="hero-home__ctas">
            {%- if section.settings.cta1_label != blank -%}
              <a
                class="button button--primary hero-home__cta"
                {% if section.settings.cta1_link != blank %}href="{{ section.settings.cta1_link }}"{% else %}role="link" aria-disabled="true"{% endif %}
              >{{ section.settings.cta1_label | escape }}</a>
            {%- endif -%}
            {%- if section.settings.cta2_label != blank -%}
              <a
                class="button button--secondary hero-home__cta"
                {% if section.settings.cta2_link != blank %}href="{{ section.settings.cta2_link }}"{% else %}role="link" aria-disabled="true"{% endif %}
              >{{ section.settings.cta2_label | escape }}</a>
            {%- endif -%}
          </div>
        {%- endif -%}
        {%- if section.settings.microcopy != blank -%}
          <p class="hero-home__microcopy">{{ section.settings.microcopy | escape }}</p>
        {%- endif -%}
      </div>

      {%- if section.settings.image != blank -%}
        <div class="hero-home__media">
          {{
            section.settings.image
            | image_url: width: 1200
            | image_tag:
              loading: 'eager',
              fetchpriority: 'high',
              sizes: '(min-width: 990px) 46vw, 92vw',
              widths: '320, 480, 640, 800, 1000, 1200',
              class: 'hero-home__image',
              alt: hero_alt
          }}
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{% stylesheet %}
.hero-home__grid {
  display: grid;
  gap: 2.4rem;
  align-items: center;
}
.hero-home__content {
  text-align: center;
  max-width: 56rem;
  margin: 0 auto;
}
.hero-home__eyebrow {
  font-family: var(--font-body-family);
  font-weight: 600;
  font-size: 1.2rem;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--accent-ink);
  margin: 0 0 1.2rem;
}
.hero-home__title {
  margin: 0 0 1.4rem;
}
.hero-home__subtitle {
  font-family: var(--font-accent);
  font-style: italic;
  font-size: clamp(1.8rem, 2.4vw, 2.4rem);
  line-height: 1.3;
  opacity: 0.9;
  margin: 0 0 2rem;
}
.hero-home__ctas {
  display: flex;
  flex-wrap: wrap;
  gap: 1rem;
  justify-content: center;
}
.hero-home__cta {
  margin: 0;
}
.hero-home__microcopy {
  font-size: 1.3rem;
  opacity: 0.75;
  margin: 1.6rem 0 0;
}
.hero-home__image {
  display: block;
  width: 100%;
  height: auto;
  border-radius: var(--media-radius, 0.4rem);
}
@media screen and (min-width: 990px) {
  .hero-home__grid {
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
  }
  .hero-home__grid--no-image {
    grid-template-columns: 1fr;
  }
  .hero-home__content {
    text-align: left;
    margin: 0;
    max-width: none;
  }
  .hero-home__ctas {
    justify-content: flex-start;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Hero home",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Esquema de color", "default": "scheme-1" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "100% originales · garantía" },
    { "type": "text", "id": "heading", "label": "Título", "default": "Importados originales, sin pagar de más" },
    { "type": "text", "id": "subheading", "label": "Subtítulo (cursiva)", "default": "Diseñador, nicho y árabes — sellados y verificables." },
    { "type": "header", "content": "Botones" },
    { "type": "text", "id": "cta1_label", "label": "CTA primario", "default": "Ver catálogo" },
    { "type": "url", "id": "cta1_link", "label": "Link CTA primario" },
    { "type": "text", "id": "cta2_label", "label": "CTA secundario", "default": "Probá con un decant" },
    { "type": "url", "id": "cta2_link", "label": "Link CTA secundario" },
    { "type": "header", "content": "Imagen y microcopy" },
    { "type": "image_picker", "id": "image", "label": "Imagen de producto" },
    { "type": "text", "id": "microcopy", "label": "Microcopy (garantía / reseñas)", "default": "Garantía de originalidad · Devolución sin vueltas" },
    { "type": "header", "content": "Espaciado" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Padding superior", "default": 64 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Padding inferior", "default": 56 }
  ],
  "presets": [
    { "name": "Hero home" }
  ]
}
{% endschema %}
