{% comment %}
  Footer NUMEN — diseño validado en numen-menu-footer-mockup.html (sección FOOTER).

  Estructura: marca + tagline, columnas de links (blocks link_list → menús de
  Admin → Navegación), contacto (WhatsApp global + email), datos fiscales
  condicionales, sellos (Mercado Pago + QR Data Fiscal) y barra final.

  Acordeón mobile / columnas desktop: las columnas son <details> nativos que se
  renderizan ABIERTOS server-side (sin JS y para crawlers todo el contenido queda
  visible). El script inline del final colapsa en <750px (la primera columna queda
  abierta, como el mockup) y reabre todo en desktop.

  Datos fiscales (razón social / CUIT / domicilio) quedan ocultos hasta que se
  carguen en settings: la definición fiscal está pendiente de los socios.
{% endcomment %}

<link rel="stylesheet" href="{{ 'component-numen-footer.css' | asset_url }}" media="print" onload="this.media='all'">
<noscript>{{ 'component-numen-footer.css' | asset_url | stylesheet_tag }}</noscript>
{%- if section.settings.show_social -%}
  {{ 'component-list-social.css' | asset_url | stylesheet_tag }}
{%- endif -%}

{%- liquid
  # WhatsApp global: ignorar el placeholder con X para no generar un link roto (mismo gate que el drawer).
  assign wa_num = settings.whatsapp_number
  if wa_num contains 'X' or wa_num contains 'x'
    assign wa_num = ''
  endif

  assign has_social_icons = true
  if settings.social_facebook_link == blank and settings.social_instagram_link == blank and settings.social_youtube_link == blank and settings.social_tiktok_link == blank and settings.social_twitter_link == blank and settings.social_pinterest_link == blank and settings.social_snapchat_link == blank and settings.social_tumblr_link == blank and settings.social_vimeo_link == blank
    assign has_social_icons = false
  endif
  assign show_social_row = false
  if section.settings.show_social and has_social_icons
    assign show_social_row = true
  endif

  assign show_contact = false
  if wa_num != blank or section.settings.footer_email != blank or show_social_row
    assign show_contact = true
  endif

  assign show_fiscal = false
  if section.settings.razon_social != blank or section.settings.cuit != blank or section.settings.domicilio != blank or section.settings.fiscal_note != blank
    assign show_fiscal = true
  endif

  assign show_payment_badge = false
  if section.settings.show_payment_badge and section.settings.payment_badge_text != blank
    assign show_payment_badge = true
  endif
  assign show_badges = false
  if show_payment_badge or section.settings.data_fiscal_qr != blank
    assign show_badges = true
  endif

  assign data_fiscal_label = section.settings.data_fiscal_label | default: 'Data Fiscal'
-%}

<footer class="numen-footer color-{{ section.settings.color_scheme }} gradient">
  <div class="f-inner page-width">
    <div class="f-top">
      <div class="f-head">
        <p class="f-brand">{{ shop.name }}</p>
        {%- if section.settings.footer_tagline != blank -%}
          <p class="f-tag">{{ section.settings.footer_tagline }}</p>
        {%- endif -%}
      </div>

      {%- if section.blocks.size > 0 -%}
        <div class="f-cols">
          {%- assign col_idx = 0 -%}
          {%- for block in section.blocks -%}
            {%- case block.type -%}
              {%- when '@app' -%}
                <div class="f-col f-col--app" {{ block.shopify_attributes }}>
                  {%- render block -%}
                </div>
              {%- when 'link_list' -%}
                {%- if block.settings.menu != blank and block.settings.menu.links.size > 0 -%}
                  {%- assign col_idx = col_idx | plus: 1 -%}
                  <details class="f-col" open{% if col_idx == 1 %} data-f-open{% endif %} {{ block.shopify_attributes }}>
                    <summary class="f-col__head">
                      <span>
                        {%- if block.settings.heading != blank -%}
                          {{- block.settings.heading -}}
                        {%- else -%}
                          {{- block.settings.menu.title | escape -}}
                        {%- endif -%}
                      </span>
                      <svg class="f-col__chev" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                      </svg>
                    </summary>
                    <div class="f-col__links">
                      {%- for link in block.settings.menu.links -%}
                        {%- liquid
                          assign link_class = 'f-link'
                          if block.settings.strong_link_title != blank and link.title == block.settings.strong_link_title
                            assign link_class = link_class | append: ' f-link--strong'
                          endif
                          if section.settings.arrepentimiento_url != blank and link.url == section.settings.arrepentimiento_url
                            assign link_class = link_class | append: ' f-link--arrep'
                          endif
                        -%}
                        <a href="{{ link.url }}" class="{{ link_class }}"{% if link.current %} aria-current="page"{% endif %}>
                          {{- link.title | escape -}}
                        </a>
                      {%- endfor -%}
                    </div>
                  </details>
                {%- endif -%}
            {%- endcase -%}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    {%- if show_contact or show_fiscal -%}
      <div class="f-meta">
        {%- if show_contact -%}
          <div class="f-contact">
            {%- if section.settings.contact_heading != blank -%}
              <span class="f-contact__label">{{ section.settings.contact_heading }}</span>
            {%- endif -%}
            {%- if wa_num != blank -%}
              <a href="https://wa.me/{{ wa_num }}" target="_blank" rel="noopener">
                {%- if section.settings.contact_wa_display != blank -%}
                  {{- section.settings.contact_wa_display -}}
                {%- else -%}
                  WhatsApp +{{ wa_num }}
                {%- endif -%}
              </a>
            {%- endif -%}
            {%- if section.settings.footer_email != blank -%}
              <a href="mailto:{{ section.settings.footer_email }}">{{ section.settings.footer_email }}</a>
            {%- endif -%}
            {%- if show_social_row -%}
              {%- render 'social-icons', class: 'footer__list-social' -%}
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- if show_fiscal -%}
          <div class="f-datos">
            {%- if section.settings.razon_social != blank -%}
              <b>{{ section.settings.razon_social }}</b><br>
            {%- endif -%}
            {%- if section.settings.cuit != blank or section.settings.domicilio != blank -%}
              {%- if section.settings.cuit != blank -%}CUIT {{ section.settings.cuit }}{%- endif -%}
              {%- if section.settings.cuit != blank and section.settings.domicilio != blank %} · {% endif -%}
              {{- section.settings.domicilio -}}<br>
            {%- endif -%}
            {%- if section.settings.fiscal_note != blank -%}
              {{ section.settings.fiscal_note }}
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if show_badges -%}
      <div class="f-badges">
        {%- if show_payment_badge -%}
          <span class="f-badge">
            {%- render 'icon-line', icon: 'card' -%}
            {{ section.settings.payment_badge_text }}
          </span>
        {%- endif -%}
        {%- if section.settings.data_fiscal_qr != blank -%}
          {%- if section.settings.data_fiscal_url != blank -%}
            <a class="f-qr" href="{{ section.settings.data_fiscal_url }}" target="_blank" rel="noopener">
              {{ section.settings.data_fiscal_qr | image_url: width: 88 | image_tag: loading: 'lazy', widths: '44, 88', sizes: '44px', alt: data_fiscal_label }}
            </a>
          {%- else -%}
            <span class="f-qr">
              {{ section.settings.data_fiscal_qr | image_url: width: 88 | image_tag: loading: 'lazy', widths: '44, 88', sizes: '44px', alt: data_fiscal_label }}
            </span>
          {%- endif -%}
          <span class="f-qr__label">{{ data_fiscal_label }}</span>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="f-bottom">
      <span>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}</span>
      {%- if section.settings.bottom_note != blank -%}
        <span>{{ section.settings.bottom_note }}</span>
      {%- endif -%}
    </div>
  </div>
</footer>

<script>
  // Acordeón sólo en mobile: server-side todo abierto (SEO / sin JS). Acá se
  // colapsa <750px dejando la primera columna abierta ([data-f-open], como el
  // mockup) y se reabre todo al pasar a desktop.
  (function () {
    var footer = document.querySelector('.numen-footer');
    if (!footer) return;
    var mq = window.matchMedia('(min-width: 750px)');
    function apply() {
      footer.querySelectorAll('details.f-col').forEach(function (col) {
        if (mq.matches || col.hasAttribute('data-f-open')) col.setAttribute('open', '');
        else col.removeAttribute('open');
      });
    }
    apply();
    if (mq.addEventListener) mq.addEventListener('change', apply);
    else mq.addListener(apply);
  })();
</script>

{% schema %}
{
  "name": "t:sections.footer.name",
  "blocks": [
    {
      "type": "@app"
    },
    {
      "type": "link_list",
      "name": "t:sections.footer.blocks.link_list.name",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "heading",
          "default": "t:sections.footer.blocks.link_list.settings.heading.default",
          "label": "t:sections.footer.blocks.link_list.settings.heading.label"
        },
        {
          "type": "link_list",
          "id": "menu",
          "default": "footer",
          "label": "t:sections.footer.blocks.link_list.settings.menu.label"
        },
        {
          "type": "text",
          "id": "strong_link_title",
          "label": "Link destacado (título exacto)",
          "info": "El link del menú cuyo título coincida se muestra en negrita (ej: Cómo verificamos autenticidad)."
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-2"
    },
    {
      "type": "header",
      "content": "Marca"
    },
    {
      "type": "text",
      "id": "footer_tagline",
      "label": "Tagline",
      "default": "Perfumería curada. Originales importados, verificables frasco por frasco."
    },
    {
      "type": "header",
      "content": "Contacto"
    },
    {
      "type": "text",
      "id": "contact_heading",
      "label": "Título de contacto",
      "default": "¿Dudas? Escribinos:"
    },
    {
      "type": "text",
      "id": "contact_wa_display",
      "label": "Número de WhatsApp visible",
      "info": "Sólo cómo se muestra (ej: WhatsApp +54 9 341 555-1234). El link usa el número de WhatsApp de la configuración general del tema; si ese número está vacío o con X, el link no aparece."
    },
    {
      "type": "text",
      "id": "footer_email",
      "label": "Email de contacto"
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "Mostrar redes sociales",
      "info": "Usa los links de redes de la configuración general del tema.",
      "default": true
    },
    {
      "type": "header",
      "content": "Datos fiscales",
      "info": "El bloque queda oculto hasta cargar al menos un dato."
    },
    {
      "type": "text",
      "id": "razon_social",
      "label": "Razón social / nombre"
    },
    {
      "type": "text",
      "id": "cuit",
      "label": "CUIT"
    },
    {
      "type": "text",
      "id": "domicilio",
      "label": "Domicilio fiscal"
    },
    {
      "type": "text",
      "id": "fiscal_note",
      "label": "Nota adicional",
      "default": "Despachos desde Rosario, Santa Fe."
    },
    {
      "type": "header",
      "content": "Sellos"
    },
    {
      "type": "checkbox",
      "id": "show_payment_badge",
      "label": "Mostrar sello de pago",
      "default": true
    },
    {
      "type": "text",
      "id": "payment_badge_text",
      "label": "Texto del sello de pago",
      "default": "Mercado Pago"
    },
    {
      "type": "image_picker",
      "id": "data_fiscal_qr",
      "label": "QR Data Fiscal (ARCA)",
      "info": "Imagen del QR de Data Fiscal. Si está vacío, no se muestra."
    },
    {
      "type": "url",
      "id": "data_fiscal_url",
      "label": "Link del QR Data Fiscal",
      "info": "URL de la constancia en ARCA a la que apunta el QR."
    },
    {
      "type": "text",
      "id": "data_fiscal_label",
      "label": "Texto del sello Data Fiscal",
      "default": "Data Fiscal"
    },
    {
      "type": "header",
      "content": "Legales"
    },
    {
      "type": "url",
      "id": "arrepentimiento_url",
      "label": "URL del botón de arrepentimiento",
      "info": "El link del menú que apunte a esta URL se resalta en terracota (requisito AR: link destacado)."
    },
    {
      "type": "text",
      "id": "bottom_note",
      "label": "Texto de cierre",
      "default": "Hecho en Argentina"
    }
  ]
}
{% endschema %}
