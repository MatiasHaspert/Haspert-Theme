{%- comment -%}
  Botón de Arrepentimiento (Res. 424/2020 SCI / Ley 24.240).
  Form de contacto público (sin login). Dispara email al equipo; el código de
  identificación se informa dentro de las 24 hs (operativo). Texto editable por schema.
{%- endcomment -%}

<div class="arr color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width section-{{ section.id }}-padding">
    <div class="arr__inner">
      {%- if section.settings.heading != blank -%}
        <h1 class="arr__title">{{ section.settings.heading }}</h1>
      {%- endif -%}
      {%- if section.settings.intro != blank -%}
        <div class="arr__intro rte">{{ section.settings.intro }}</div>
      {%- endif -%}

      {%- form 'contact', id: 'ArrepentimientoForm', class: 'arr__form' -%}
        {%- if form.posted_successfully? -%}
          <div class="arr__success form-status" role="status" tabindex="-1" autofocus>
            {{ section.settings.success_text }}
          </div>
        {%- elsif form.errors -%}
          <div class="arr__error form-status" role="alert" tabindex="-1" autofocus>
            {{ 'templates.contact.form.error_heading' | t }}
            {{ form.errors | default_errors }}
          </div>
        {%- endif -%}

        <div class="field">
          <input
            class="field__input"
            type="text"
            id="ArrName"
            name="contact[name]"
            value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
            placeholder="{{ section.settings.label_name }}"
            required
          >
          <label class="field__label" for="ArrName">{{ section.settings.label_name }}</label>
        </div>

        <div class="field">
          <input
            class="field__input"
            type="email"
            id="ArrEmail"
            name="contact[email]"
            value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
            placeholder="{{ section.settings.label_email }}"
            autocapitalize="off"
            autocomplete="email"
            required
          >
          <label class="field__label" for="ArrEmail">{{ section.settings.label_email }}</label>
        </div>

        <div class="field">
          <input
            class="field__input"
            type="tel"
            id="ArrPhone"
            name="contact[teléfono]"
            placeholder="{{ section.settings.label_phone }}"
            autocomplete="tel"
          >
          <label class="field__label" for="ArrPhone">{{ section.settings.label_phone }}</label>
        </div>

        <div class="field">
          <input
            class="field__input"
            type="text"
            id="ArrOrder"
            name="contact[número de pedido]"
            placeholder="{{ section.settings.label_order }}"
            required
          >
          <label class="field__label" for="ArrOrder">{{ section.settings.label_order }}</label>
        </div>

        <div class="field">
          <textarea
            rows="4"
            class="text-area field__input"
            id="ArrBody"
            name="contact[body]"
            placeholder="{{ section.settings.label_message }}"
          ></textarea>
          <label class="field__label" for="ArrBody">{{ section.settings.label_message }}</label>
        </div>

        <div class="arr__submit">
          <button type="submit" class="button button--primary">{{ section.settings.submit_label }}</button>
        </div>
      {%- endform -%}
    </div>
  </div>
</div>

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{% stylesheet %}
.arr__inner { max-width: 64rem; margin: 0 auto; }
.arr__title { margin: 0 0 1.2rem; }
.arr__intro { margin-bottom: 2.4rem; opacity: 0.9; }
.arr__form .field { margin-bottom: 1.4rem; }
.arr__success,
.arr__error { margin-bottom: 2rem; }
.arr__success { color: rgb(var(--color-foreground)); font-weight: 600; }
.arr__submit { margin-top: 0.6rem; }
{% endstylesheet %}

{% schema %}
{
  "name": "Form arrepentimiento",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Esquema de color", "default": "scheme-1" },
    { "type": "text", "id": "heading", "label": "Título", "default": "Botón de Arrepentimiento" },
    { "type": "richtext", "id": "intro", "label": "Texto introductorio", "default": "<p>Si te arrepentiste de tu compra, tenés derecho a revocar la operación dentro de los <strong>10 días corridos</strong> de recibido el producto (Ley 24.240, art. 34). Completá el formulario y vas a recibir un <strong>código de identificación de arrepentimiento</strong> dentro de las 24 hs hábiles. No necesitás registrarte ni iniciar sesión.</p>" },
    { "type": "text", "id": "label_name", "label": "Etiqueta nombre", "default": "Nombre y apellido" },
    { "type": "text", "id": "label_email", "label": "Etiqueta email", "default": "Email" },
    { "type": "text", "id": "label_phone", "label": "Etiqueta teléfono", "default": "Teléfono / WhatsApp" },
    { "type": "text", "id": "label_order", "label": "Etiqueta número de pedido", "default": "Número de pedido" },
    { "type": "text", "id": "label_message", "label": "Etiqueta mensaje", "default": "Mensaje (opcional)" },
    { "type": "text", "id": "submit_label", "label": "Texto del botón", "default": "Enviar solicitud" },
    { "type": "richtext", "id": "success_text", "label": "Mensaje de éxito", "default": "<p>Recibimos tu solicitud de arrepentimiento. Te vamos a enviar el código de identificación dentro de las 24 hs hábiles.</p>" },
    { "type": "header", "content": "Espaciado" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding superior", "default": 56 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding inferior", "default": 56 }
  ],
  "presets": [
    { "name": "Form arrepentimiento" }
  ]
}
{% endschema %}
