{% comment %}
  Sección: Prueba social extendida (UGC + fotos + badge)
  Versión final corregida 100% compatible con Theme Check.
{% endcomment %}

{% style %}
  /* ==============================
     🎨 SISTEMA DE COLORES DINÁMICOS
     ============================== */
  .ugc-{{ section.id }} {
    --ugc-bg: {{ section.settings.bg_color }};
    --ugc-card-bg: {{ section.settings.card_bg }};
    --ugc-title-color: {{ section.settings.title_color }};
    --ugc-subtitle-color: {{ section.settings.subtitle_color }};
    --ugc-accent-color: {{ section.settings.accent_color }};
    --ugc-badge-bg: {{ section.settings.badge_bg }};
    --ugc-badge-text: {{ section.settings.badge_text }};
  }

  /* --- LAYOUT GENERAL --- */
  .ugc-{{ section.id }} {
    background: var(--ugc-bg);
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .ugc-{{ section.id }}__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  /* --- CABECERA Y TÍTULOS --- */
  .ugc-{{ section.id }}__header {
    text-align: left;
    margin-bottom: 32px;
  }

  .ugc-{{ section.id }}__title {
    font-size: {{ section.settings.title_size }}px;
    font-weight: 700;
    margin-bottom: 8px;
    color: var(--ugc-title-color);
  }

  .ugc-{{ section.id }}__subtitle {
    font-size: {{ section.settings.subtitle_size }}px;
    opacity: 0.85;
    max-width: 640px;
    color: var(--ugc-subtitle-color);
  }

  .ugc-{{ section.id }}__microclaim {
    text-align: left;
    font-size: 15px;
    font-weight: 600;
    margin-bottom: 14px;
    opacity: 0.9;
    color: var(--ugc-title-color);
  }

  .ugc-{{ section.id }}__group-title {
    font-size: 18px;
    font-weight: 600;
    margin: 32px 0 16px;
    color: var(--ugc-title-color);
  }

  /* --- BADGES (Etiquetas) --- */
  .ugc-{{ section.id }}__badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 6px 12px;
    border-radius: 999px;
    background: var(--ugc-badge-bg);
    color: var(--ugc-badge-text);
    margin-bottom: 16px;
  }

  .ugc-{{ section.id }}__badge-icon {
    font-size: 18px;
  }

  .ugc-{{ section.id }}__badge-text-main {
    font-weight: 600;
    font-size: 14px;
  }

  .ugc-{{ section.id }}__badge-text-sub {
    font-size: 13px;
    opacity: 0.8;
  }

  /* --- GRID SYSTEM --- */
  .ugc-{{ section.id }}__videos-grid,
  .ugc-{{ section.id }}__photos-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 20px;
  }

  /* --- TARJETAS (Cards) --- */
  .ugc-{{ section.id }}__video-card,
  .ugc-{{ section.id }}__photo-card {
    border-radius: 16px;
    overflow: hidden;
    background: var(--ugc-card-bg);
    box-shadow: 0 10px 25px rgba(15, 23, 42, 0.08);
    opacity: 0;
    transform: translateY(20px);
    transition: all 0.5s ease;
  }

  /* VISIBILITY STATE (ANIMACIÓN) */
  .ugc-{{ section.id }}__item--visible {
    opacity: 1 !important;
    transform: translateY(0) !important;
  }

  /* --- VIDEO COMPONENT --- */
  .ugc-{{ section.id }}__video-wrapper {
    position: relative;
    width: 100%;
    padding-top: 177.78%; /* Aspect Ratio 9:16 */
    background: #000;
  }

  .ugc-{{ section.id }}__video-wrapper video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ugc-{{ section.id }}__video-label {
    padding: 10px 12px 12px;
    font-size: 14px;
    line-height: 1.4;
    color: var(--ugc-subtitle-color);
  }

  /* --- FOTO/IMAGEN COMPONENT --- */
  .ugc-{{ section.id }}__photo-image img {
    width: 100%;
    height: 220px;
    object-fit: cover;
    display: block;
    /* Efectos Look Premium */
    filter: brightness(0.96) saturate(1.05) sepia(0.05);
    transition: transform 0.3s ease, filter 0.3s ease;
  }

  /* Hover Effects en Fotos */
  .ugc-{{ section.id }}__photo-card:hover .ugc-{{ section.id }}__photo-image img {
    transform: scale(1.05);
    filter: brightness(1) saturate(1.1);
  }

  .ugc-{{ section.id }}__photo-body {
    padding: 12px 14px 14px;
  }

  .ugc-{{ section.id }}__photo-name {
    font-weight: 600;
    font-size: 14px;
    margin-bottom: 4px;
    color: var(--ugc-title-color);
  }

  .ugc-{{ section.id }}__photo-quote {
    font-size: 14px;
    opacity: 0.9;
    margin-bottom: 8px;
    color: var(--ugc-subtitle-color);
  }

  .ugc-{{ section.id }}__stars {
    font-size: 14px;
    color: var(--ugc-accent-color);
  }

  /* --- AUTOR / AVATAR --- */
  .ugc-{{ section.id }}__author-photo {
    display: flex;
    justify-content: center;
    margin-top: 12px;
    margin-bottom: 6px;
  }

  .ugc-{{ section.id }}__author-name {
    text-align: center;
    font-weight: 600;
    font-size: 14px;
    margin-bottom: 4px;
    opacity: 0.9;
    color: var(--ugc-title-color);
  }

  .ugc-author-img {
    /* Avatares Perfectos */
    width: 48px;
    height: 48px;
    border-radius: 9999px; /* Círculo perfecto */
    object-fit: cover;
    display: block;
    margin: 0 auto 10px;
    box-shadow: 0 2px 6px rgba(0,0,0,0.12);
  }

  /* --- RESPONSIVE / MEDIA QUERIES --- */
  @media (max-width: 900px) {
    .ugc-{{ section.id }}__videos-grid,
    .ugc-{{ section.id }}__photos-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .ugc-{{ section.id }}__header,
    .ugc-{{ section.id }}__microclaim {
      text-align: center;
    }

    .ugc-{{ section.id }}__subtitle {
      margin: 0 auto;
    }

    .ugc-{{ section.id }}__videos-grid,
    .ugc-{{ section.id }}__photos-grid {
      grid-template-columns: minmax(0, 1fr);
    }
  }
{% endstyle %}


<div class="ugc-{{ section.id }}" data-ugc-section data-section-id="{{ section.id }}">
  <div class="ugc-{{ section.id }}__inner">

    <!-- ENCABEZADO -->
    <div class="ugc-{{ section.id }}__header">
      {% if section.settings.microclaim != blank %}
        <p class="ugc-{{ section.id }}__microclaim">
          {{ section.settings.microclaim }}
        </p>
      {% endif %}

      <div class="ugc-{{ section.id }}__badge">
        <span class="ugc-{{ section.id }}__badge-icon">⭐</span>
        <div>
          <div class="ugc-{{ section.id }}__badge-text-main">
            {{ section.settings.badge_main }}
          </div>
          <div class="ugc-{{ section.id }}__badge-text-sub">
            {{ section.settings.badge_sub }}
          </div>
        </div>
      </div>

      <h2 class="ugc-{{ section.id }}__title">
        {{ section.settings.title }}
      </h2>

      {% if section.settings.subtitle != blank %}
        <p class="ugc-{{ section.id }}__subtitle">
          {{ section.settings.subtitle }}
        </p>
      {% endif %}
    </div>

    <!-- GRID VIDEOS -->
    {% assign has_videos = false %}
    {% for block in section.blocks %}
      {% if block.type == 'ugc_video' %}
        {% assign has_videos = true %}
        {% break %}
      {% endif %}
    {% endfor %}

    {% if has_videos %}
      <div class="ugc-{{ section.id }}__videos-grid">
        {% for block in section.blocks %}
          {% if block.type == 'ugc_video' %}
            <div class="ugc-{{ section.id }}__video-card" data-ugc-animate {{ block.shopify_attributes }}>
              <div class="ugc-{{ section.id }}__video-wrapper">
                {% if block.settings.video != blank %}
                  {{ block.settings.video
                    | video_tag:
                      autoplay: true,
                      loop: true,
                      muted: true,
                      controls: false,
                      playsinline: true
                  }}
                {% endif %}
              </div>
              {% if block.settings.label != blank %}
                <p class="ugc-{{ section.id }}__video-label">
                  {{ block.settings.label }}
                </p>
              {% endif %}
              {% if block.settings.author_photo %}
                <div class="ugc-{{ section.id }}__author-photo">
                  {{ block.settings.author_photo
                    | image_url: width: 80
                    | image_tag: loading: 'lazy', alt: block.settings.author_name, class: 'ugc-author-img'
                  }}
                </div>
              {% endif %}

              {% if block.settings.author_name %}
                <p class="ugc-{{ section.id }}__author-name">
                  {{ block.settings.author_name }}
                </p>
              {% endif %}
            </div>
          {% endif %}
          
        {% endfor %}
      </div>
    {% endif %}

    <!-- GRID FOTOS -->
    {% assign has_photos = false %}
    {% for block in section.blocks %}
      {% if block.type == 'photo_testimonial' %}
        {% assign has_photos = true %}
        {% break %}
      {% endif %}
    {% endfor %}

    {% if has_photos %}
      <div class="ugc-{{ section.id }}__group-title">
      </div>

      <div class="ugc-{{ section.id }}__photos-grid">
        {% for block in section.blocks %}
          {% if block.type == 'photo_testimonial' %}
            <div class="ugc-{{ section.id }}__photo-card" data-ugc-animate {{ block.shopify_attributes }}>
              
              <div class="ugc-{{ section.id }}__photo-image">
                {% if block.settings.image %}
                  {{ block.settings.image
                    | image_url: width: 600
                    | image_tag: loading: 'lazy', alt: block.settings.name
                  }}
                {% endif %}
              </div>

              <div class="ugc-{{ section.id }}__photo-body">
                {% if block.settings.author_photo %}
                  <div class="ugc-{{ section.id }}__author-photo">
                    {{ block.settings.author_photo
                      | image_url: width: 80
                      | image_tag: loading: 'lazy', alt: block.settings.name, class: 'ugc-author-img'
                    }}
                  </div>
                {% endif %}

                <div class="ugc-{{ section.id }}__photo-name">
                  {{ block.settings.name }}
                </div>

                <div class="ugc-{{ section.id }}__stars">
                  {% for i in (1..block.settings.rating) %}
                    ★
                  {% endfor %}
                </div>

                <div class="ugc-{{ section.id }}__photo-quote">
                  “{{ block.settings.quote }}”
                </div>

              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}
  </div>
</div>

{% javascript %}
document.addEventListener("DOMContentLoaded", function() {
  const root = document.querySelector("[data-ugc-section]");
  if (!root) return;

  const sectionId = root.getAttribute("data-section-id");
  const visibleClass = `ugc-${sectionId}__item--visible`;

  // ANIMACIONES
  const items = root.querySelectorAll("[data-ugc-animate]");

  if ("IntersectionObserver" in window && items.length > 0) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add(visibleClass);
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.2 });

    items.forEach((item) => observer.observe(item));
  } else {
    items.forEach((item) =>
      item.classList.add(visibleClass)
    );
  }

  // VIDEO PLAY/PAUSE INTELIGENTE
  const videos = root.querySelectorAll("video");

  if ("IntersectionObserver" in window && videos.length > 0) {
    const videoObserver = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        const video = entry.target;
        if (entry.isIntersecting) {
          video.play().catch(() => {});
        } else {
          video.pause();
        }
      });
    }, { threshold: 0.5 });

    videos.forEach((video) => videoObserver.observe(video));
  }
});
{% endjavascript %}

{% schema %}
{
  "name": "Prueba social ext",
  "tag": "section",
  "class": "ugc-social-proof-section",
  "settings": [
    {
