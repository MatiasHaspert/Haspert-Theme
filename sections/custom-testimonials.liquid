{%- comment -%}
  Testimonios (NUMEN, patrón tcard del mockup de la home §3.7):
  cita en serif itálica + avatar de iniciales (o foto) + nombre · ciudad +
  tick "compra verificada" (solo informativo, no CTA).

  ⚠ SOLO CONTENIDO REAL: la instancia de la home queda OCULTA desde el theme
  editor hasta que haya testimonios verdaderos. No publicar citas inventadas.
{%- endcomment -%}
{{ 'component-slider.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- liquid
  assign columns_mobile_int = section.settings.columns_mobile | plus: 0
  assign show_mobile_slider = false
  if section.settings.swipe_on_mobile and section.blocks.size > columns_mobile_int
    assign show_mobile_slider = true
  endif
-%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width section-{{ section.id }}-padding isolate">
    {%- if section.settings.overline != blank or section.settings.title != blank -%}
      <div class="testi__head">
        {%- if section.settings.overline != blank -%}
          <p class="testi__overline">{{ section.settings.overline | escape }}</p>
        {%- endif -%}
        {%- if section.settings.title != blank -%}
          <h2 class="title {{ section.settings.heading_size }} testi__title">{{ section.settings.title }}</h2>
        {%- endif -%}
      </div>
    {%- endif -%}

    <slider-component class="slider-mobile-gutter">
      <ul
        class="testi__grid grid grid--{{ section.settings.columns_mobile }}-col-tablet-down grid--{{ section.settings.columns_desktop }}-col-desktop{% if show_mobile_slider %} slider slider--tablet grid--peek{% endif %}"
        id="Slider-{{ section.id }}"
        role="list"
      >
        {%- for block in section.blocks -%}
          {%- liquid
            assign who_name = block.settings.name | strip
            assign name_parts = who_name | split: ' '
            assign initials = name_parts[0] | slice: 0
            if name_parts.size > 1
              assign second_initial = name_parts[1] | slice: 0
              assign initials = initials | append: second_initial
            endif
            assign initials = initials | upcase
          -%}
          <li
            id="Slide-{{ section.id }}-{{ forloop.index }}"
            class="grid__item{% if section.settings.swipe_on_mobile %} slider__slide{% endif %}"
            {{ block.shopify_attributes }}
          >
            <figure class="testi-card">
              {%- if block.settings.testimonial_text != blank -%}
                <blockquote class="testi-card__quote rte">{{ block.settings.testimonial_text }}</blockquote>
              {%- endif -%}
              <figcaption class="testi-card__who">
                <span class="testi-card__avatar" aria-hidden="true">
                  {%- if block.settings.person_image != blank -%}
                    {{ block.settings.person_image | image_url: width: 104 | image_tag: class: 'testi-card__avatar-img', widths: '52, 104', alt: '', loading: 'lazy' }}
                  {%- else -%}
                    {{ initials }}
                  {%- endif -%}
                </span>
                {%- if who_name != blank -%}
                  <span class="testi-card__name">
                    {{- who_name | escape -}}
                    {%- if block.settings.city != blank %} · {{ block.settings.city | escape }}{% endif -%}
                  </span>
                {%- endif -%}
                {%- if block.settings.verified and section.settings.verified_label != blank -%}
                  <span class="testi-card__verified">
                    <svg viewBox="0 0 24 24" fill="none" width="12" height="12" aria-hidden="true"><path d="M5 13l4 4L19 7" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    {{ section.settings.verified_label | escape }}
                  </span>
                {%- endif -%}
              </figcaption>
            </figure>
          </li>
        {%- endfor -%}
      </ul>

      {%- if show_mobile_slider -%}
        <div class="slider-buttons large-up-hide">
          <button type="button" class="slider-button slider-button--prev" name="previous" aria-label="{{ 'general.slider.previous_slide' | t }}">
            <span class="svg-wrapper">{{ 'icon-caret.svg' | inline_asset_content }}</span>
          </button>
          <div class="slider-counter caption">
            <span class="slider-counter--current">1</span>
            <span aria-hidden="true"> / </span>
            <span class="visually-hidden">{{ 'general.slider.of' | t }}</span>
            <span class="slider-counter--total">{{ section.blocks.size }}</span>
          </div>
          <button type="button" class="slider-button slider-button--next" name="next" aria-label="{{ 'general.slider.next_slide' | t }}">
            <span class="svg-wrapper">{{ 'icon-caret.svg' | inline_asset_content }}</span>
          </button>
        </div>
      {%- endif -%}
    </slider-component>
  </div>
</div>

{% stylesheet %}
.testi__head {
  margin-bottom: 0.6rem;
}
.testi__overline {
  font-family: var(--font-body-family);
  font-weight: 600;
  font-size: 1.15rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--accent-ink);
  margin: 0 0 0.4rem;
}
.testi__title {
  margin: 0 0 1rem;
}
.testi__grid {
  row-gap: 1.2rem;
}
.testi-card {
  --testi-ok: #246a45;
  height: 100%;
  margin: 0;
  border: 0.1rem solid rgba(var(--color-foreground), 0.14);
  border-radius: 0.8rem;
  background: rgba(var(--color-foreground), 0.04);
  padding: 1.4rem 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 1rem;
}
.testi-card__quote {
  font-family: var(--font-accent, Georgia, serif);
  font-style: italic;
  font-size: 1.45rem;
  line-height: 1.5;
  color: rgb(var(--color-foreground));
  margin: 0;
  border: 0;
  padding: 0;
}
.testi-card__quote > :first-child { margin-top: 0; }
.testi-card__quote > :last-child { margin-bottom: 0; }
.testi-card__who {
  margin-top: auto;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 0.8rem;
  font-size: 1.15rem;
  color: rgba(var(--color-foreground), 0.65);
}
.testi-card__avatar {
  flex: none;
  width: 2.6rem;
  height: 2.6rem;
  border-radius: 50%;
  overflow: hidden;
  display: grid;
  place-items: center;
  font-weight: 700;
  font-size: 1rem;
  letter-spacing: 0.02em;
  color: var(--accent-ink);
  background: rgba(var(--color-foreground), 0.08);
  background: color-mix(in srgb, var(--accent, #b25a3c) 16%, rgb(var(--color-background)));
}
.testi-card__avatar-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.testi-card__verified {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  font-size: 1rem;
  font-weight: 600;
  color: var(--testi-ok);
}
{% endstylesheet %}

{% schema %}
{
  "name": "Testimonios",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "paragraph",
      "content": "Solo testimonios REALES. Mantené la sección oculta hasta tener contenido verdadero; el tick de \"compra verificada\" se marca por testimonio."
    },
    {
      "type": "text",
      "id": "overline",
      "label": "Overline",
      "default": "Clientes"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Título de la sección",
      "default": "Los que ya compraron"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "Mediano" },
        { "value": "h1", "label": "Grande" },
        { "value": "h0", "label": "Extra Grande" }
      ],
      "default": "h1",
      "label": "Tamaño del Título"
    },
    {
      "type": "text",
      "id": "verified_label",
      "label": "Texto del tick de verificación",
      "info": "Se muestra solo en los testimonios marcados como compra verificada.",
      "default": "Compra verificada"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 2,
      "label": "Columnas en desktop"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "options": [
        { "value": "1", "label": "1 columna" },
        { "value": "2", "label": "2 columnas" }
      ],
      "default": "1",
      "label": "Columnas en mobile"
    },
    {
      "type": "checkbox",
      "id": "swipe_on_mobile",
      "default": false,
      "label": "Activar slider en mobile"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Esquema de color",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding de la sección"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding superior",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding inferior",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonio",
      "settings": [
        {
          "type": "richtext",
          "id": "testimonial_text",
          "label": "Cita (testimonio real)",
          "default": "<p>Escribí acá el testimonio real. Nada inventado.</p>"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Nombre",
          "info": "Ej.: Martín F. Las iniciales del avatar salen de acá.",
          "default": "Nombre A."
        },
        {
          "type": "text",
          "id": "city",
          "label": "Ciudad"
        },
        {
          "type": "checkbox",
          "id": "verified",
          "label": "Compra verificada",
          "info": "Marcalo solo si podés respaldarlo con una orden real.",
          "default": false
        },
        {
          "type": "image_picker",
          "id": "person_image",
          "label": "Foto (opcional)",
          "info": "Si no hay foto, se muestran las iniciales."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonios",
      "blocks": [
        { "type": "testimonial" },
        { "type": "testimonial" }
      ]
    }
  ]
}
{% endschema %}
