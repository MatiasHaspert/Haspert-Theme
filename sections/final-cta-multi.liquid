      "min": 0,
      "max": 100,
      "step": 4,
      "default": 40
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Fondo de tarjeta",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Color del título",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Color del subtítulo",
      "default": "#444444"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Color del texto",
      "default": "#222222"
    },
    {
      "type": "color",
      "id": "price_color",
