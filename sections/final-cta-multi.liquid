{% style %}

/* ==========================================================
   🎨 SISTEMA DE COLORES DINÁMICOS — CTA FINAL
========================================================== */
.final-cta-{{ section.id }} {
  --cta-bg: {{ section.settings.bg_color }};
  --cta-card-bg: {{ section.settings.card_bg }};
  --cta-title: {{ section.settings.title_color }};
  --cta-subtitle: {{ section.settings.subtitle_color }};
  --cta-text: {{ section.settings.text_color }};
  --cta-price: {{ section.settings.price_color }};
  --cta-price-compare: {{ section.settings.price_compare_color }};
  --cta-btn-bg: {{ section.settings.button_bg }};
  --cta-btn-text: {{ section.settings.button_text }};
  --cta-btn-bg-hover: {{ section.settings.button_bg_hover }};
  --cta-badge-bg: {{ section.settings.badge_bg }};
  --cta-badge-text: {{ section.settings.badge_text }};
}

/* ==========================================================
   LAYOUT GENERAL
========================================================== */
.final-cta-{{ section.id }} {
  padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px 0;
  background: var(--cta-bg);
}

.final-cta-{{ section.id }}__inner {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 20px;
}

/* ==========================================================
   MICRO BADGE
========================================================== */
.calmi-product-cta-{{ section.id }}__badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: var(--cta-badge-bg);
  color: var(--cta-badge-text);
  padding: 6px 14px;
  border-radius: 999px;
  font-weight: 600;
  font-size: 0.9rem;
  margin-bottom: 18px;
}

/* ==========================================================
   GRID
========================================================== */
.final-cta-{{ section.id }}__grid {
  display: grid;
  grid-template-columns: repeat({{ section.settings.columns }}, 1fr);
  gap: 28px;
}

/* ==========================================================
   CARD
========================================================== */
.final-cta-card {
  background: var(--cta-card-bg);
  border-radius: 18px;
  padding: 22px;
  box-shadow: 0 10px 28px rgba(0,0,0,0.08);
  transition: all 0.3s ease;
  border: 1px solid rgba(0,0,0,0.05);
  position: relative;
}

.final-cta-card:hover {
  transform: translateY(-6px) scale(1.02);
  box-shadow: 0 18px 40px rgba(0,0,0,0.12);
}

/* ==========================================================
   BADGE “BEST SELLER”
========================================================== */
.final-cta-card__badge {
  position: absolute;
  top: 12px;
  left: 12px;
  background: #FEE2E2;
  color: #B91C1C;
  font-weight: 700;
  font-size: 0.9rem;
  padding: 6px 10px;
  border-radius: 8px;
  z-index: 5;
  box-shadow: 0 4px 10px rgba(0,0,0,0.1);
}

/* ==========================================================
   IMAGE
========================================================== */
.final-cta-card__image img {
  width: 100%;
  height: 260px;
  object-fit: cover;
  border-radius: 14px;
  display: block;
}

/* ==========================================================
   TEXTOS
========================================================== */
.final-cta-card__title,
.final-cta-card__benefit,
.final-cta-card__price,
.final-cta-card__price strong {
  color: var(--cta-text) !important;
}

.final-cta-card__title {
  font-size: 1.8rem;
  font-weight: 600;
  margin-bottom: 10px;
  color: var(--cta-title) !important;
}

/* ==========================================================
   BENEFICIOS
========================================================== */
.final-cta-card__benefits {
  margin-bottom: 12px;
}

.final-cta-card__benefit {
  font-size: 1.4rem;
  margin-bottom: 4px;
  display: flex;
  gap: 6px;
  align-items: center;
  color: var(--cta-text);
}

/* ==========================================================
   PRECIO
========================================================== */
.final-cta-card__price {
  margin-top: 12px;
  font-size: 1.6rem;
  color: var(--cta-price);
}

.final-cta-card__price s {
  opacity: 0.55;
  margin-right: 6px;
  color: var(--cta-price-compare);
}

.final-cta-card__price strong {
  font-size: 1.9rem;
  color: var(--cta-price);
}

/* ==========================================================
   BOTÓN
========================================================== */
.final-cta-card__button {
  margin-top: 18px;
  width: 100%;
  padding: 12px;
  font-size: 1.55rem;
  border-radius: 10px;
  background: var(--cta-btn-bg) !important;
  color: var(--cta-btn-text) !important;
  border: none;
  text-align: center;
}

.final-cta-card__button:hover {
  background: var(--cta-btn-bg-hover) !important;
}

/* ==========================================================
   EXTRAS
========================================================== */
.final-cta-card__extras {
  margin-top: 16px;
  padding-top: 12px;
  border-top: 1px solid rgba(0,0,0,0.08);
  display: grid;
  gap: 6px;
}

.final-cta-card__extra {
  display: flex;
  gap: 6px;
  align-items: center;
  font-size: 1.25rem;
  opacity: 0.9;
  color: var(--cta-text);
}

/* ==========================================================
   SOCIAL PROOF
========================================================== */
.final-cta-social-proof {
  text-align: center;
  max-width: 720px;
  margin: 0 auto 34px auto;
  font-size: 1.25rem;
  line-height: 1.55;
  color: var(--cta-text);
  opacity: 0.92;
}

.final-cta-social-proof strong {
  color: var(--cta-title);
  font-weight: 700;
}

/* ==========================================================
   MOBILE
========================================================== */
@media screen and (max-width: 749px) {
  .final-cta-{{ section.id }}__grid {
    grid-template-columns: 1fr;
    gap: 22px;
  }

  .final-cta-card {
    padding: 18px;
  }

  .final-cta-card__title {
    font-size: 1.65rem;
  }

  .final-cta-card__image img {
    height: auto !important;
    max-height: 300px;
    object-fit: contain !important;
    border-radius: 14px;
  }
}

{% endstyle %}



<section class="final-cta-{{ section.id }}">
  <div class="final-cta-{{ section.id }}__inner">
    
    {% if section.settings.badge != blank %}
      <div class="calmi-product-cta-{{ section.id }}__badge">
        {{ section.settings.badge }}
      </div>
    {% endif %}

    {% if section.settings.heading != blank %}
      <h2 class="title h1" style="text-align:center; margin-bottom:12px;">
        {{ section.settings.heading }}
      </h2>
    {% endif %}

    {% if section.settings.subheading != blank %}
      <p style="text-align:center; font-size:1.3rem; color:#444; margin-bottom:32px;">
        {{ section.settings.subheading }}
      </p>
    {% endif %}

    <div class="final-cta-social-proof">
      <p>
        <strong>Más de 10.000 familias ya eligieron Calmi para dormir mejor.</strong><br>
        Elegí el tuyo y empezá a disfrutar noches más tranquilas desde hoy.
      </p>
    </div>

    <div class="final-cta-{{ section.id }}__grid">

      {% for block in section.blocks %}
        <div class="final-cta-card" {{ block.shopify_attributes }}>

          {% if block.settings.best_seller %}
            <div class="final-cta-card__badge">🔥 Best Seller</div>
          {% endif %}

          {% if block.settings.image %}
          <div class="final-cta-card__image">
            {{ block.settings.image | image_url: width: 1200 | image_tag }}
          </div>
          {% endif %}

          {% if block.settings.title %}
          <h3 class="final-cta-card__title">{{ block.settings.title }}</h3>
          {% endif %}

          <!-- Benefits -->
          <div class="final-cta-card__benefits">
            {% for i in (1..4) %}
              
              {% assign emoji_key = "benefit_" | append: i | append: "_emoji" %}
              {% assign text_key  = "benefit_" | append: i %}
              
              {% assign emoji = block.settings[emoji_key] %}
              {% assign text  = block.settings[text_key] %}

              {% if text != blank %}
                <div class="final-cta-card__benefit">
                  {{ emoji }} {{ text }}
                </div>
              {% endif %}

            {% endfor %}
          </div>


          <!-- Price -->
          {% if block.settings.price_compare or block.settings.price %}
          <div class="final-cta-card__price">
            {% if block.settings.price_compare %}
              <s>{{ block.settings.price_compare }}</s>
            {% endif %}
            {% if block.settings.price %}
              <strong>{{ block.settings.price }}</strong>
            {% endif %}
          </div>
          {% endif %}

          <!-- Button -->
          {% if block.settings.button_label %}
            <a href="{{ block.settings.button_link | default: '#' }}" 
               class="button button--primary final-cta-card__button">
              {{ block.settings.button_label }}
            </a>
          {% endif %}

          <!-- Extra info -->
          <div class="final-cta-card__extras">
            {% if block.settings.installments != blank %}
              <div class="final-cta-card__extra">💳 {{ block.settings.installments }}</div>
            {% endif %}
            {% if block.settings.shipping != blank %}
              <div class="final-cta-card__extra">🚚 {{ block.settings.shipping }}</div>
            {% endif %}
            {% if block.settings.warranty != blank %}
              <div class="final-cta-card__extra">🛡️ {{ block.settings.warranty }}</div>
            {% endif %}
            {% if block.settings.security != blank %}
              <div class="final-cta-card__extra">🔒 {{ block.settings.security }}</div>
            {% endif %}
          </div>

        </div>
      {% endfor %}

    </div>

  </div>
</section>


{% schema %}
{
  "name": "CTA Final Producto",
  "settings": [
    { "type": "text", "id": "badge", "label": "Micro-badge", "default": "⭐ Elegí tu modelo favorito" },
