{%- comment -%}
  Autenticidad ampliada (§4.7): foto del lote + 3 pasos (blocks) + CTA WhatsApp + link original-vs-réplica.
  OS 2.0, editable por theme editor. El número de WhatsApp es global (settings.whatsapp_number);
  el mensaje se arma con el producto actual. Nada hardcodeado.

  ⚠ MULTI-INSTANCIA: vive en la PDP (templates/product.json), en la home
  (templates/index.json) y en /pages/autenticidad. Cualquier cambio acá impacta
  las tres. La home usa: sin foto (show_photo off), título H2 y la fila de dos
  links; la PDP usa la foto del lote y el link-card "Original vs. réplica".
{%- endcomment -%}

{%- liquid
  # Acento de marca con contraste AA: oscurece sólo sobre fondos claros.
  assign accent = section.settings.accent_color
  assign scheme_bg = section.settings.color_scheme.settings.background
  assign bg_bright = scheme_bg | color_brightness
  assign accent_ink = accent
  if scheme_bg == blank or bg_bright > 140
    assign accent_ink = accent | color_darken: 22
  endif

  # WhatsApp: ignorar el placeholder con X para no generar un link roto.
  assign wa_num = settings.whatsapp_number
  if wa_num contains 'X' or wa_num contains 'x'
    assign wa_num = ''
  endif
  assign prod_name = product.title | default: section.settings.whatsapp_fallback_name
  assign wa_text = section.settings.whatsapp_message | replace: '{product}', prod_name
  assign lote_alt = section.settings.lote_image.alt | default: section.settings.lote_badge | default: section.settings.heading
-%}

<div class="auth color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width section-{{ section.id }}-padding">
    {%- if section.settings.heading != blank -%}
      <p class="auth__overline">{{ section.settings.heading }}</p>
    {%- endif -%}
    {%- if section.settings.title != blank -%}
      <h2 class="auth__title">{{ section.settings.title | escape }}</h2>
    {%- endif -%}

    <div class="auth__card{% unless section.settings.show_photo %} auth__card--no-photo{% endunless %}">
      {%- if section.settings.show_photo -%}
      <div class="auth__photo">
        {%- if section.settings.lote_image != blank -%}
          {{
            section.settings.lote_image
            | image_url: width: 1000
            | image_tag: loading: 'lazy', sizes: '(min-width: 750px) 60rem, 100vw', widths: '400, 600, 800, 1000', class: 'auth__img', alt: lote_alt
          }}
        {%- else -%}
          <div class="auth__photo-ph">{{ 'image' | placeholder_svg_tag: 'auth__ph-svg' }}</div>
        {%- endif -%}
        {%- if section.settings.lote_badge != blank -%}
          <span class="auth__lot">
            <svg viewBox="0 0 24 24" fill="none" width="13" height="13" aria-hidden="true"><path d="M5 13l4 4L19 7" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
            {{ section.settings.lote_badge }}
          </span>
        {%- endif -%}
      </div>
      {%- endif -%}

      <div class="auth__body">
        {%- if section.blocks.size > 0 -%}
          <ol class="auth__steps">
            {%- for block in section.blocks -%}
              {%- if block.type == 'paso' and block.settings.text != blank -%}
                <li class="auth__step" {{ block.shopify_attributes }}>
                  <span class="auth__n" aria-hidden="true">{{ forloop.index }}</span>
                  <div class="auth__step-text rte">{{ block.settings.text }}</div>
                </li>
              {%- endif -%}
            {%- endfor -%}
          </ol>
        {%- endif -%}

        {%- if wa_num != blank and section.settings.whatsapp_label != blank -%}
          <a class="auth__wa" href="https://wa.me/{{ wa_num }}?text={{ wa_text | url_encode }}" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 00-8.5 15.2L2 22l4.9-1.4A10 10 0 1012 2zm0 18a8 8 0 01-4.1-1.1l-.3-.2-2.9.8.8-2.8-.2-.3A8 8 0 1112 20zm4.4-6c-.2-.1-1.4-.7-1.6-.8s-.4-.1-.5.1-.6.8-.8.9-.3.2-.5 0a6.5 6.5 0 01-1.9-1.2 7 7 0 01-1.3-1.6c-.1-.2 0-.4.1-.5l.4-.4.2-.4v-.4l-.7-1.7c-.2-.5-.4-.4-.5-.4h-.5a.9.9 0 00-.7.3 2.8 2.8 0 00-.9 2.1c0 1.2.9 2.4 1 2.6s1.8 2.8 4.4 3.9c1.6.7 2.2.7 3 .6.5 0 1.4-.6 1.6-1.1s.2-1 .1-1.1l-.4-.2z"/></svg>
            {{ section.settings.whatsapp_label }}
          </a>
        {%- endif -%}

        {%- if section.settings.compare_link != blank and section.settings.compare_title != blank -%}
          <a class="auth__compare" href="{{ section.settings.compare_link }}">
            <span class="auth__compare-body">
              <b>{{ section.settings.compare_title }}</b>
              {%- if section.settings.compare_text != blank -%}<span>{{ section.settings.compare_text }}</span>{%- endif -%}
            </span>
            <svg viewBox="0 0 24 24" fill="none" width="18" height="18" aria-hidden="true"><path d="M9 6l6 6-6 6" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        {%- endif -%}

        {%- liquid
          assign has_link_1 = false
          if section.settings.link_1_label != blank and section.settings.link_1_url != blank
            assign has_link_1 = true
          endif
          assign has_link_2 = false
          if section.settings.link_2_label != blank and section.settings.link_2_url != blank
            assign has_link_2 = true
          endif
        -%}
        {%- if has_link_1 or has_link_2 -%}
          <div class="auth__links">
            {%- if has_link_1 -%}
              <a class="auth__links-item" href="{{ section.settings.link_1_url }}">{{ section.settings.link_1_label | escape }}</a>
            {%- endif -%}
            {%- if has_link_2 -%}
              <a class="auth__links-item" href="{{ section.settings.link_2_url }}">{{ section.settings.link_2_label | escape }}</a>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  #shopify-section-{{ section.id }} {
    --auth-accent: {{ accent }};
    --auth-accent-rgb: {{ accent.red }}, {{ accent.green }}, {{ accent.blue }};
    --auth-accent-ink: {{ accent_ink }};
    --auth-ok: #1c4a32;
    --auth-ok-bg: #e7f2ea;
    --auth-ok-line: #b6d8c2;

    /* Motion (consistente con la PDP) */
    --perfume-ease-select: cubic-bezier(0.23, 1, 0.32, 1);
    --perfume-dur-select: 200ms;
    --perfume-dur-tap: 140ms;
  }
{%- endstyle -%}

{% stylesheet %}
.auth__overline {
  font-family: var(--font-body, var(--font-body-family));
  font-size: 1.15rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase;
  color: rgba(var(--color-foreground), 0.6);
  max-width: 60rem; margin: 0 auto 1.4rem;
}
.auth__title {
  max-width: 60rem;
  margin: 0 auto 1.8rem;
}
.auth__overline + .auth__title { margin-top: -0.6rem; }
.auth__card {
  max-width: 60rem; margin: 0 auto;
  border: 0.1rem solid rgba(var(--color-foreground), 0.14);
  border-radius: 1.4rem; background: rgb(var(--color-background)); overflow: hidden;
}
.auth__photo {
  position: relative; aspect-ratio: 16 / 10;
  background: radial-gradient(120% 100% at 30% 18%, #FCFAF4, #EEE8DC);
  display: grid; place-items: center;
  border-bottom: 0.1rem solid rgba(var(--color-foreground), 0.14);
}
.auth__img { width: 100%; height: 100%; object-fit: cover; }
.auth__photo-ph { width: 50%; opacity: 0.35; }
.auth__photo-ph .auth__ph-svg { width: 100%; height: auto; }
.auth__lot {
  position: absolute; left: 1.2rem; bottom: 1.2rem;
  display: inline-flex; align-items: center; gap: 0.6rem;
  background: rgba(var(--color-background), 0.92);
  border: 0.1rem solid var(--auth-ok-line); color: var(--auth-ok);
  border-radius: 0.4rem; padding: 0.5rem 0.9rem;
  font-size: 1.1rem; font-weight: 600; letter-spacing: 0.04em;
}
.auth__body { padding: 1.8rem 1.8rem 2rem; }
.auth__steps { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 1.2rem; }
.auth__step { display: flex; gap: 1.1rem; align-items: flex-start; }
.auth__n {
  flex: none; width: 2.2rem; height: 2.2rem; border-radius: 50%;
  background: rgba(var(--auth-accent-rgb), 0.14); color: var(--auth-accent-ink);
  font-weight: 700; font-size: 1.2rem; display: grid; place-items: center;
}
.auth__step-text { font-size: 1.3rem; color: rgba(var(--color-foreground), 0.78); line-height: 1.5; }
.auth__step-text b, .auth__step-text strong { color: rgb(var(--color-foreground)); font-weight: 600; }
.auth__step-text > :first-child { margin-top: 0; }
.auth__step-text > :last-child { margin-bottom: 0; }
.auth__wa {
  display: flex; align-items: center; justify-content: center; gap: 0.9rem;
  margin-top: 1.6rem; min-height: 4.8rem; padding: 0 1.6rem;
  border: 0.15rem solid #128c7e; border-radius: 0.8rem;
  background: rgb(var(--color-background)); color: #0c5b51;
  font-weight: 600; font-size: 1.4rem; text-decoration: none;
  transition: background-color var(--perfume-dur-select, 200ms) var(--perfume-ease-select, var(--ease-select)),
              transform var(--perfume-dur-tap, 140ms) var(--perfume-ease-select, var(--ease-select));
}
.auth__wa:active { transform: scale(0.97); }
@media (hover: hover) { .auth__wa:hover { background: rgba(18, 140, 126, 0.06); } }
.auth__compare {
  display: flex; align-items: center; gap: 1.2rem;
  margin-top: 1.2rem; padding: 1.3rem 1.4rem;
  border: 0.1rem solid rgba(var(--color-foreground), 0.14); border-radius: 0.8rem;
  text-decoration: none; color: inherit; transition: border-color var(--perfume-dur-select, 200ms) var(--perfume-ease-select, var(--ease-select));
}
@media (hover: hover) { .auth__compare:hover { border-color: var(--auth-accent); } }
.auth__compare-body { flex: 1 1 auto; min-width: 0; }
.auth__compare-body b { display: block; font-size: 1.3rem; color: rgb(var(--color-foreground)); }
.auth__compare-body span { display: block; font-size: 1.2rem; color: rgba(var(--color-foreground), 0.62); margin-top: 0.2rem; }
.auth__compare svg { flex: none; color: rgba(var(--color-foreground), 0.5); }
.auth__links {
  display: flex; flex-wrap: wrap; gap: 0.8rem 1.8rem;
  justify-content: center; margin-top: 1.4rem;
}
.auth__links-item {
  font-size: 1.2rem; font-weight: 600; color: var(--auth-accent-ink);
  text-decoration: underline; text-underline-offset: 0.3rem;
}
.auth__wa:focus-visible,
.auth__compare:focus-visible,
.auth__links-item:focus-visible { outline: 0.2rem solid var(--auth-accent, #1E34A8); outline-offset: 0.2rem; }
@media (prefers-reduced-motion: reduce) {
  .auth__wa, .auth__compare { transition: none; }
  .auth__wa:active { transform: none; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Autenticidad perfume",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Esquema de color", "default": "scheme-1" },
    { "type": "color", "id": "accent_color", "label": "Color de acento", "default": "#1E34A8" },
    { "type": "text", "id": "heading", "label": "Overline (texto chico arriba)", "default": "Cómo verificás que es original" },
    { "type": "text", "id": "title", "label": "Título (H2, opcional)", "info": "Usado en la home: overline + título grande. En la PDP puede quedar vacío." },
    { "type": "header", "content": "Foto del lote" },
    { "type": "checkbox", "id": "show_photo", "label": "Mostrar foto del lote", "info": "En la home se apaga (la sección queda solo con pasos + WhatsApp + links).", "default": true },
    { "type": "image_picker", "id": "lote_image", "label": "Foto del lote / batch code" },
    { "type": "text", "id": "lote_badge", "label": "Etiqueta sobre la foto", "default": "Foto real del lote" },
    { "type": "header", "content": "WhatsApp" },
    { "type": "paragraph", "content": "El número se configura global en Configuración del tema → WhatsApp / Contacto. El {product} se reemplaza por el producto actual." },
    { "type": "text", "id": "whatsapp_label", "label": "Texto del botón", "default": "Pedir video del lote por WhatsApp" },
    { "type": "text", "id": "whatsapp_message", "label": "Mensaje pre-armado", "default": "Hola! Quiero ver el video del lote de {product} antes de comprar." },
    { "type": "text", "id": "whatsapp_fallback_name", "label": "Nombre si no hay producto", "default": "este perfume" },
    { "type": "header", "content": "Original vs. réplica (link-card, estilo PDP)" },
    { "type": "url", "id": "compare_link", "label": "Link a la guía original vs. réplica" },
    { "type": "text", "id": "compare_title", "label": "Título del link", "default": "Original vs. réplica: cómo notar la diferencia" },
    { "type": "text", "id": "compare_text", "label": "Subtítulo del link", "default": "Guía con las señales que mira nuestro equipo." },
    { "type": "header", "content": "Fila de links (estilo home)" },
    { "type": "paragraph", "content": "Dos links chicos subrayados al pie de la card. Se muestran solo si tienen label y URL." },
    { "type": "text", "id": "link_1_label", "label": "Link 1 · label" },
    { "type": "url", "id": "link_1_url", "label": "Link 1 · URL" },
    { "type": "text", "id": "link_2_label", "label": "Link 2 · label" },
    { "type": "url", "id": "link_2_url", "label": "Link 2 · URL" },
    { "type": "header", "content": "Espaciado" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding superior", "default": 48 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding inferior", "default": 48 }
  ],
  "blocks": [
    {
      "type": "paso",
      "name": "Paso",
      "settings": [
        { "type": "richtext", "id": "text", "label": "Texto del paso", "default": "<p>Describí un paso de verificación.</p>" }
      ]
    }
  ],
  "max_blocks": 5,
  "presets": [
    {
      "name": "Autenticidad perfume",
      "blocks": [
        { "type": "paso", "settings": { "text": "<p>Cada frasco sellado tiene un <strong>código de lote (batch code)</strong> impreso. Te mostramos el real en las fotos del producto.</p>" } },
        { "type": "paso", "settings": { "text": "<p>Podés cruzar ese código en verificadores públicos de batch para confirmar fabricante y fecha.</p>" } },
        { "type": "paso", "settings": { "text": "<p>¿Querés verlo en vivo? Te enviamos <strong>foto y video del lote por WhatsApp</strong> antes de comprar.</p>" } }
      ]
    }
  ]
}
{% endschema %}
