{%- comment -%}
  Barra de ángulos curatoriales (NUMEN) — sub-navegación por colección.
  Fila horizontal scrolleable de chips (imagen circular + label). Editable por
  blocks: cada block = colección + (imagen opcional) + (label opcional). Va entre
  el banner y los controles de la grilla. El chip de la colección actual se
  resalta. No duplica los filtros (esos van en el drawer): acá van ÁNGULOS
  (Más elegidos, Para la noche, Frescos, Regalos…), no casas/familias.

  Fallback de imagen: block.image → collection.image → monograma (1ª letra).
{%- endcomment -%}
{{ 'section-collection-nav-bar.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- if section.blocks.size > 0 -%}
  <nav
    class="collnav color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding"
    aria-label="{{ section.settings.aria_label | escape }}"
  >
    <ul class="collnav__track" role="list">
      {%- for block in section.blocks -%}
        {%- liquid
          assign col = block.settings.collection
          assign label = block.settings.label
          if label == blank
            assign label = col.title
          endif
          assign url = col.url | default: block.settings.link
          assign img = block.settings.image
          if img == blank
            assign img = col.image
          endif
          assign is_active = false
          if col.id and collection.id and col.id == collection.id
            assign is_active = true
          endif
        -%}
        <li class="collnav__item" {{ block.shopify_attributes }}>
          <a
            class="collnav__link{% if is_active %} is-active{% endif %}"
            href="{{ url | default: '#' }}"
            {% if is_active %}aria-current="page"{% endif %}
            data-angle="{{ label | escape }}"
            data-collection="{{ col.handle }}"
          >
            <span class="collnav__thumb">
              {%- if img != blank -%}
                <img
                  src="{{ img | image_url: width: 120 }}"
                  srcset="{{ img | image_url: width: 60 }} 60w, {{ img | image_url: width: 120 }} 120w"
                  sizes="5.6rem"
                  width="56"
                  height="56"
                  alt=""
                  loading="lazy"
                >
              {%- else -%}
                <span class="collnav__monogram" aria-hidden="true">{{ label | slice: 0 | upcase }}</span>
              {%- endif -%}
            </span>
            <span class="collnav__label">{{ label | escape }}</span>
          </a>
        </li>
      {%- endfor -%}
    </ul>
  </nav>
{%- endif -%}

{% schema %}
{
  "name": "Barra de ángulos",
  "tag": "section",
  "class": "section section-collection-nav",
  "max_blocks": 12,
  "settings": [
    {
      "type": "paragraph",
      "content": "Sub-navegación por ÁNGULO (Más elegidos, Para la noche, Frescos, Regalos…), no por casa/familia (esas van en los filtros). Cada bloque apunta a una colección curada."
    },
    {
      "type": "text",
      "id": "aria_label",
      "label": "Etiqueta accesible (aria-label)",
      "default": "Colecciones"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 14
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 8
    }
  ],
  "blocks": [
    {
      "type": "angle",
      "name": "Ángulo",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Colección"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "info": "Si se deja vacío, usa el nombre de la colección."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagen",
          "info": "Opcional. Si se deja vacía, usa la imagen de la colección; si no hay, muestra la inicial."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link alternativo",
          "info": "Opcional. Solo si el ángulo no apunta a una colección (ej. 'Todos' → /collections/all)."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Barra de ángulos",
      "blocks": [{ "type": "angle" }, { "type": "angle" }, { "type": "angle" }, { "type": "angle" }]
    }
  ]
}
{% endschema %}
