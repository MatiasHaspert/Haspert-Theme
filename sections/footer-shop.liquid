{% style %}
  .footer-premium-{{ section.id }} {
    --footer-bg: {{ section.settings.bg_color }};
    --footer-text: {{ section.settings.text_color }};
    --footer-title: {{ section.settings.title_color }};
    --footer-link: {{ section.settings.link_color }};
    --footer-icon: {{ section.settings.icon_color }};
    --footer-mini-icon: {{ section.settings.mini_icon_color }};
    --footer-social: {{ section.settings.social_color }};
    --footer-trust-text: {{ section.settings.trust_text_color }};
    --footer-border: {{ section.settings.bottom_border_color }};
    --footer-bottom-text: {{ section.settings.bottom_text_color }};
    --footer-card-bg: {{ section.settings.card_bg }};
  }

  .footer-premium-{{ section.id }} {
    padding: 80px 20px 40px 20px;
    background: var(--footer-bg);
    color: var(--footer-text);
    font-size: 1.55rem;
  }

  /* GRID */
  .footer-premium-{{ section.id }}__inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3,1fr);
    gap: 50px;
  }

  /* TITULOS */
  .footer-premium-{{ section.id }} h3 {
    font-size: 1.8rem;
    font-weight: 700;
    margin-bottom: 18px;
    color: var(--footer-title);
  }

  /* LISTAS */
  .footer-premium-{{ section.id }} ul {
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .footer-premium-{{ section.id }} li {
    display: flex;
    align-items: center;
    gap: 8px;
    opacity: 0.85;
    line-height: 1.55;
    margin-bottom: 8px;
    color: var(--footer-text);
  }

  /* MINI ICONO */
  .footer-premium-{{ section.id }}__mini-icon {
    width: 14px;
    height: 14px;
    opacity: .9;
    filter: brightness(0) saturate(100%) invert(0%) sepia(0%) saturate(0%) hue-rotate(0deg) brightness(100%);
  }

  /* SOCIAL */
  .footer-premium-{{ section.id }}__social-icons {
    display: flex;
    gap: 20px;
    margin-top: 20px;
  }

  .footer-premium-{{ section.id }}__social-icons svg {
    width: 24px;
    height: 24px;
    fill: var(--footer-social);
    opacity: 0.85;
    transition: opacity .25s ease;
  }

  .footer-premium-{{ section.id }}__social-icons svg:hover {
    opacity: 1;
  }

  /* TRUST BAR */
  .footer-premium-{{ section.id }}__trustbar {
    display: flex;
    justify-content: center;
    gap: 28px;
    padding: 16px 0 26px 0;
    font-size: 1.4rem;
    opacity: 0.92;
    margin-top: 20px;
    flex-wrap: wrap;
    color: var(--footer-trust-text);
  }

  .footer-premium-{{ section.id }}__trust-item {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .footer-premium-{{ section.id }}__trust-icon {
    width: 18px;
    height: 18px;
    opacity: 0.9;
  }

  /* PAGOS */
  .footer-premium-{{ section.id }}__payments img {
    height: 26px;
    width: auto;
    margin: 0 4px;
    opacity: .95;
  }

  /* FOOTER BOTTOM */
  .footer-premium-{{ section.id }}__bottom {
    border-top: 1px solid var(--footer-border);
    margin-top: 55px;
    padding-top: 26px;
    text-align: center;
    opacity: 0.85;
    font-size: 1.45rem;
    color: var(--footer-bottom-text);
  }

  /* MOBILE */
  @media (max-width: 749px) {
    .footer-premium-{{ section.id }}__inner {
      grid-template-columns: 1fr;
      gap: 45px;
    }

    .footer-premium-{{ section.id }} {
      padding: 50px 20px 30px 20px;
    }

    .footer-premium-{{ section.id }}__trustbar {
      gap: 14px;
      padding-top: 10px;
    }
  }
{% endstyle %}


<section class="footer-premium-{{ section.id }}">
  <div class="footer-premium-{{ section.id }}__inner">

    <div>
      <h3>{{ section.settings.g_title }}</h3>

      <ul>
        <li>
          <img class="footer-premium-{{ section.id }}__mini-icon" src="{{ 'icon-check.svg' | asset_url }}" width="16" height="16">
          {{ section.settings.g_1 }}
        </li>
        <li>
          <img class="footer-premium-{{ section.id }}__mini-icon" src="{{ 'icon-check.svg' | asset_url }}" width="16" height="16">
          {{ section.settings.g_2 }}
        </li>
        <li>
          <img class="footer-premium-{{ section.id }}__mini-icon" src="{{ 'icon-check.svg' | asset_url }}" width="16" height="16">
          {{ section.settings.g_3 }}
        </li>
      </ul>
    </div>

    <div>
      <h3>{{ section.settings.s_title }}</h3>

      <ul>
        <li>
          Nuestro equipo está para ayudarte todos los días. Respondemos rápido.
        </li>
        {% if section.settings.s_email %}
        <li>
          <img class="footer-premium-{{ section.id }}__mini-icon" src="{{ 'icon-mail.svg' | asset_url }}" width="16" height="16">
          {{ section.settings.s_email }}
        </li>
        {% endif %}

        {% if section.settings.s_whatsapp %}
        <li>
          <img class="footer-premium-{{ section.id }}__mini-icon" src="{{ 'icon-whatsapp.svg' | asset_url }}" width="16" height="16">
          {{ section.settings.s_whatsapp }}
        </li>
        {% endif %}

        <li>
          Respondemos rápido. Estamos para ayudarte todos los días.  
        </li>
      </ul>
    </div>

    <div>
      <h3>{{ section.settings.m_title }}</h3>
      <p>{{ section.settings.m_desc }}</p>
      <p>{{ section.settings.reviews_text }}</p>

      <div class="footer-premium-{{ section.id }}__social-icons">
        {% if section.settings.instagram %}
          <a href="{{ section.settings.instagram }}" target="_blank">
            <svg viewBox="0 0 24 24"><path d="M7 2C4.243 2 2 4.243 2 7v10c0 2.757 2.243 5 5 5h10c2.757 0 5-2.243 5-5V7c0-2.757-2.243-5-5-5H7zm10 2a3 3 0 013 3v10a3 3 0 01-3 3H7a3 3 0 01-3-3V7a3 3 0 013-3h10zm-5 3a5 5 0 100 10 5 5 0 000-10zm6.5-.25a1.25 1.25 0 11-2.5 0 1.25 1.25 0 012.5 0z"/></svg>
          </a>
        {% endif %}

        {% if section.settings.tiktok %}
          <a href="{{ section.settings.tiktok }}" target="_blank">
            <svg viewBox="0 0 24 24"><path d="M16 3c.2 1.7 1.5 3 3.2 3.2V9c-1.3 0-2.5-.4-3.5-1v6.3c0 3-2.4 5.5-5.5 5.7A5.7 5.7 0 014 14c.2-3 2.7-5.4 5.7-5.4.4 0 .8 0 1.2.1v3.2c-.4-.2-.8-.4-1.2-.4-1.4 0-2.5 1.3-2.5 2.5 0 1.4 1.1 2.5 2.5 2.5s2.5-1 2.5-2.4V3h4z"/></svg>
          </a>
        {% endif %}

        {% if section.settings.facebook %}
          <a href="{{ section.settings.facebook }}" target="_blank">
            <svg viewBox="0 0 24 24"><path d="M22 12a10 10 0 10-11.5 9.9v-7H7v-3h3.5V9.5a4.5 4.5 0 014.8-5c1.4 0 2.8.3 2.8.3v3H16c-1.6 0-2 .9-2 1.9V12H18l-.5 3h-3v7A10 10 0 0022 12z"/></svg>
          </a>
        {% endif %}
      </div>
    </div>

  </div>

  <div class="footer-premium-{{ section.id }}__trustbar">

    <div class="footer-premium-{{ section.id }}__trust-item">
      <img class="footer-premium-{{ section.id }}__trust-icon" src="{{ 'icon-truck.svg' | asset_url }}" width="16" height="16">
      Envíos a todo el país
    </div>

    <div class="footer-premium-{{ section.id }}__trust-item">
      <img class="footer-premium-{{ section.id }}__trust-icon" src="{{ 'icon-shield.svg' | asset_url }}" width="16" height="16">
      Garantía 30 días
    </div>

    <div class="footer-premium-{{ section.id }}__trust-item">
      <img class="footer-premium-{{ section.id }}__trust-icon" src="{{ 'icon-lock.svg' | asset_url }}" width="16" height="16">
      Pago seguro 100% protegido
    </div>

    <div class="footer-premium-{{ section.id }}__trust-item">
      🇦🇷 Operamos desde Argentina — soporte local
    </div>

  </div>

  <div class="footer-premium-{{ section.id }}__bottom">

    <div class="footer-premium-{{ section.id }}__payments">
      {% if section.settings.icon_visa %}
        {{ section.settings.icon_visa | image_url: width: 80 | image_tag: class: 'footer-payment-icon' }}
      {% endif %}
      {% if section.settings.icon_mastercard %}
        {{ section.settings.icon_mastercard | image_url: width: 80 | image_tag: class: 'footer-payment-icon' }}
      {% endif %}
      {% if section.settings.icon_amex %}
        {{ section.settings.icon_amex | image_url: width: 80 | image_tag: class: 'footer-payment-icon' }}
      {% endif %}
      {% if section.settings.icon_mp %}
        {{ section.settings.icon_mp | image_url: width: 140 | image_tag: class: 'footer-payment-icon' }}
      {% endif %}
    </div>

    © {{ 'now' | date: "%Y" }} {{ shop.name }} · Todos los derechos reservados
  </div>

</section>

{% schema %}
{
  "name": "Footer Premium",
  "settings": [
    { "type": "text", "id": "g_title", "label": "Título Garantías", "default": "Garantías" },
    { "type": "text", "id": "g_1", "label": "Garantía 1", "default": "30 días de prueba o reembolso" },
    { "type": "text", "id": "g_2", "label": "Garantía 2", "default": "Cambios fáciles y rápidos" },
    { "type": "text", "id": "g_3", "label": "Garantía 3", "default": "Productos certificados y seguros" },

    { "type": "text", "id": "s_title", "label": "Título Soporte", "default": "Soporte" },
    { "type": "text", "id": "s_email", "label": "Email" },
    { "type": "text", "id": "s_whatsapp", "label": "WhatsApp", "default": "+54 9 11 4000 0000" },

    { "type": "text", "id": "m_title", "label": "Título Marca", "default": "Nuestra Marca" },
    { "type": "textarea", "id": "m_desc", "label": "Descripción", "default": "Perfumería importada y árabe original. Frasco sellado, lote verificable y envíos a todo el país." },

    { "type": "text", "id": "reviews_text", "label": "Texto de reseñas", "default": "+1200 reseñas verificadas" },

    { "type": "url", "id": "instagram", "label": "Instagram" },
    { "type": "url", "id": "tiktok", "label": "TikTok" },
    { "type": "url", "id": "facebook", "label": "Facebook" },
    {
      "type": "header",
      "content": "Íconos de métodos de pago"
    },
    {
      "type": "image_picker",
      "id": "icon_visa",
      "label": "Ícono Visa"
    },
    {
      "type": "image_picker",
      "id": "icon_mastercard",
      "label": "Ícono Mastercard"
    },
    {
      "type": "image_picker",
      "id": "icon_amex",
      "label": "Ícono American Express"
    },
    {
      "type": "image_picker",
      "id": "icon_mp",
      "label": "Ícono Mercado Pago"
    },
    {
      "type": "header",
      "content": "🎨 Colores personalizados del Footer"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Fondo del footer",
      "default": "#fafafa"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Color del texto",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Color de los títulos",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Color para links",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Color general de iconos (social)",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "mini_icon_color",
      "label": "Color de mini íconos (listas)",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "social_color",
      "label": "Color de los íconos sociales",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "trust_text_color",
      "label": "Color del texto de la trustbar",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "bottom_border_color",
      "label": "Color del borde inferior",
      "default": "rgba(0,0,0,0.1)"
    },
    {
      "type": "color",
      "id": "bottom_text_color",
      "label": "Color del texto inferior",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Fondo de las tarjetas en columnas (opcional)",
      "default": "transparent"
    }
  ]
}
{% endschema %}