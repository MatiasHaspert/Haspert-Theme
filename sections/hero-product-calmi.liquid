{% comment %}
  Sección: Calmi - HERO principal de producto con Pack 2x (versión A)
  Archivo: /sections/product-hero-calmi.liquid

  - Hero principal para plantillas de producto.
  - Layout 2 columnas: galería izquierda, contenido derecha.
  - Precio + compare_at + badge de descuento dinámico.
  - Selector de modelo (Nutria / Capibara / Elefante, etc.) usando variantes SINGLE.
  - Botón de compra usando product-form nativo (solo Single).
  - Módulo Pack 2x: elegís 2 modelos libres, con 50% OFF en la segunda unidad.
    * NO depende de variantes "Pack 2x" → arma el pack usando variantes SINGLE.
  - Beneficios rápidos configurables vía blocks.
{% endcomment %}

{% if product == blank %}
  <div class="product-hero-calmi-placeholder">
    <p>Esta sección debe usarse en una plantilla de producto.</p>
  </div>
{% else %}
  {%- assign current_variant = product.selected_or_first_available_variant -%}

  {%- if current_variant.option2 == 'Calmi Nutria' -%}
    {%- for v in product.variants -%}
      {%- if v.available and v.option2 != 'Calmi Nutria' -%}
        {%- assign current_variant = v -%}
        {%- break -%}
      {%- endif -%}
    {%- endfor -%}
  {%- endif -%}


  {%- assign model_option = product.options_with_values[0] -%}
  {%- assign model_option_position = model_option.position -%}
  {%- for opt in product.options_with_values -%}
    {%- if opt.name == 'Tipo Peluche' -%}
      {%- assign model_option = opt -%}
      {%- assign model_option_position = opt.position -%}
    {%- endif -%}
  {%- endfor -%}

  {%- case model_option_position -%}
    {%- when 1 -%}
      {%- assign current_model_value = current_variant.option1 -%}
    {%- when 2 -%}
      {%- assign current_model_value = current_variant.option2 -%}
    {%- when 3 -%}
      {%- assign current_model_value = current_variant.option3 -%}
    {%- else -%}
      {%- assign current_model_value = model_option.values[0] -%}
  {%- endcase -%}

  {%- assign initial_media = current_variant.featured_media | default: product.featured_media -%}

  {% style %}
    /* ============================
   PRODUCT HERO — DESKTOP BASE
   ============================ */

  .product-hero-calmi-{{ section.id }} {
    background: {{ section.settings.hero_bg }};
  }

  .product-hero-calmi-{{ section.id }} .phc-gallery-main {
    background: {{ section.settings.gallery_bg }};
  }

  .product-hero-calmi-{{ section.id }} .phc-title {
    color: {{ section.settings.title_color }};
  }

  .product-hero-calmi-{{ section.id }} .phc-subtitle {
    color: {{ section.settings.subtitle_color }};
  }

  .product-hero-calmi-{{ section.id }} .phc-badge {
    background: {{ section.settings.badge_color_bg }};
    color: {{ section.settings.badge_color_text }};
  }

  .product-hero-calmi-{{ section.id }} .phc-price-current {
    color: {{ section.settings.price_color }};
  }

  .product-hero-calmi-{{ section.id }} .phc-price-compare {
    color: {{ section.settings.price_compare_color }};
  }

  .product-hero-calmi-{{ section.id }} .phc-cta-button {
    background: {{ section.settings.cta_bg }};
    color: {{ section.settings.cta_text }};
  }

  .product-hero-calmi-{{ section.id }} .phc-sticky-cta-button,
  .product-hero-calmi-{{ section.id }} .phc-sticky-desktop-button {
    background: {{ section.settings.cta_bg }};
    color: {{ section.settings.cta_text }};
  }

    /* ----------------------------
      1) LAYOUT GENERAL
      ---------------------------- */
    .product-hero-calmi {
      padding: 2.5rem 1.5rem;
    }

    .product-hero-calmi__inner {
      max-width: 1200px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: minmax(0, 1.1fr) minmax(0, 1fr);
      gap: 2.5rem;
      align-items: flex-start;
    }

    /* ----------------------------
      2) GALLERY — MAIN
      ---------------------------- */
    .phc-gallery {
      display: flex;
      flex-direction: column;
      gap: 0.85rem;
    }

    .phc-gallery-main-inner {
      width: 100%;
      height: 100%;
      position: relative;
    }

    .phc-gallery-main {
      position: relative;
      border-radius: 1.25rem;
      overflow: hidden;
      background: #f4f4f5;
      aspect-ratio: 4 / 5;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: default;
    }

    .phc-gallery-main--clickable {
      cursor: zoom-in;
    }

    .phc-gallery-main img,
    .phc-gallery-main video,
    .phc-gallery-main model-viewer {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .phc-video {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      border-radius: inherit;
    }

    /* ----------------------------
      3) GALLERY — THUMBS
      ---------------------------- */
    .phc-gallery-thumbs {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .phc-gallery-thumb {
      border-radius: 0.75rem;
      overflow: hidden;
      border: 1px solid rgba(0,0,0,0.04);
      background: #fff;
      padding: 0;
      cursor: pointer;
      flex: 0 0 auto;
      width: 64px;
      height: 64px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .phc-gallery-thumb img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .phc-gallery-thumb.is-active {
      outline: 2px solid #111827;
      outline-offset: 0;
      border-color: transparent;
    }

    .phc-thumb-video-icon {
      position: absolute;
      bottom: 4px;
      right: 4px;
      background: rgba(0,0,0,0.55);
      color: #fff;
      font-size: 12px;
      padding: 2px 5px;
      border-radius: 4px;
      font-weight: bold;
      pointer-events: none;
      z-index: 3;
    }

    /* ----------------------------
      4) CONTENT WRAPPER
      ---------------------------- */
    .phc-content {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    /* ----------------------------
      5) BADGE
      ---------------------------- */
    .phc-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      font-size: 0.8rem;
      font-weight: 600;
      padding: 0.35rem 0.65rem;
      border-radius: 999px;
      background: rgba(34,197,94,0.08);
      color: #15803d;
      margin-bottom: 0.4rem;
    }

    .phc-badge-dot {
      width: 7px;
      height: 7px;
      border-radius: 999px;
      background: #22c55e;
      box-shadow: 0 0 0 4px rgba(34,197,94,0.2);
    }

    /* ----------------------------
      6) TITLES
      ---------------------------- */
    .phc-title {
      font-size: clamp(1.9rem, 2.15rem + 0.4vw, 2.4rem);
      line-height: 1.1;
      letter-spacing: -0.03em;
      margin: 0 0 0.55rem;
    }

    .phc-subtitle {
      font-size: 0.98rem;
      line-height: 1.6;
      opacity: 0.88;
      margin-bottom: 0.55rem;
    }

    /* ----------------------------
      7) PRICE BLOCK
      ---------------------------- */
    .phc-price-row {
      margin: 0;
      padding: 0;
    }

    .phc-price-current {
      font-size: 2.0rem;
      font-weight: 800;
      color: #ef4444;
    }

    .phc-price-compare {
      font-size: 1.1rem;
      opacity: 0.6;
      text-decoration: line-through;
      margin-left: 0.4rem;
    }

    .phc-price-badge {
      background: #f472b6 !important;  /* Rosa más fuerte (but elegante) */
      color: #9d174d !important;       /* Rosa oscuro premium */
      padding: 0.28rem 0.68rem !important; /* leve más sólido */
      border-radius: 999px;
      font-size: 0.9rem;
      font-weight: 700;
      margin-left: 0.45rem;
      letter-spacing: -0.01em;          /* se ve más compacto y pro */
    }

    .phc-installments-text {
      margin: 0;
      padding: 0;
      font-size: 1.3rem;
      line-height: 1.2;
      margin-top: 0.4rem !important;
      margin-bottom: 0.75rem !important;
    }

    /* ----------------------------
      8) VARIANTS
      ---------------------------- */
    .phc-variants-label {
      font-size: 0.9rem;
      font-weight: 600;
      margin: 0 0 1rem;
      opacity: 0.8;
      margin-top: 1.1rem !important; /* antes ~0 */
    }

    .phc-variants {
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
      margin-bottom: 0.7rem;
    }

    .phc-variant-option__values {
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem;
    }

    .phc-variant-pill {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      padding: 0.3rem 0.45rem 0.3rem 0.3rem;
      border-radius: 999px;
      border: 1px solid rgba(0,0,0,0.08);
      background: #fff;
      cursor: pointer;
      font-size: 0.85rem;
      transition: box-shadow 0.18s ease, border-color 0.18s ease, transform 0.1s ease, background 0.18s ease;
    }

    .phc-variant-pill-thumb {
      width: 32px;
      height: 32px;
      border-radius: 999px;
      overflow: hidden;
      background: #f4f4f5;
      flex-shrink: 0;
    }

    .phc-variant-pill-thumb img,
    .phc-variant-pill-thumb svg {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .phc-variant-pill-label {
      white-space: nowrap;
    }

    .phc-variant-pill.is-active {
      border-color: #111827;
      box-shadow: 0 0 0 1px #111827;
      background: #f9fafb;
      transform: translateY(-1px);
    }

    /* ----------------------------
      9) PRODUCT FORM + QUANTITY
      ---------------------------- */
    .phc-form {
      display: flex;
      flex-direction: column;
      gap: 0.6rem;
      margin-top: 0.3rem;
    }

    .phc-quantity {
      display: flex;
      align-items: center;
      justify-content: space-between;
      font-size: 0.9rem;
      gap: 0.6rem;
    }

    .phc-quantity-input {
      display: inline-flex;
      align-items: center;
      border-radius: 999px;
      border: 1px solid rgba(0,0,0,0.08);
      overflow: hidden;
      background: #fff;
    }

    .phc-quantity-input button {
      border: none;
      background: transparent;
      width: 32px;
      height: 32px;
      font-size: 1.1rem;
      cursor: pointer;
    }

    .phc-quantity-input input {
      width: 42px;
      text-align: center;
      border: none;
      outline: none;
      font-size: 0.95rem;
    }

    /* ----------------------------
      10) CTA BUTTON
      ---------------------------- */
    .phc-cta-button {
      width: 100%;
      border-radius: 999px;
      padding: 0.9rem 1.2rem;
      border: none;
      background: linear-gradient(135deg, #fb923c, #f97316);
      color: #fff;
      font-weight: 700;
      font-size: 1rem;
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.4rem;
      box-shadow: 0 14px 30px rgba(249,115,22,0.35);
      transition: transform 0.12s ease, box-shadow 0.12s ease, opacity 0.12s ease;
    }

    .phc-cta-button:hover:not([disabled]) {
      transform: translateY(-1px);
      box-shadow: 0 18px 36px rgba(249,115,22,0.4);
    }

    .phc-cta-button:disabled {
      opacity: 0.6;
      cursor: not-allowed;
      box-shadow: none;
    }

    .phc-cta-subtext {
      font-size: 0.82rem;
      color: #4b5563;
      margin: 0;
      text-align: center;
    }

    /* ----------------------------
      11) BENEFITS (INLINE + GRID)
      ---------------------------- */
    .phc-benefits-inline {
      display: flex;
      align-items: center;
      gap: 0.9rem;
      font-size: 0.85rem;
      color: #4b5563;
      flex-wrap: wrap;
      margin-top: 0.85rem !important; /* antes 0.45 */
      margin-bottom: 0.35rem !important;
    }

    .phc-benefit-inline {
      display: flex;
      align-items: center;
      gap: 0.35rem;
      white-space: nowrap;
    }

    .phc-benefit-inline .icon {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: 1.1rem;
    }

    /* Benefits grid */
    .phc-benefits {
      list-style: none;
      padding: 0;
      margin: 1rem 0 0;
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 0.6rem 1rem;
      margin-bottom: 1rem !important;
    }

    .phc-benefit {
      display: flex;
      align-items: flex-start;
      gap: 0.45rem;
      font-size: 0.78rem;
    }

    .phc-benefit__icon {
      width: 20px;
      height: 20px;
      border-radius: 999px;
      background: #ecfdf5;
      color: #16a34a;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .phc-benefit__title {
      font-weight: 600;
      margin: 0 0 0.05rem;
    }

    .phc-benefit__text {
      margin: 0;
      opacity: 0.8;
    }

    /* Nutria deshabilitada */
    .phc-variant-pill.is-sold-out {
      opacity: 0.45;
      cursor: not-allowed !important;
      background: #f4f4f5 !important;
      border-color: #e5e7eb !important;
    }

    /* Badge "Agotado" */
    .phc-variant-badge-soldout {
      background: #e11d48;
      color: #fff;
      font-size: 0.65rem;
      padding: 0.15rem 0.45rem;
      border-radius: 999px;
      margin-left: 0.35rem;
      font-weight: 700;
      text-transform: uppercase;
    }

    /* ==========================================
   🎉 PACK 2× — BLACK FRIDAY EDITION
   ========================================== */
  
  .phc-pack,
  .phc-pack * {
    color: #f8f8f8 !important;
  }

  /* Labels dentro del selector */
  .phc-variant-pill.phc-pack-pill .phc-variant-pill-label {
    color: #ffffff !important;
  }

  .phc-pack {
    margin-top: 1.4rem;
    padding: 1.2rem 1rem 1.3rem;
    border-radius: 1.2rem;
    background: linear-gradient(135deg, #111, #1c1c1c 40%, #0f0f0f);
    border: 1px solid rgba(255, 34, 94, 0.35);
    box-shadow: 0 8px 22px rgba(255, 0, 72, 0.2);
    color: #fff;
    position: relative;
    overflow: hidden;
  }

  .phc-pack::before {
    /* borde neon suave */
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 1px;
    background: linear-gradient(135deg, #ff2e63, #ff006e, #ff3d81);
    -webkit-mask: 
      linear-gradient(#fff 0 0) content-box, 
      linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
            mask-composite: exclude;
    pointer-events: none;
  }

  .phc-pack-title {
    font-size: 1.1rem;
    font-weight: 800;
    color: #ff4f8b;
  }

  /* Descripción breve debajo del título */
  .phc-pack-header div div {
    color: #e8e8e8 !important;
    opacity: 1 !important;
  }

  .phc-pack-tag {
    font-size: 0.75rem;
    font-weight: 800;
    padding: 0.35rem 0.7rem;
    border-radius: 999px;
    background: linear-gradient(135deg, #ff003c, #ff4f8b);
    color: #fff;
    box-shadow: 0 4px 12px rgba(255, 0, 72, 0.35);
  }

  .phc-pack-picker-label {
    color: #f2f2f2 !important;
    font-weight: 600 !important;
  }

  .phc-pack-options .phc-pack-pill {
    background: #1c1c1c !important;
    border: 1px solid rgba(255, 80, 120, 0.35);
    color: #fff !important;
  }

  .phc-pack-pill.is-active {
    background: #ff2e63 !important;
    color: white !important;
    border-color: #ff2e63 !important;
    box-shadow: 0 3px 8px rgba(255, 46, 99, 0.45);
    transform: translateY(-2px);
  }

  .phc-pack-summary {
    background: rgba(255, 255, 255, 0.05) !important;
    border: 1px solid rgba(255, 0, 72, 0.25);
    color: #fff;
  }

  /* El número del ahorro */
  .phc-pack-summary-row span[data-pack-savings] {
    color: #ff8fb0 !important;
    font-weight: 700 !important;
  }

  .phc-pack-total-value {
    color: #ffb3c8 !important;
    font-weight: 800 !important;
  }

  .phc-pack-savings-pill {
    background: rgba(255, 0, 72, 0.3) !important;
    font-weight: 700;
    color: #ff8fb0 !important;
  }

  .phc-pack-cta {
    margin-top: 0.5rem;
    padding: 0.9rem 1.2rem;
    border-radius: 999px;
    background: linear-gradient(135deg, #ff0055, #ff2e63, #ff4f8b);
    color: #fff;
    font-size: 1rem;
    font-weight: 900;
    text-shadow: 0 0 8px rgba(255, 0, 72, 0.55);
    transition: 0.15s ease;
  }

  .phc-pack-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 14px 32px rgba(255, 0, 72, 0.55);
  }

  .phc-pack-microcopy {
    font-size: 0.8rem;
    font-weight: 600;
    color: #ff4f8b; /* mismo tono que el Black Friday */
    margin-top: 1.3rem;
    margin-bottom: 0.25rem;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }

  .phc-pack-microcopy span {
    opacity: 0.95;
  }


