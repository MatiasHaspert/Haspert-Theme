    /* ----------------------------
      13) ZOOM MODAL
      ---------------------------- */
    .phc-zoom-backdrop {
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.6);
      display: none;
      align-items: center;
      justify-content: center;
      z-index: 9999;
      padding: 1.5rem;
    }

    .phc-zoom-backdrop.is-open {
      display: flex;
    }

    .phc-zoom-inner {
      max-width: 100%;
      max-height: 100%;
    }

    .phc-zoom-inner img {
      max-width: 100%;
      max-height: 100%;
      display: block;
      border-radius: 1.25rem;
    }

    .phc-zoom-close {
      position: absolute;
      top: 1rem;
      right: 1rem;
      border: none;
      border-radius: 999px;
      width: 32px;
      height: 32px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: rgba(15,23,42,0.8);
      color: #fff;
      cursor: pointer;
    }

    /* ----------------------------
      14) ANIMATIONS
      ---------------------------- */
    .phc-gallery-main-media {
      opacity: 1;
      transition: opacity 0.35s ease;
    }

    .phc-gallery-main-media.is-fading-out {
      opacity: 0;
    }

    .phc-gallery-main-media.is-fading-in {
      opacity: 1;
    }

    /* ============================
      FAQ QUESTIONS (ACORDEÓN)
    ============================ */

    .phc-faq {
      margin-top: 0.1rem;
      border-top: 1px solid rgba(0,0,0,0.06);
      display: flex;
      flex-direction: column;
      gap: 0.35rem;
    }

    .phc-faq-item {
      border-bottom: 1px solid rgba(0,0,0,0.06);
      padding-bottom: 0.2rem;
    }

    .phc-faq-question {
      width: 100%;
      background: transparent;
      border: none;
      padding: 0.35rem 0;
      font-size: 0.9rem;
      font-weight: 600;
      text-align: left;
      display: flex;
      align-items: center;
      justify-content: space-between;
      cursor: pointer;
    }

    .phc-faq-icon {
      margin-right: 0.45rem;
      font-size: 1.15rem;
    }

    .phc-faq-icon svg {
      width: 20px;
      height: 20px;
      display: inline-block;
    }

    .phc-faq-arrow {
      transition: transform .2s ease;
      opacity: .7;
    }

    .phc-faq-question.is-open .phc-faq-arrow {
      transform: rotate(180deg);
      opacity: 1;
    }

    .phc-faq-answer {
      display: none;
      padding: 0.2rem 0 0.4rem 1.8rem;
      font-size: 0.86rem;
      line-height: 1.5;
      opacity: 0.85;
    }

    .phc-faq-answer.is-open {
      display: block;
    }

    /* COLOR SELECTOR — MATCH VARIANT PILLS */
    .phc-color-selector-wrapper {
      margin-top: .6rem;
      margin-bottom: .4rem;
    }

    .phc-color-pill {
      border-radius: 999px;
      padding: 0.32rem 0.55rem 0.32rem 0.35rem;
    }

    .phc-color-pill.is-active {
      border-color: #111827;
      box-shadow: 0 0 0 1px #111827;
      background: #f9fafb;
      transform: translateY(-1px);
    }


    /* ============================
   PRODUCT HERO — MOBILE OVERRIDES
   ============================ */

    @media (max-width: 749px) {
      .phc-sticky-cta-desktop {
        display: none !important;
      }

      /* ----------------------------
        1) LAYOUT GENERAL
        ---------------------------- */
      .product-hero-calmi {
        padding: 1.75rem 1.25rem 2.25rem;
      }

      .product-hero-calmi__inner {
        grid-template-columns: 1fr;
        gap: 1.75rem;
      }

      /* ----------------------------
        2) GALLERY MOBILE
        ---------------------------- */
      .phc-gallery-main {
        aspect-ratio: 1 / 1;
        max-height: 330px;
        height: 100%;
      }

      .phc-gallery-thumbs {
        display: flex;
        flex-wrap: nowrap;
        overflow-x: auto;
        overflow-y: hidden;
        gap: 0.5rem;
        padding-bottom: 0.5rem;
        scroll-snap-type: x mandatory;
        -webkit-overflow-scrolling: touch;
      }

      .phc-gallery-thumb {
        flex: 0 0 auto;
        width: 72px;
        height: 72px;
        scroll-snap-align: start;
      }

      /* ocultar scrollbar */
      .phc-gallery-thumbs::-webkit-scrollbar {
        display: none;
      }

      /* 🔥 FIX: evitar desfasamiento del hero en mobile */
      .product-hero-calmi__inner,
      .phc-gallery,
      .phc-gallery-main,
      .phc-gallery-main-inner {
        max-width: 100% !important;
        overflow: hidden !important;
      }

      /* 🔥 FIX específico para evitar desplazamiento lateral */
      .product-hero-calmi {
        overflow-x: hidden !important;
      }

      /* 🔥 Garantiza que las thumbnails no generen "anchos fantasma" */
      .phc-gallery-thumbs {
        width: 100%;
        box-sizing: border-box;
      }

      /* ----------------------------
        3) CONTENT ORDER MOBILE
        ---------------------------- */
      .phc-content {
        display: flex;
        flex-direction: column;
        gap: 0.5rem; /* antes 1rem */
      }

      .phc-title {
        order: -4;
      }

      .phc-subtitle {
        order: -3;
      }

      .phc-badge {
        order: -2 !important;  /* más alto que el precio, pero debajo del título */
      }

      .phc-price-row {
        order: -1;
      }

      .phc-variants {
        order: 0;
      }

      form.phc-form {
        order: 1;
      }

      .phc-pack-microcopy {
        order: 2;
      }

      .phc-pack {
        margin-top: 2rem;
        order: 3;
      }

      /* FAQ (acordeones) */
      .phc-faq-blocks {
        order: 4 !important;
        margin-top: 1.5rem;
      }

      /* ----------------------------
        4) BENEFITS MOBILE
        ---------------------------- */
      .phc-benefits {
        grid-template-columns: repeat(2, minmax(0, 1fr));
        order: 5;
      }

      /* ----------------------------
        5) PACK 2X MOBILE
        ---------------------------- */
      .phc-pack-pickers {
        grid-template-columns: 1fr;
      }

      /* ----------------------------
        6) STICKY CTA MOBILE (base in Part 3)
        ---------------------------- */
      .phc-sticky-cta-mobile {
        display: none;
        position: fixed;
        left: 0;
        right: 0;
        bottom: 0;
        will-change: transform, opacity;
        padding: 0.75rem 1rem calc(0.75rem + env(safe-area-inset-bottom));
        background: rgba(255,255,255,0.95);
        backdrop-filter: blur(10px);
        border-top: 1px solid rgba(0,0,0,0.08);

        z-index: 9999;

        opacity: 0;
        transform: translateY(20px);
        pointer-events: none;

        transition: opacity .18s ease, transform .18s ease;
      }

      .phc-sticky-cta-mobile.is-visible {
        display: block;
        opacity: 1;
        transform: translateY(0);
        pointer-events: auto;
      }

      .phc-sticky-cta-button {
        width: 100%;
        border-radius: 999px;
        padding: 1rem 1.2rem;
        border: none;
        background: linear-gradient(135deg, #fb923c, #f97316);
        color: #fff;
        font-weight: 700;
        font-size: 1.05rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;

        box-shadow: 0 12px 28px rgba(249,115,22,0.35);
        transition: transform 0.1s ease, box-shadow 0.1s ease;
      }

      .phc-sticky-cta-button:active {
        transform: scale(0.97);
        box-shadow: 0 8px 16px rgba(249,115,22,0.25);
      }

    }

    /* ============================
   PRODUCT HERO — STICKY CTA
   (DESKTOP BASE)
   ============================ */
    @media (min-width: 750px) {
      .phc-sticky-cta-mobile {
        display: none !important;
        visibility: hidden !important;
        opacity: 0 !important;
        pointer-events: none !important;
      }
    }

    /* ----------------------------
      Sticky CTA — Offer block
      ---------------------------- */

    .phc-sticky-offer {
      display: flex;
      flex-direction: column;
      gap: 0.15rem;
      margin-bottom: 0.5rem;
    }

    .phc-sticky-price {
      font-size: 1.3rem;
      font-weight: 800;
      color: #ef4444;
      line-height: 1;
    }

    .phc-sticky-compare {
      font-size: 0.85rem;
      opacity: 0.55;
      text-decoration: line-through;
      margin-left: 0.25rem;
    }

    .phc-sticky-badge {
      background: #fbcfe8;
      color: #be185d;
      padding: 0.15rem 0.5rem;
      border-radius: 999px;
      font-size: 0.75rem;
      font-weight: 700;
      width: fit-content;
    }

    .phc-sticky-installments {
      font-size: 0.85rem;
      color: #374151;
      margin-top: 0.1rem;
    }

    /* =============================
   STICKY CTA — DESKTOP (AMPLIADO)
   ============================= */

  .phc-sticky-cta-desktop {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    padding: 1.2rem 2rem; /* MAS ALTO */
    background: rgba(255, 255, 255, 0.97);
    backdrop-filter: blur(12px);
    border-top: 1px solid rgba(0, 0, 0, 0.06);
    box-shadow: 0 -10px 26px rgba(15, 23, 42, 0.12);
    z-index: 9998;

    transform: translateY(100%);
    opacity: 0;
    pointer-events: none;
    transition: transform 0.22s ease, opacity 0.22s ease;
  }

  .phc-sticky-cta-desktop.is-visible {
    transform: translateY(0);
    opacity: 1;
    pointer-events: auto;
  }

  /* Contenedor interno */
  .phc-sticky-desktop-inner {
    max-width: 1300px;  /* MAS ANCHO */
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  /* Bloque de oferta */
  .phc-sticky-offer {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .phc-sticky-price {
    font-size: 1.9rem;        /* MAS GRANDE */
    font-weight: 800;
    color: #ef4444;
    line-height: 1;
  }

  .phc-sticky-compare {
    font-size: 1.05rem;
    opacity: 0.6;
    text-decoration: line-through;
  }

  .phc-sticky-badge {
    background: #f9a8d4;
    color: #9d174d;
    padding: 0.25rem 0.7rem;
    border-radius: 999px;
    font-size: 0.9rem;        /* MAS GRANDE */
    font-weight: 700;
  }

  /* Texto de cuotas */
  .phc-sticky-installments {
    font-size: 1rem;
    color: #374151;
  }

  /* Botón desktop */
  .phc-sticky-desktop-button {
    min-width: 260px;        /* MAS ANCHO */
    border-radius: 999px;
    padding: 1rem 1.6rem;    /* MAS ALTO */
    border: none;
    background: linear-gradient(135deg, #fb923c, #f97316);
    color: #fff;
    font-weight: 800;         /* MÁS GROSOR */
    font-size: 1.15rem;       /* MAS GRANDE */
    cursor: pointer;

    display: inline-flex;
    align-items: center;
    justify-content: center;
    white-space: nowrap;

    box-shadow: 0 14px 30px rgba(249, 115, 22, 0.35);
    transition: transform 0.12s ease, box-shadow 0.12s ease, opacity 0.12s ease;
  }

  .phc-sticky-desktop-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 20px 36px rgba(249, 115, 22, 0.45);
  }

  {% endstyle %}

  <section
    id="product-hero-calmi-{{ section.id }}"
    class="product-hero-calmi product-hero-calmi-{{ section.id }} color-{{ section.settings.color_scheme }}"
    data-product-hero-calmi
    data-product-id="{{ product.id }}"
    data-initial-variant-id="{{ current_variant.id }}"
  >
    <div class="product-hero-calmi__inner">
      <div class="phc-gallery">
        <div
          class="phc-gallery-main{% if initial_media and initial_media.media_type == 'image' %} phc-gallery-main--clickable{% endif %}"
          data-gallery-main
        >
          <div class="phc-gallery-main-inner" data-gallery-main-inner>
            {% if initial_media %}
              <div
                class="phc-gallery-main-media"
                data-media-type="{{ initial_media.media_type }}"
              data-media-id="{{ initial_media.id }}"
              >
                {% case initial_media.media_type %}
                  {% when 'image' %}
                    {{ initial_media | image_url: width: 1200 | image_tag: loading: 'eager', fetchpriority: 'high', alt: initial_media.alt | escape }}
                  {% when 'video' %}
                  <video 
                    autoplay 
                    muted 
                    loop 
                    playsinline
                    preload="metadata"
                    class="phc-video"
                  >
                    {% for source in initial_media.sources %}
                      {% if source.mime_type contains 'mp4' %}
                        <source src="{{ source.url }}" type="video/mp4">
                      {% endif %}
                    {% endfor %}
                  </video>

                  {% when 'external_video' %}
                    {{ initial_media | external_video_tag }}
                  {% when 'model' %}
                    {{ initial_media | model_viewer_tag }}
                  {% else %}
                    {{ initial_media | image_url: width: 1200 | image_tag: loading: 'lazy', alt: initial_media.alt | escape }}
                {% endcase %}
              </div>
            {% else %}
              <div class="phc-gallery-main-media">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
        </div>
      </div>

        {% if product.media.size > 1 %}
          <div class="phc-gallery-thumbs" data-gallery-thumbs>
            {% for media in product.media %}
              <button
                type="button"
                class="phc-gallery-thumb{% if initial_media and media.id == initial_media.id %} is-active{% endif %}"
                data-media-id="{{ media.id }}"
                aria-label="{{ media.alt | default: product.title | escape }}"
              >
                {% case media.media_type %}
                  {% when 'image' %}
                    {{ media | image_url: width: 200 | image_tag: loading: 'lazy', alt: media.alt | escape }}
                  {% when 'video' %}
                      {{ media | image_url: width: 200 | image_tag: loading: 'lazy', alt: media.alt | escape }}                      
                  {% when 'external_video' %}
                    {{ media | image_url: width: 200 | image_tag: loading: 'lazy', alt: media.alt | escape }}
                  {% when 'model' %}
                    {{ media | image_url: width: 200 | image_tag: loading: 'lazy', alt: media.alt | escape }}
                  {% else %}
                    {{ media | image_url: width: 200 | image_tag: loading: 'lazy', alt: media.alt | escape }}
                {% endcase %}
              </button>
            {% endfor %}
          </div>
        {% endif %}

        {% for media in product.media %}
          <template id="ProductHeroMedia-{{ section.id }}-{{ media.id }}">
            <div
              class="phc-gallery-main-media"
              data-media-type="{{ media.media_type }}"
              data-media-id="{{ media.id }}"
            >
              {% case media.media_type %}
                {% when 'image' %}
                  {{ media | image_url: width: 1400 | image_tag: loading: 'lazy', alt: media.alt | escape }}
                {% when 'video' %}
                  <video 
                    autoplay 
                    muted 
                    loop 
                    playsinline
                    preload="metadata"
                    class="phc-video"
                  >
                    {% for source in media.sources %}
                      {% if source.mime_type contains 'mp4' %}
                        <source src="{{ source.url }}" type="video/mp4">
                      {% endif %}
                    {% endfor %}
                  </video>
                {% when 'external_video' %}
                  {{ media | external_video_tag }}
                {% when 'model' %}
                  {{ media | model_viewer_tag }}
                {% else %}
                  {{ media | image_url: width: 1400 | image_tag: loading: 'lazy', alt: media.alt | escape }}
              {% endcase %}
            </div>
          </template>
        {% endfor %}
      </div>

      <div class="phc-content">
        {% if section.settings.show_badge and section.settings.badge_text != blank %}
          <div class="phc-badge">
            <span class="phc-badge-dot"></span>
            <span>{{ section.settings.badge_text }}</span>
          </div>
        {% endif %}

        <div>
          <h1 class="phc-title">
            {% if section.settings.heading != blank %}
              {{ section.settings.heading }}
            {% else %}
              {{ product.title | escape }}
            {% endif %}
          </h1>

          {% if section.settings.subheading != blank %}
            <div class="phc-subtitle rte">
              {{ section.settings.subheading }}
            </div>
          {% endif %}
        </div>

        <div class="phc-price-row">

          <span class="phc-price-current">
            {{ section.settings.hero_price_special }}
          </span>

          <span class="phc-price-compare">
            {{ section.settings.hero_price_original }}
          </span>

          <span class="phc-price-badge">
            {{ section.settings.hero_discount_label }}
          </span>
        </div>

        {% if section.settings.hero_installments_text != blank %}
          <div class="phc-installments-text">
            <strong> {{ section.settings.hero_installments_text }} </strong>
          </div>
        {% endif %}
        
        {% if section.blocks.size > 0 %}
          <div class="phc-benefits-inline">
            {% for block in section.blocks %}
              {% if block.type == 'hero_benefit_inline' %}
                <div class="phc-benefit-inline" {{ block.shopify_attributes }}>
                  <span class="icon">{{ block.settings.icon }}</span>
                  <span>{{ block.settings.text }}</span>
                </div>
              {% endif %}
            {% endfor %}
          </div>
        {% endif %}

        <p class="phc-variants-label">
          Elegí tu Calmi
        </p>

        <div class="phc-variants" data-variant-picker>
          <fieldset class="phc-variant-option" data-option-index="{{ model_option_position | minus: 1 }}">
            <legend style="display:none;"></legend>
            <div class="phc-variant-option__values">
              {% for value in model_option.values %}
                {% assign is_active = false %}
                {% if value == current_model_value and value != 'Calmi Nutria' %}
                  {% assign is_active = true %}
                {% endif %}

                {%- assign swatch_media = nil -%}
                {%- for v in product.variants -%}
                  {%- case model_option_position -%}
                    {%- when 1 -%}
                      {%- if v.option1 == value -%}
                        {%- assign swatch_media = v.featured_media | default: v.image -%}
                        {%- break -%}
                      {%- endif -%}
                    {%- when 2 -%}
                      {%- if v.option2 == value -%}
                        {%- assign swatch_media = v.featured_media | default: v.image -%}
                        {%- break -%}
                      {%- endif -%}
                    {%- when 3 -%}
                      {%- if v.option3 == value -%}
                        {%- assign swatch_media = v.featured_media | default: v.image -%}
                        {%- break -%}
                      {%- endif -%}
                  {%- endcase -%}
                {%- endfor -%}

                {% assign is_sold_out = false %}
                {% if value == 'Calmi Nutria' %}
                  {% assign is_sold_out = true %}
                {% endif %}

                <button
                  type="button"
                  class="phc-variant-pill
                    {% if is_active %} is-active{% endif %}
                    {% if is_sold_out %} is-sold-out{% endif %}"
                  data-model-pill
                  data-model-name="{{ value | escape }}"
                  {% if is_sold_out %} disabled aria-disabled="true"{% endif %}
                >

                  <span class="phc-variant-pill-thumb">
                    {% if swatch_media %}
                      {{ swatch_media | image_url: width: 80 | image_tag: loading: 'lazy', alt: value }}
                    {% else %}
                      {{ 'image' | placeholder_svg_tag }}
                    {% endif %}
                  </span>
                  <span class="phc-variant-pill-label">{{ value }}</span>

                  {% if is_sold_out %}
                    <span class="phc-variant-badge-soldout">Agotado</span>
                  {% endif %}

                </button>
              {% endfor %}
            </div>
          </fieldset>
        </div>

        {%- assign color_option = nil -%}

        {%- for opt in product.options_with_values -%}
          {%- if opt.name == 'Color' -%}
            {%- assign color_option = opt -%}
          {%- endif -%}
        {%- endfor -%}


        <div class="phc-color-selector-wrapper" data-color-root style="display:none;">
          <p class="phc-variants-label">Elegí el color</p>

          <div class="phc-variant-option__values" data-color-pills>
            {% if color_option %}
              {% for color in color_option.values %}
                <button
                  type="button"
                  class="phc-variant-pill phc-color-pill"
                  data-color-pill
                  data-color-value="{{ color | escape }}"
                >
                  <span class="phc-variant-pill-thumb">
                    <img 
                      src="{{ 'icon-padlock.svg' | asset_url }}"
                      alt="{{ color | escape }}"
                      width="80"
                      height="80"
                      loading="lazy"
                      style="object-fit:cover;"
                    >
                  </span>

                  <span class="phc-variant-pill-label">{{ color | escape }}</span>
                </button>
              {% endfor %}
            {% endif %}


          </div>
        </div>

        {% assign form_id = 'product-hero-form-' | append: section.id %}
        {%- form 'product', product, id: form_id, class: 'phc-form', novalidate: 'novalidate' -%}
          <input type="hidden" name="id" value="{{ current_variant.id }}" data-product-variant-id>

          {% if section.settings.show_quantity_selector %}
            <div class="phc-quantity">
              <span>{{ 'products.product.quantity.label' | t }}</span>
              <div class="phc-quantity-input" data-quantity-wrapper>
                <button type="button" data-quantity-minus aria-label="{{ 'products.product.quantity.decrease' | t }}">-</button>
                <input
                  type="number"
                  name="quantity"
                  min="1"
                  value="1"
                  inputmode="numeric"
                  data-quantity-input
                >
                <button type="button" data-quantity-plus aria-label="{{ 'products.product.quantity.increase' | t }}">+</button>
              </div>
            </div>
          {% endif %}

          <button
            type="submit"
            name="add"
            class="phc-cta-button"
            data-add-to-cart
            {% unless current_variant.available %}disabled{% endunless %}
          >
            <span>
              {% if current_variant.available %}
                {{ section.settings.cta_label | default: 'Quiero mi Calmi ✨' }}
              {% else %}
                {{ 'products.product.sold_out' | t }}
              {% endif %}
            </span>
          </button>

          {% if section.settings.show_cta_subtext and section.settings.cta_subtext != blank %}
            <p class="phc-cta-subtext">
              {{ section.settings.cta_subtext }}
            </p>
          {% endif %}
        {%- endform -%}

        <div class="phc-faq-blocks">
          <div class="phc-faq">
            {% for block in section.blocks %}
              {% if block.type == 'faq' %}
                <div class="phc-faq-item" {{ block.shopify_attributes }}>
                  <button class="phc-faq-question" data-faq-toggle>
                    <span class="phc-faq-icon">
                      {% if block.settings.icon_svg != blank %}
                        {{ block.settings.icon_svg }}
                      {% else %}
                        {{ block.settings.icon }}
                      {% endif %}
                    </span>
                    {{ block.settings.question }}
                    <span class="phc-faq-arrow">⌄</span>
                  </button>

                  <div class="phc-faq-answer">
                    {{ block.settings.answer }}
                  </div>
                </div>
              {% endif %}
            {% endfor %}
          </div>
        </div>

        {% if section.blocks.size > 0 %}
          <ul class="phc-benefits">
            {% for block in section.blocks %}
              {% if block.type == 'benefit' %}
                <li class="phc-benefit" {{ block.shopify_attributes }}>
                  <div class="phc-benefit__icon">
                    {% if block.settings.icon_svg != blank %}
                      {{ block.settings.icon_svg }}
                    {% else %}
                      <svg viewBox="0 0 16 16" aria-hidden="true" focusable="false">
                        <path
                          fill="currentColor"
                          d="M6.5 11.5L3 8l1.4-1.4L6.5 8.7l5.1-5.1L13 5l-6.5 6.5z"
                        />
                      </svg>
                    {% endif %}
                  </div>
                  <div>
                    {% if block.settings.title != blank %}
                      <p class="phc-benefit__title">{{ block.settings.title }}</p>
                    {% endif %}
                    {% if block.settings.text != blank %}
                      <p class="phc-benefit__text">{{ block.settings.text }}</p>
                    {% endif %}
                  </div>
                </li>
              {% endif %}
            {% endfor %}
          </ul>
        {% endif %}

      </div>
    </div>

    <div class="phc-zoom-backdrop" data-zoom-backdrop>
      <button class="phc-zoom-close" type="button" data-zoom-close>✕</button>
      <div class="phc-zoom-inner" data-zoom-inner></div>
    </div>

    <script type="application/json" id="ProductJson-{{ section.id }}">
      {{ product | json }}
    </script>
   
    
    <div class="phc-sticky-cta-mobile" data-sticky-wrapper>
 
      <div class="phc-sticky-offer">
        <span class="phc-sticky-price">
          {{ section.settings.hero_price_special }}
        </span>

        <span class="phc-sticky-compare">
          {{ section.settings.hero_price_original }}
        </span>

        <span class="phc-sticky-badge">
          {{ section.settings.hero_discount_label }}
        </span>

        {% if section.settings.hero_installments_text != blank %}
          <div class="phc-sticky-installments">
            💳 {{ section.settings.hero_installments_text }}
          </div>
        {% endif %}
      </div>

      <button
        type="submit"
        form="{{ form_id }}"
        class="phc-sticky-cta-button"
        data-sticky-cta
      >
        {{ section.settings.cta_label | default: 'Quiero mi Calmi ✨' }}
      </button>

      <input type="hidden" name="id" data-sticky-variant-id>

    </div>

    {%- comment -%} Sticky CTA DESKTOP {%- endcomment -%}
    <div class="phc-sticky-cta-desktop" data-sticky-desktop-wrapper>
      <div class="phc-sticky-desktop-inner">
        <div class="phc-sticky-offer">
          <span class="phc-sticky-price">
            {{ section.settings.hero_price_special }}
          </span>

          <span class="phc-sticky-compare">
            {{ section.settings.hero_price_original }}
          </span>

          <span class="phc-sticky-badge">
            {{ section.settings.hero_discount_label }}
          </span>

          {% if section.settings.hero_installments_text != blank %}
            <div class="phc-sticky-installments">
              <strong>💳 {{ section.settings.hero_installments_text }} </strong>
            </div>
          {% endif %}
        </div>

        <button
          type="submit"
          form="{{ form_id }}"
          class="phc-sticky-desktop-button"
          data-sticky-desktop-cta
        >
          {{ section.settings.cta_label | default: 'Quiero mi Calmi ✨' }}
        </button>

        <input type="hidden" name="id" data-sticky-variant-id>

      </div>
    </div>


    <script>
    (function() {
      const section = document.querySelector('.product-hero-calmi-{{ section.id }}[data-product-hero-calmi]');
      if (!section) return;

      const productJsonEl = document.getElementById('ProductJson-{{ section.id }}');
      if (!productJsonEl) return;

      let productData;
      try { productData = JSON.parse(productJsonEl.textContent || productJsonEl.innerText); }
      catch (e) { console.error('Error parsing product JSON', e); return; }

      const moneyFormat = {{ shop.money_format | json }};
      const defaultCtaLabel = {{ section.settings.cta_label | default: 'Quiero mi Calmi ✨' | json }};
      const soldOutLabel = {{ 'products.product.sold_out' | t | json }};

      function money(amount) {
        try {
          if (window.Shopify && typeof Shopify.formatMoney === "function") {
            return Shopify.formatMoney(amount, moneyFormat);
          }
        } catch (e) {}

        // Fallback seguro para cuando Shopify.formatMoney NO existe
        const number = amount / 100;
        return number.toLocaleString('es-AR', {
          style: 'currency',
          currency: 'ARS'
        });
      }

      function findCorrectVariant(model, color = null) {
        return productData.variants.find(v => {
          const isSingle = String(v.options[0]).toLowerCase() === 'single';
          const isModel = v.options[1] === model;
          const isColor = color ? v.options[2] === color : true;

          return isSingle && isModel && isColor;
        }) || null;
      }


    const modelOptionIndex = 1;

    const initialVariantId = section.getAttribute('data-initial-variant-id');
    let currentVariant = productData.variants.find(v => v.id == initialVariantId) || productData.variants[0];
    let selectedModel = currentVariant.options[modelOptionIndex];

    const form = section.querySelector('form.phc-form');
    const variantIdInput = form?.querySelector('[data-product-variant-id]');
    const addToCartBtn = form?.querySelector('[data-add-to-cart]');

    const modelButtons = section.querySelectorAll('[data-model-pill]');
    const colorRoot = section.querySelector('[data-color-root]');
    const colorPills = section.querySelectorAll('[data-color-pill]');

    const galleryMainInner = section.querySelector('[data-gallery-main-inner]');

    /** ===========================================================
    *  UPDATE VARIANT — SIEMPRE ACTUALIZA:
    *  - input hidden
    *  - sticky CTA (desktop & mobile)
    *  - botón del formulario
    *  - galería
    ============================================================= */
    function updateVariant(variant) {
      if (!variant) return;

      currentVariant = variant;

      // update main hidden input
      if (variantIdInput) variantIdInput.value = variant.id;

      // update hidden inputs in all CTAs
      document.querySelectorAll('[data-product-variant-id], [data-sticky-variant-id]')
        .forEach(input => input.value = variant.id);


      // update CTA button
      if (addToCartBtn) {
        const span = addToCartBtn.querySelector('span');
        if (variant.available) {
          addToCartBtn.disabled = false;
          span.textContent = defaultCtaLabel;
        } else {
          addToCartBtn.disabled = true;
          span.textContent = soldOutLabel;
        }
      }

      updateGalleryMedia(variant);
    }

    /** ===========================================================
    *  GALERÍA — Update foto al cambiar variante
    ============================================================= */
    function updateGalleryMedia(variant) {
      if (!variant || !variant.featured_media) return;

      const mediaId = variant.featured_media.id;
      const template = document.getElementById(`ProductHeroMedia-{{ section.id }}-${mediaId}`);
      if (!template) return;

      const clone = template.content.cloneNode(true);

      const oldMedia = galleryMainInner.querySelector('.phc-gallery-main-media');
      if (oldMedia) oldMedia.classList.add('is-fading-out');

      setTimeout(() => {
        galleryMainInner.innerHTML = '';

        const newMedia = clone.querySelector('.phc-gallery-main-media');
        newMedia.classList.add('is-fading-in');
        galleryMainInner.appendChild(newMedia);

        setTimeout(() => newMedia.classList.remove('is-fading-in'), 350);
      }, 200);
    }

    /** ===========================================================
    *  MODEL SELECTOR (Capibara / Elefante / Nutria disabled)
    ============================================================= */
    modelButtons.forEach(btn => {
      const modelName = btn.dataset.modelName;

      if (modelName === selectedModel) btn.classList.add('is-active');

      btn.addEventListener('click', () => {
        if (btn.classList.contains('is-sold-out')) return;

        selectedModel = modelName;
        const selectedColor =
          document.querySelector('.phc-color-pill.is-active')?.dataset.colorValue || null;

        modelButtons.forEach(b => b.classList.remove('is-active'));
        btn.classList.add('is-active');

        const newVariant = findCorrectVariant(selectedModel, selectedColor);
        updateVariant(newVariant);

        showOrHideColorSelector();

        if (selectedModel !== 'Calmi Capibara') {
          updateColorPillsActive(null);
        }

        updateColorPillImages();
      });
    });

    
    function showOrHideColorSelector() {
      const allowedColors = {
        "Calmi Capibara": ["Marrón", "Rosa", "Blanco"],
        "Calmi Osito": ["Marrón", "Verde", "Celeste", "Rosa", "Azul"]
      };

      // Si el modelo no tiene colores → ocultar por completo
      if (!allowedColors[selectedModel]) {
        colorRoot.style.display = "none";
        updateColorPillsActive(null);
        return;
      }

      // Mostrar selector
      colorRoot.style.display = "block";

      colorPills.forEach(pill => {
        const color = pill.dataset.colorValue;

        // Mostrar solo colores válidos
        if (allowedColors[selectedModel].includes(color)) {
          pill.style.display = "inline-flex";
          pill.disabled = false;
          pill.classList.remove("is-disabled");
        } else {
          pill.style.display = "none";
          pill.disabled = true;
        }
      });

    }


    function updateColorPillsActive(colorValue) {
      colorPills.forEach(p => {
        p.classList.toggle('is-active', p.dataset.colorValue === colorValue);
      });
    }

    colorPills.forEach(btn => {
      btn.addEventListener('click', () => {
        const color = btn.dataset.colorValue;
        if (!color) return;

        updateColorPillsActive(color);

        // Ahora usa el modelo ACTUAL seleccionado
        const variant = findCorrectVariant(selectedModel, color);
        updateVariant(variant);

        updateColorPillImages();
      });
    });

    function updateColorPillImages() {
      colorPills.forEach(pill => {
        const color = pill.dataset.colorValue;

        const variantForImage = productData.variants.find(v =>
          v.options[1] === selectedModel &&
          v.options[2] === color &&
          v.featured_media
        );

        const img = pill.querySelector('img');
        if (variantForImage && img) {
          img.src = variantForImage.featured_media.preview_image.src;
        }
      });
    }


    showOrHideColorSelector();

    /** ===========================================================
    *  INIT
    ============================================================= */
    if (currentVariant) updateVariant(currentVariant);


    // 🔥 NUEVO: cargar imágenes correctas en color pills APENAS CARGA LA PÁGINA
    updateColorPillImages();
    /* -------------------------
      THUMBNAIL CLICK HANDLER
      ------------------------- */
    const thumbsContainer = section.querySelector('[data-gallery-thumbs]');
    if (thumbsContainer) {
      thumbsContainer.querySelectorAll('[data-media-id]').forEach(thumb => {
        thumb.addEventListener('click', () => {
          const mediaId = thumb.getAttribute('data-media-id');
          if (!mediaId) return;

          const template = document.getElementById(`ProductHeroMedia-{{ section.id }}-${mediaId}`);
          if (!template) return;

          const clone = template.content.cloneNode(true);

          const oldMedia = galleryMainInner.querySelector('.phc-gallery-main-media');
          if (oldMedia) oldMedia.classList.add('is-fading-out');

          setTimeout(() => {
            galleryMainInner.innerHTML = '';

            const newMedia = clone.querySelector('.phc-gallery-main-media');
            newMedia.classList.add('is-fading-in');
            galleryMainInner.appendChild(newMedia);

            setTimeout(() => newMedia.classList.remove('is-fading-in'), 350);

            // Actualizar estado visual de thumbnails
            thumbsContainer.querySelectorAll('[data-media-id]')
              .forEach(t => t.classList.remove('is-active'));

            thumb.classList.add('is-active');
          }, 150);
        });
      });
    }
      
      /* -------------------------
        FAQ ACCORDION — FIX FINAL
      ------------------------- */
      (function(){
        const section = document.querySelector('.product-hero-calmi-{{ section.id }}[data-product-hero-calmi]');
        if (!section) return;

        const faqToggles = section.querySelectorAll('[data-faq-toggle]');
        if (!faqToggles.length) return;

        faqToggles.forEach(btn => {
          btn.addEventListener('click', () => {
            const answer = btn.nextElementSibling;
            const isOpen = answer.classList.contains('is-open');

            // cerrar todos
            section.querySelectorAll('.phc-faq-answer').forEach(a => a.classList.remove('is-open'));
            section.querySelectorAll('.phc-faq-question').forEach(q => q.classList.remove('is-open'));

            // reabrir si estaba cerrado
            if (!isOpen) {
              answer.classList.add('is-open');
              btn.classList.add('is-open');
            }
          });
        });
      })();

      
    })();
    
    (function() {
      const stickyWrapper = document.querySelector('.phc-sticky-cta-mobile');
      const heroSection = document.querySelector('#product-hero-calmi-{{ section.id }}');

      if (!stickyWrapper || !heroSection) return;

      // Solo en mobile
      if (!window.matchMedia("(max-width: 749px)").matches) return;

      const observer = new IntersectionObserver(
        entries => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              // El HERO está visible → NO mostrar el sticky
              stickyWrapper.classList.remove('is-visible');
            } else {
              // El HERO salió de pantalla → mostrar sticky
              stickyWrapper.classList.add('is-visible');
            }
          });
        },
        {
          threshold: 0.05, // detecta cuando el hero está casi fuera
          rootMargin: "-20% 0px 0px 0px" 
          // opcional: hace que aparezca una vez que pasó un poco más
        }
      );

      observer.observe(heroSection);
    })();

    (function() {
      const stickyWrapper = document.querySelector('.phc-sticky-cta-desktop');
      const heroSection = document.querySelector('#product-hero-calmi-{{ section.id }}');

      if (!stickyWrapper || !heroSection) return;

      // Solo en desktop
      if (!window.matchMedia('(min-width: 750px)').matches) return;

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              // El HERO está visible → NO mostramos sticky
              stickyWrapper.classList.remove('is-visible');
            } else {
              // El HERO salió de pantalla → mostramos sticky desktop
              stickyWrapper.classList.add('is-visible');
            }
          });
        },
        {
          threshold: 0.05,
          rootMargin: '-20% 0px 0px 0px'
        }
      );

      observer.observe(heroSection);
    })();

    </script>


  </section>
{% endif %}

