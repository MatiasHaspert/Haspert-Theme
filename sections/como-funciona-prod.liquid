{% style %}

/* ============================
   🎨 SISTEMA DE COLORES
   ============================ */

.calmi-how-works-{{ section.id }} {
  --how-bg: {{ section.settings.bg_color }};
  --how-title: {{ section.settings.title_color }};
  --how-subtitle: {{ section.settings.subtitle_color }};
  --how-card-bg: {{ section.settings.card_bg }};
  --how-card-title: {{ section.settings.card_title_color }};
  --how-card-text: {{ section.settings.card_text_color }};
  --how-shadow: 0 5px 20px rgba(0,0,0,0.06);
  --how-shadow-hover: 0 10px 26px rgba(0,0,0,0.08);
}

/* ============================
   CONTENEDOR GENERAL
   ============================ */

.calmi-how-works {
  padding: 60px 0;
  background: var(--how-bg);
}

.calmi-how-works__inner {
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 20px;
  text-align: center;
}

/* ============================
   HEADING
   ============================ */

.calmi-how-works__heading {
  margin-bottom: 40px;
}

.calmi-how-works__title {
  font-size: 2.4rem;
  font-weight: 700;
  margin-bottom: 10px;
  color: var(--how-title);
}

.calmi-how-works__subtitle {
  font-size: 1.45rem;
  max-width: 640px;
  margin: 0 auto;
  color: var(--how-subtitle);
}

/* ============================
   GRID
   ============================ */

.calmi-how-works__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 34px;
}

/* ============================
   STEP CARD
   ============================ */

.calmi-how-works__step {
  background: var(--how-card-bg);
  padding: 24px;
  border-radius: 14px;
  box-shadow: var(--how-shadow);
  transition: 0.3s ease;
}

.calmi-how-works__step:hover {
  transform: translateY(-4px);
  box-shadow: var(--how-shadow-hover);
}

/* ============================
   MEDIA
   ============================ */

.calmi-how-works__media {
  margin-bottom: 14px;
}

.calmi-how-works__media img,
.calmi-how-works__media video {
  width: 100%;
  border-radius: 12px;
  object-fit: cover;
  display: block;
}

/* ============================
   TEXTOS DE CADA PASO
   ============================ */

.calmi-how-works__step-title {
  font-size: 1.4rem;
  font-weight: 700;
  margin-bottom: 8px;
  color: var(--how-card-title);
}

.calmi-how-works__step-text {
  font-size: 1.25rem;
  color: var(--how-card-text);
  line-height: 1.45;
}

/* ============================
   RESPONSIVE
   ============================ */

@media (max-width: 749px) {
  .calmi-how-works__grid {
    grid-template-columns: 1fr;
    gap: 24px;
  }

  .calmi-how-works__title {
    font-size: 2rem;
  }

  .calmi-how-works__step {
    padding: 20px;
  }
}

{% endstyle %}


<section class="calmi-how-works calmi-how-works-{{ section.id }}">
  <div class="calmi-how-works__inner">

    <!-- Título principal -->
    <div class="calmi-how-works__heading">
      <h2 class="calmi-how-works__title">
        {{ section.settings.title }}
      </h2>
      <p class="calmi-how-works__subtitle">
        {{ section.settings.subtitle }}
      </p>
    </div>

    <!-- Grid de pasos -->
    <div class="calmi-how-works__grid">

      {% for block in section.blocks %}
      <div class="calmi-how-works__step" {{ block.shopify_attributes }}>

        <div class="calmi-how-works__media">

          {% if block.settings.video %}
            {{ block.settings.video | video_tag:
                autoplay: true,
                loop: true,
                controls: false,
                muted: true,
                playsinline: true
            }}

          
          {% elsif block.settings.image %}
            {% assign img_w = block.settings.image.width | default: 800 %}
            {% assign img_h = block.settings.image.height | default: 800 %}
            {{ block.settings.image 
               | image_url: width: 1200 
               | image_tag: 
                  width: img_w,
                  height: img_h,
                  alt: block.settings.title,
                  class: "calmi-how-works__image",
                  loading: "lazy"
            }}
          {% endif %}

        </div>

        <!-- Texto -->
        <h3 class="calmi-how-works__step-title">{{ block.settings.title }}</h3>
        <p class="calmi-how-works__step-text">{{ block.settings.text }}</p>

      </div>
      {% endfor %}

    </div>
  </div>
</section>


{% schema %}
{
  "name": "Cómo funciona - Plant Prd",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "Cómo funciona Calmi"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtítulo",
      "default": "Un mecanismo natural que imita la respiración y los latidos humanos para generar calma en segundos."
    },
    {
      "type": "header",
      "content": "🎨 Colores personalizados"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Color de fondo",
      "default": "#F7F7F7"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Color del título",
      "default": "#222222"
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Color del subtítulo",
      "default": "#4B5563"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Color de la tarjeta",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "card_title_color",
      "label": "Color del título del paso",
      "default": "#222222"
    },
    {
      "type": "color",
      "id": "card_text_color",
      "label": "Color del texto del paso",
      "default": "rgba(0,0,0,0.7)"
    }

  ],
  "blocks": [
    {
      "type": "step",
      "name": "Paso",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagen del paso"
        },
        {
          "type": "video",
          "id": "video",
          "label": "Video del paso (opcional)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Título del paso",
          "default": "Encendé"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Descripción",
          "default": "Activa la respiración real y los latidos suaves."
        }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [
    {
      "name": "Cómo funciona Calmi",
      "blocks": [
        { "type": "step" },
        { "type": "step" },
        { "type": "step" }
      ]
    }
  ]
}
{% endschema %}
