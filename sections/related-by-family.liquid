{%- comment -%}
  Cross-sell por familia olfativa (AOV / descubrimiento).
  Recomienda otros perfumes que comparten al menos una familia (metafield lista custom.familia_olfativa)
  con el producto actual. Reusa el snippet card-product y las clases de grilla de la base (sin CSS nuevo de card).
  Precios desde Shopify. Todo editable por theme editor. Si no hay match, fallback opcional a la colección.
{%- endcomment -%}

{%- liquid
  assign limit = section.settings.products_to_show

  # Colección donde buscar candidatos: la elegida en settings, o la 1ª del producto como fallback.
  assign coll = section.settings.collection
  if coll == blank
    assign coll = product.collections.first
  endif

  assign cur_families = product.metafields.custom.familia_olfativa.value
  assign cur_family_label = cur_families | first
  assign matched_by_family = false

  # Dorado de marca con contraste AA: oscurece sólo sobre fondos claros.
  assign accent = section.settings.accent_color
  assign scheme_bg = section.settings.color_scheme.settings.background
  assign bg_bright = scheme_bg | color_brightness
  assign accent_ink = accent
  if scheme_bg == blank or bg_bright > 140
    assign accent_ink = accent | color_darken: 22
  endif
-%}

{%- liquid
  assign shown = 0
  assign skip_card_styles = false
-%}

{%- comment -%} Pase 1: match por familia olfativa compartida. {%- endcomment -%}
{%- capture card_items -%}
  {%- if product != blank and coll != blank and cur_families != blank -%}
    {%- for candidate in coll.products -%}
      {%- if shown >= limit -%}{%- break -%}{%- endif -%}
      {%- if candidate.id == product.id -%}{%- continue -%}{%- endif -%}
      {%- assign cand_families = candidate.metafields.custom.familia_olfativa.value -%}
      {%- assign is_match = false -%}
      {%- if cand_families != blank -%}
        {%- for cf in cand_families -%}
          {%- if cur_families contains cf -%}{%- assign is_match = true -%}{%- break -%}{%- endif -%}
        {%- endfor -%}
      {%- endif -%}
      {%- if is_match -%}
        <li class="grid__item">
          {%- render 'card-product',
            card_product: candidate,
            media_aspect_ratio: section.settings.image_ratio,
            image_shape: section.settings.image_shape,
            show_secondary_image: section.settings.show_secondary_image,
            show_vendor: section.settings.show_vendor,
            show_rating: section.settings.show_rating,
            lazy_load: true,
            skip_styles: skip_card_styles,
            quick_add: section.settings.quick_add,
            section_id: section.id
          -%}
        </li>
        {%- assign shown = shown | plus: 1 -%}
        {%- assign skip_card_styles = true -%}
      {%- endif -%}
    {%- endfor -%}
  {%- endif -%}
{%- endcapture -%}

{%- if shown > 0 -%}
  {%- assign matched_by_family = true -%}
{%- endif -%}

{%- comment -%} Pase 2 (fallback): otros productos de la colección, sin filtrar por familia. {%- endcomment -%}
{%- if shown == 0 and section.settings.enable_fallback and product != blank and coll != blank -%}
  {%- liquid
    assign shown = 0
    assign skip_card_styles = false
  -%}
  {%- capture card_items -%}
    {%- for candidate in coll.products -%}
      {%- if shown >= limit -%}{%- break -%}{%- endif -%}
      {%- if candidate.id == product.id -%}{%- continue -%}{%- endif -%}
      <li class="grid__item">
        {%- render 'card-product',
          card_product: candidate,
          media_aspect_ratio: section.settings.image_ratio,
          image_shape: section.settings.image_shape,
          show_secondary_image: section.settings.show_secondary_image,
          show_vendor: section.settings.show_vendor,
          show_rating: section.settings.show_rating,
          lazy_load: true,
          skip_styles: skip_card_styles
        -%}
      </li>
      {%- assign shown = shown | plus: 1 -%}
      {%- assign skip_card_styles = true -%}
    {%- endfor -%}
  {%- endcapture -%}
{%- endif -%}

{%- if shown > 0 -%}
  {{ 'component-card.css' | asset_url | stylesheet_tag }}
  {{ 'component-price.css' | asset_url | stylesheet_tag }}
  {{ 'section-related-products.css' | asset_url | stylesheet_tag }}
  {%- if section.settings.quick_add != 'none' -%}
    {{ 'quick-add.css' | asset_url | stylesheet_tag }}
    <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
  {%- endif -%}
  {%- if section.settings.quick_add == 'standard' -%}
    <script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>
  {%- endif -%}
  <div class="color-{{ section.settings.color_scheme }} gradient">
    <div class="rbf page-width section-{{ section.id }}-padding isolate{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      <div class="rbf__head">
        {%- if section.settings.heading != blank -%}
          <h2 class="rbf__heading inline-richtext {{ section.settings.heading_size }}">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.show_family_label and matched_by_family and cur_family_label != blank -%}
          <span class="rbf__family">{{ cur_family_label }}</span>
        {%- endif -%}
      </div>
      <ul
        class="grid product-grid grid--{{ section.settings.columns_desktop }}-col-desktop grid--{{ section.settings.columns_mobile }}-col-tablet-down"
        role="list"
      >
        {{ card_items }}
      </ul>
    </div>
  </div>
{%- elsif request.design_mode -%}
  {%- comment -%} Sólo en el editor: ayuda al merchant a configurar. No se renderiza en la tienda. {%- endcomment -%}
  <div class="color-{{ section.settings.color_scheme }} gradient">
    <div class="rbf page-width section-{{ section.id }}-padding">
      <p class="rbf__onboarding">{{ section.settings.onboarding_text }}</p>
    </div>
  </div>
{%- endif -%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  #shopify-section-{{ section.id }} {
    --rbf-accent: {{ section.settings.accent_color }};
    --rbf-accent-ink: {{ accent_ink }};
  }
{%- endstyle -%}

{% stylesheet %}
.rbf__head {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 1rem;
  margin: 0 0 2rem;
}
.rbf__heading { margin: 0; }
.rbf__family {
  display: inline-flex;
  align-items: center;
  font-size: 1.2rem;
  letter-spacing: 0.06rem;
  text-transform: uppercase;
  padding: 0.4rem 1rem;
  border: 0.1rem solid var(--rbf-accent-ink);
  color: var(--rbf-accent-ink);
  border-radius: var(--badge-corner-radius, 0.2rem);
}
.rbf__onboarding { text-align: center; opacity: 0.7; margin: 0; }
{% endstylesheet %}

{% schema %}
{
  "name": "Cross-sell por familia",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Esquema de color", "info": "Las cards usan su propio esquema en Configuración del tema → Tarjetas.", "default": "scheme-1" },
    { "type": "color", "id": "accent_color", "label": "Color de acento", "default": "#C2A24C" },
    { "type": "inline_richtext", "id": "heading", "label": "Título", "default": "Te puede gustar" },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Tamaño del título",
      "options": [
        { "value": "h2", "label": "Chico" },
        { "value": "h1", "label": "Mediano" },
        { "value": "h0", "label": "Grande" }
      ],
      "default": "h1"
    },
    { "type": "checkbox", "id": "show_family_label", "label": "Mostrar chip con la familia olfativa", "default": true },
    { "type": "header", "content": "Fuente de productos" },
    { "type": "collection", "id": "collection", "label": "Colección donde buscar", "info": "Si la dejás vacía, busca en la primera colección del producto. Tip: apuntá a un catálogo de perfumes para mejores cruces." },
    { "type": "range", "id": "products_to_show", "min": 2, "max": 10, "step": 1, "label": "Productos a mostrar", "default": 4 },
    { "type": "checkbox", "id": "enable_fallback", "label": "Si no hay match por familia, mostrar otros de la colección", "info": "Evita que la sección quede vacía mientras cargás los metafields del catálogo.", "default": true },
    { "type": "text", "id": "onboarding_text", "label": "Texto de ayuda (sólo en el editor)", "default": "Sin coincidencias todavía: cargá el metafield \"Familia olfativa\" en los productos o elegí una colección con perfumes." },
    { "type": "header", "content": "Grilla" },
    { "type": "range", "id": "columns_desktop", "min": 1, "max": 6, "step": 1, "label": "Columnas en desktop", "default": 4 },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columnas en mobile",
      "options": [
        { "value": "1", "label": "1 columna" },
        { "value": "2", "label": "2 columnas" }
      ],
      "default": "2"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Relación de imagen",
      "options": [
        { "value": "adapt", "label": "Adaptar a la imagen" },
        { "value": "portrait", "label": "Retrato" },
        { "value": "square", "label": "Cuadrada" }
      ],
      "default": "adapt"
    },
    { "type": "select", "id": "image_shape", "label": "Forma de imagen", "options": [
      { "value": "default", "label": "Por defecto" },
      { "value": "arch", "label": "Arco" },
      { "value": "round", "label": "Redonda" }
    ], "default": "default" },
    { "type": "checkbox", "id": "show_secondary_image", "label": "Mostrar segunda imagen al pasar el mouse", "default": false },
    { "type": "checkbox", "id": "show_vendor", "label": "Mostrar marca (vendor)", "default": false },
    { "type": "checkbox", "id": "show_rating", "label": "Mostrar rating", "default": false },
    {
      "type": "select",
      "id": "quick_add",
      "label": "Botón de compra rápida",
      "info": "\"Compra rápida\" agrega directo si el perfume tiene 1 variante, o abre un modal para elegir presentación (frasco/decant/tester) sin entrar a la PDP.",
      "options": [
        { "value": "none", "label": "No mostrar" },
        { "value": "standard", "label": "Compra rápida" }
      ],
      "default": "standard"
    },
    { "type": "header", "content": "Espaciado" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding superior", "default": 36 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding inferior", "default": 36 }
  ],
  "presets": [
    { "name": "Cross-sell por familia" }
  ],
  "enabled_on": {
    "templates": ["product"]
  }
}
{% endschema %}
