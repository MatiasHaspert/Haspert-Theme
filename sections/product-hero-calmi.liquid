{% comment %}
  Sección: Calmi - HERO principal de producto con Pack 2x (versión A)
  Archivo: /sections/product-hero-calmi.liquid

  - Hero principal para plantillas de producto.
  - Layout 2 columnas: galería izquierda, contenido derecha.
  - Precio + compare_at + badge de descuento dinámico.
  - Selector de modelo (Nutria / Capibara / Elefante, etc.) usando variantes SINGLE.
  - Botón de compra usando product-form nativo (solo Single).
  - Módulo Pack 2x: elegís 2 modelos libres, con 50% OFF en la segunda unidad.
    * NO depende de variantes "Pack 2x" → arma el pack usando variantes SINGLE.
  - Beneficios rápidos configurables vía blocks.
{% endcomment %}

{% if product == blank %}
  <div class="product-hero-calmi-placeholder">
    <p>Esta sección debe usarse en una plantilla de producto.</p>
  </div>
{% else %}
  {%- assign current_variant = product.selected_or_first_available_variant -%}

  {%- assign model_option = product.options_with_values[0] -%}
  {%- assign model_option_position = model_option.position -%}
  {%- for opt in product.options_with_values -%}
    {%- if opt.name == 'Tipo Peluche' -%}
      {%- assign model_option = opt -%}
      {%- assign model_option_position = opt.position -%}
    {%- endif -%}
  {%- endfor -%}

  {%- case model_option_position -%}
    {%- when 1 -%}
      {%- assign current_model_value = current_variant.option1 -%}
    {%- when 2 -%}
      {%- assign current_model_value = current_variant.option2 -%}
    {%- when 3 -%}
      {%- assign current_model_value = current_variant.option3 -%}
    {%- else -%}
      {%- assign current_model_value = model_option.values[0] -%}
  {%- endcase -%}

  {%- assign initial_media = current_variant.featured_media | default: product.featured_media -%}

  {% style %}
    .product-hero-calmi {
      padding: 2.5rem 1.5rem;
    }

    .product-hero-calmi__inner {
      max-width: 1200px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: minmax(0, 1.1fr) minmax(0, 1fr);
      gap: 2.5rem;
      align-items: flex-start;
    }

    @media (max-width: 749px) {
      .product-hero-calmi {
        padding: 1.75rem 1.25rem 2.25rem;
      }

      .product-hero-calmi__inner {
        grid-template-columns: 1fr;
        gap: 1.75rem;
      }
    }

    .phc-gallery {
      display: flex;
      flex-direction: column;
      gap: 0.85rem;
    }

    .phc-gallery-main {
      position: relative;
      border-radius: 1.25rem;
      overflow: hidden;
      background: #f4f4f5;
      aspect-ratio: 4 / 5;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: default;
    }

    .phc-gallery-main--clickable {
      cursor: zoom-in;
    }

    .phc-gallery-main img,
    .phc-gallery-main video,
    .phc-gallery-main model-viewer {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .phc-gallery-thumbs {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .phc-gallery-thumb {
      border-radius: 0.75rem;
      overflow: hidden;
      border: 1px solid rgba(0,0,0,0.04);
      background: #fff;
      padding: 0;
      cursor: pointer;
      flex: 0 0 auto;
      width: 64px;
      height: 64px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .phc-gallery-thumb img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .phc-gallery-thumb.is-active {
      outline: 2px solid #111827;
      outline-offset: 0;
      border-color: transparent;
    }

    .phc-content {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .phc-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      font-size: 0.8rem;
      font-weight: 600;
      padding: 0.35rem 0.65rem;
      border-radius: 999px;
      background: rgba(34,197,94,0.08);
      color: #15803d;
      margin-bottom: 0.35rem;
    }

    .phc-badge-dot {
      width: 7px;
      height: 7px;
      border-radius: 999px;
      background: #22c55e;
      box-shadow: 0 0 0 4px rgba(34,197,94,0.2);
    }

    .phc-title {
      font-size: clamp(1.9rem, 2.15rem + 0.4vw, 2.4rem);
      line-height: 1.1;
      letter-spacing: -0.03em;
      margin: 0 0 0.35rem;
    }

    .phc-subtitle {
      font-size: 0.98rem;
      line-height: 1.6;
      opacity: 0.88;
      margin-bottom: 0.4rem;
    }

    .phc-rating-row {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      font-size: 0.85rem;
      color: #4b5563;
      margin-bottom: 0.4rem;
    }

    .phc-rating-stars {
      display: inline-flex;
      gap: 2px;
      color: #facc15;
    }

    .phc-rating-star {
      width: 16px;
      height: 16px;
    }

    .phc-price-row {
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      gap: 0.4rem;
      margin: 0.4rem 0 0.6rem;
    }

    .phc-price-current {
      font-size: 1.6rem;
      font-weight: 800;
      color: #f97316;
    }

    .phc-price-compare {
      font-size: 0.95rem;
      opacity: 0.6;
      text-decoration: line-through;
    }

    .phc-price-badge {
      font-size: 0.78rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      padding: 0.25rem 0.55rem;
      border-radius: 999px;
      background: rgba(249,115,22,0.12);
      color: #c2410c;
    }

    .phc-price-badge--hidden {
      display: none;
    }

    .phc-variants-label {
      font-size: 0.9rem;
      font-weight: 600;
      margin: 0 0 0.4rem;
      opacity: 0.8;
    }

    .phc-variants {
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
      margin-bottom: 0.7rem;
    }

    .phc-variant-option__values {
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem;
    }

    .phc-variant-pill {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      padding: 0.3rem 0.45rem 0.3rem 0.3rem;
      border-radius: 999px;
      border: 1px solid rgba(0,0,0,0.08);
      background: #fff;
      cursor: pointer;
      font-size: 0.85rem;
      transition: box-shadow 0.18s ease, border-color 0.18s ease, transform 0.1s ease, background 0.18s ease;
    }

    .phc-variant-pill-thumb {
      width: 32px;
      height: 32px;
      border-radius: 999px;
      overflow: hidden;
      background: #f4f4f5;
      flex-shrink: 0;
    }

    .phc-variant-pill-thumb img,
    .phc-variant-pill-thumb svg {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .phc-variant-pill-label {
      white-space: nowrap;
    }

    .phc-variant-pill.is-active {
      border-color: #111827;
      box-shadow: 0 0 0 1px #111827;
      background: #f9fafb;
      transform: translateY(-1px);
    }

    .phc-form {
      display: flex;
      flex-direction: column;
      gap: 0.6rem;
      margin-top: 0.3rem;
    }

    .phc-quantity {
      display: flex;
      align-items: center;
      justify-content: space-between;
      font-size: 0.9rem;
      gap: 0.6rem;
    }

    .phc-quantity-input {
      display: inline-flex;
      align-items: center;
      border-radius: 999px;
      border: 1px solid rgba(0,0,0,0.08);
      overflow: hidden;
      background: #fff;
    }

    .phc-quantity-input button {
      border: none;
      background: transparent;
      width: 32px;
      height: 32px;
      font-size: 1.1rem;
      cursor: pointer;
    }

    .phc-quantity-input input {
      width: 42px;
      text-align: center;
      border: none;
      outline: none;
      font-size: 0.95rem;
    }

    .phc-cta-button {
      width: 100%;
      border-radius: 999px;
      padding: 0.9rem 1.2rem;
      border: none;
      background: linear-gradient(135deg, #fb923c, #f97316);
      color: #fff;
      font-weight: 700;
      font-size: 1rem;
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.4rem;
      box-shadow: 0 14px 30px rgba(249,115,22,0.35);
      transition: transform 0.12s ease, box-shadow 0.12s ease, opacity 0.12s ease;
    }

    .phc-cta-button:hover:not([disabled]) {
      transform: translateY(-1px);
      box-shadow: 0 18px 36px rgba(249,115,22,0.4);
    }

    .phc-cta-button:disabled {
      opacity: 0.6;
      cursor: not-allowed;
      box-shadow: none;
    }

    .phc-cta-subtext {
      font-size: 0.82rem;
      color: #4b5563;
      margin: 0;
      text-align: center;
    }

    .phc-benefits {
      list-style: none;
      padding: 0;
      margin: 0.75rem 0 0;
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 0.6rem 1rem;
    }

    @media (max-width: 749px) {
      .phc-benefits {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    .phc-benefit {
      display: flex;
      align-items: flex-start;
      gap: 0.45rem;
      font-size: 0.78rem;
    }

    .phc-benefit__icon {
      width: 20px;
      height: 20px;
      border-radius: 999px;
      background: #ecfdf5;
      color: #16a34a;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .phc-benefit__title {
      font-weight: 600;
      margin: 0 0 0.05rem;
    }

    .phc-benefit__text {
      margin: 0;
      opacity: 0.8;
    }

    .phc-pack {
      margin-top: 1rem;
      padding: 0.85rem 0.9rem 0.9rem;
      border-radius: 1rem;
      border: 1px solid rgba(249,115,22,0.25);
      background: linear-gradient(135deg, rgba(254,243,199,0.45), rgba(255,247,237,0.85));
      display: flex;
      flex-direction: column;
      gap: 0.65rem;
    }

    .phc-pack-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 0.75rem;
    }

    .phc-pack-title {
      font-size: 0.95rem;
      font-weight: 700;
      margin-bottom: 0.1rem;
    }

    .phc-pack-tag {
      font-size: 0.75rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      padding: 0.25rem 0.6rem;
      border-radius: 999px;
      background: #db2777;
      color: #fff;
      white-space: nowrap;
    }

    .phc-pack-body {
      display: flex;
      flex-direction: column;
      gap: 0.55rem;
    }

    .phc-pack-pickers {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.4rem;
    }

    @media (max-width: 749px) {
      .phc-pack-pickers {
        grid-template-columns: 1fr;
      }
    }

    .phc-pack-picker-label {
      font-size: 0.78rem;
      font-weight: 600;
      margin-bottom: 0.25rem;
      opacity: 0.9;
    }

    .phc-pack-options {
      display: flex;
      flex-wrap: wrap;
      gap: 0.3rem;
    }

    .phc-pack-summary {
      border-radius: 0.75rem;
      background: rgba(255,255,255,0.8);
      padding: 0.45rem 0.55rem;
      display: flex;
      flex-direction: column;
      gap: 0.15rem;
      font-size: 0.85rem;
    }

    .phc-pack-summary-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 0.4rem;
    }

    .phc-pack-total-label {
      font-weight: 600;
    }

    .phc-pack-total-value {
      font-weight: 700;
      color: #b45309;
    }

    .phc-pack-savings-pill {
      display: inline-flex;
      align-items: center;
      padding: 0.2rem 0.45rem;
      border-radius: 999px;
      background: rgba(239,68,68,0.08);
      color: #b91c1c;
      font-size: 0.75rem;
      font-weight: 600;
    }

    .phc-pack-cta {
      margin-top: 0.25rem;
      width: 100%;
      border-radius: 999px;
      padding: 0.7rem 1rem;
      border: none;
      background: #111827;
      color: #fff;
      font-size: 0.9rem;
      font-weight: 600;
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.35rem;
      transition: opacity 0.12s ease, transform 0.12s ease, box-shadow 0.12s ease;
      box-shadow: 0 10px 24px rgba(15,23,42,0.35);
    }

    .phc-pack-cta:hover:not([disabled]) {
      opacity: 0.95;
      transform: translateY(-1px);
      box-shadow: 0 14px 26px rgba(15,23,42,0.45);
    }

    .phc-pack-cta:disabled {
      opacity: 0.55;
      cursor: not-allowed;
      box-shadow: none;
    }

    .phc-pack-cta-note {
      font-size: 0.75rem;
      opacity: 0.8;
      margin-top: 0.15rem;
    }

    .phc-zoom-backdrop {
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.6);
      display: none;
      align-items: center;
      justify-content: center;
      z-index: 9999;
      padding: 1.5rem;
    }

    .phc-zoom-backdrop.is-open {
      display: flex;
    }

    .phc-zoom-inner {
      max-width: 100%;
      max-height: 100%;
    }

    .phc-zoom-inner img {
      max-width: 100%;
      max-height: 100%;
      display: block;
      border-radius: 1.25rem;
    }

    .phc-zoom-close {
      position: absolute;
      top: 1rem;
      right: 1rem;
      border: none;
      border-radius: 999px;
      width: 32px;
      height: 32px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: rgba(15,23,42,0.8);
      color: #fff;
      cursor: pointer;
    }
  {% endstyle %}

  <section
    id="product-hero-calmi-{{ section.id }}"
    class="product-hero-calmi product-hero-calmi-{{ section.id }} color-{{ section.settings.color_scheme }}"
    data-product-hero-calmi
    data-product-json-id="ProductJson-{{ section.id }}"
    data-initial-variant-id="{{ current_variant.id }}"
    data-cta-default="{{ section.settings.cta_label | default: 'Quiero mi Calmi ✨' }}"
    data-cta-soldout="{{ 'products.product.sold_out' | t }}"
  >

    <div class="product-hero-calmi__inner">
      <div class="phc-gallery">
        <div
          class="phc-gallery-main{% if initial_media and initial_media.media_type == 'image' %} phc-gallery-main--clickable{% endif %}"
          data-gallery-main
        >
          {% if initial_media %}
            <div
              class="phc-gallery-main-media"
              data-media-type="{{ initial_media.media_type }}"
              data-media-id="{{ initial_media.id }}"
            >
              {% case initial_media.media_type %}
                {% when 'image' %}
                  {{ initial_media | image_url: width: 1200 | image_tag: loading: 'lazy', alt: initial_media.alt | escape }}
                {% when 'video' %}
                  {{ initial_media | video_tag: controls: true, muted: false, autoplay: false, loop: false }}
                {% when 'external_video' %}
                  {{ initial_media | external_video_tag }}
                {% when 'model' %}
                  {{ initial_media | model_viewer_tag }}
                {% else %}
                  {{ initial_media | image_url: width: 1200 | image_tag: loading: 'lazy', alt: initial_media.alt | escape }}
              {% endcase %}
            </div>
          {% else %}
            <div class="phc-gallery-main-media">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>

        {% if product.media.size > 1 %}
          <div class="phc-gallery-thumbs" data-gallery-thumbs>
            {% for media in product.media %}
              <button
                type="button"
                class="phc-gallery-thumb{% if initial_media and media.id == initial_media.id %} is-active{% endif %}"
                data-media-id="{{ media.id }}"
                aria-label="{{ media.alt | default: product.title | escape }}"
              >
                {% case media.media_type %}
                  {% when 'image' %}
                    {{ media | image_url: width: 200 | image_tag: loading: 'lazy', alt: media.alt | escape }}
                  {% when 'video' %}
                    {{ media | image_url: width: 200 | image_tag: loading: 'lazy', alt: media.alt | escape }}
                  {% when 'external_video' %}
                    {{ media | image_url: width: 200 | image_tag: loading: 'lazy', alt: media.alt | escape }}
                  {% when 'model' %}
                    {{ media | image_url: width: 200 | image_tag: loading: 'lazy', alt: media.alt | escape }}
                  {% else %}
                    {{ media | image_url: width: 200 | image_tag: loading: 'lazy', alt: media.alt | escape }}
                {% endcase %}
              </button>
            {% endfor %}
          </div>
        {% endif %}

        {% for media in product.media %}
          <template id="ProductHeroMedia-{{ section.id }}-{{ media.id }}">
            <div
              class="phc-gallery-main-media"
              data-media-type="{{ media.media_type }}"
              data-media-id="{{ media.id }}"
            >
              {% case media.media_type %}
                {% when 'image' %}
                  {{ media | image_url: width: 1400 | image_tag: loading: 'lazy', alt: media.alt | escape }}
                {% when 'video' %}
                  {{ media | video_tag: controls: true, muted: false, autoplay: false, loop: false }}
                {% when 'external_video' %}
                  {{ media | external_video_tag }}
                {% when 'model' %}
                  {{ media | model_viewer_tag }}
                {% else %}
                  {{ media | image_url: width: 1400 | image_tag: loading: 'lazy', alt: media.alt | escape }}
              {% endcase %}
            </div>
          </template>
        {% endfor %}
      </div>

      <div class="phc-content">
        {% if section.settings.show_badge and section.settings.badge_text != blank %}
          <div class="phc-badge">
            <span class="phc-badge-dot"></span>
            <span>{{ section.settings.badge_text }}</span>
          </div>
        {% endif %}

        <div>
          <h1 class="phc-title">
            {% if section.settings.heading != blank %}
              {{ section.settings.heading }}
            {% else %}
              {{ product.title | escape }}
            {% endif %}
          </h1>

          {% if section.settings.subheading != blank %}
            <div class="phc-subtitle rte">
              {{ section.settings.subheading }}
            </div>
          {% endif %}
        </div>

        <div class="phc-price-row" data-product-price>
          {% assign c = current_variant.compare_at_price %}
          {% assign p = current_variant.price %}

          {% if c > p %}
            <span class="phc-price-compare" data-price-compare data-initial-compare="{{ c }}"></span>
          {% endif %}
          
          <span class="phc-price-current" data-price-current data-initial-price="{{ p }}"></span>

          {% if c > p %}
            {% assign diff = c | minus: p %}
            {% assign pct = diff | times: 100 | divided_by: c | round %}
            <span class="phc-price-badge" data-discount-badge>-{{ pct }}%</span>
          {% else %}
            <span class="phc-price-badge phc-price-badge--hidden" data-discount-badge></span>
          {% endif %}
        </div>

        <p class="phc-variants-label">
          Elegí tu Calmi
        </p>

        <div class="phc-variants" data-variant-picker>
          <fieldset class="phc-variant-option" data-option-index="{{ model_option_position | minus: 1 }}">
            <legend style="display:none;"></legend>
            <div class="phc-variant-option__values">
              {% for value in model_option.values %}
                {% assign is_active = false %}
                {% if value == current_model_value %}
                  {% assign is_active = true %}
                {% endif %}

                {%- assign swatch_media = nil -%}
                {%- for v in product.variants -%}
                  {%- case model_option_position -%}
                    {%- when 1 -%}
                      {%- if v.option1 == value -%}
                        {%- assign swatch_media = v.featured_media | default: v.image -%}
                        {%- break -%}
                      {%- endif -%}
                    {%- when 2 -%}
                      {%- if v.option2 == value -%}
                        {%- assign swatch_media = v.featured_media | default: v.image -%}
                        {%- break -%}
                      {%- endif -%}
                    {%- when 3 -%}
                      {%- if v.option3 == value -%}
                        {%- assign swatch_media = v.featured_media | default: v.image -%}
                        {%- break -%}
                      {%- endif -%}
                  {%- endcase -%}
                {%- endfor -%}

                <button
                  type="button"
                  class="phc-variant-pill{% if is_active %} is-active{% endif %}"
                  data-model-pill
                  data-model-name="{{ value | escape }}"
                >
                  <span class="phc-variant-pill-thumb">
                    {% if swatch_media %}
                      {{ swatch_media | image_url: width: 80 | image_tag: loading: 'lazy', alt: value }}
                    {% else %}
                      {{ 'image' | placeholder_svg_tag }}
                    {% endif %}
                  </span>
                  <span class="phc-variant-pill-label">{{ value }}</span>
                </button>
              {% endfor %}
            </div>
          </fieldset>
        </div>

        <div class="phc-pack" data-pack-2x>
          <div class="phc-pack-header">
            <div>
              <div class="phc-pack-title">Pack 2× peluches</div>
              <div style="font-size:0.8rem;opacity:0.85;">
                Elegí <strong>dos peluches</strong> (iguales o distintos). Tenés <strong>50% OFF&nbsp;en la segunda unidad</strong>.
              </div>
            </div>
            <div class="phc-pack-tag">50% OFF 2ª unidad</div>
          </div>

          <div class="phc-pack-body">

            <div class="phc-pack-pickers">

              <div class="phc-pack-picker" data-pack-slot="1">
                <div class="phc-pack-picker-label">Peluchito 1</div>
                <div class="phc-pack-options">
                  {% for v in product.variants %}
                    {% if v.option1 != 'Single' %}
                      {% continue %}
                    {% endif %}

                    {% assign swatch_media = v.featured_media | default: v.image %}
                    <button
                      type="button"
                      class="phc-variant-pill phc-pack-pill{% if forloop.first %} is-active{% endif %}"
                      data-pack-slot-button
                      data-variant-pack="single"
                      data-variant-model="{{ v.option2 }}"
                      data-variant-id="{{ v.id }}"
                      data-variant-price="{{ v.price }}"
                    >
                      <span class="phc-variant-pill-thumb">
                        {% if swatch_media %}
                          {{ swatch_media | image_url: width: 80 | image_tag: loading: 'lazy', alt: v.option2 | escape }}
                        {% else %}
                          {{ 'image' | placeholder_svg_tag }}
                        {% endif %}
                      </span>
                      <span class="phc-variant-pill-label">{{ v.option2 }}</span>
                    </button>
                  {% endfor %}
                </div>
              </div>

              <div class="phc-pack-picker" data-pack-slot="2">
                <div class="phc-pack-picker-label">Peluchito 2</div>
                <div class="phc-pack-options">
                  {% for v in product.variants %}
                    {% if v.option1 != 'Single' %}
                      {% continue %}
                    {% endif %}

                    {% assign swatch_media = v.featured_media | default: v.image %}
                    <button
                      type="button"
                      class="phc-variant-pill phc-pack-pill{% if forloop.index == 2 %} is-active{% endif %}"
                      data-pack-slot-button
                      data-variant-pack="single"
                      data-variant-model="{{ v.option2 }}"
                      data-variant-id="{{ v.id }}"
                      data-variant-price="{{ v.price }}"
                    >
                      <span class="phc-variant-pill-thumb">
                        {% if swatch_media %}
                          {{ swatch_media | image_url: width: 80 | image_tag: loading: 'lazy', alt: v.option2 | escape }}
                        {% else %}
                          {{ 'image' | placeholder_svg_tag }}
                        {% endif %}
                      </span>
                      <span class="phc-variant-pill-label">{{ v.option2 }}</span>
                    </button>
                  {% endfor %}
                </div>
              </div>

            </div>

            <div class="phc-pack-summary">
              <div class="phc-pack-summary-row">
                <span class="phc-pack-total-label">Total Pack 2×</span>
                <span class="phc-pack-total-value" data-pack-total>-</span>
              </div>

              <div class="phc-pack-summary-row">
                <span class="phc-pack-savings">
                  <span class="phc-pack-savings-pill">🔥 50% en la 2ª unidad</span>
                </span>
                <span class="phc-pack-savings" data-pack-savings>-</span>
              </div>
            </div>

            <button
              type="button"
              class="phc-pack-cta"
              data-pack-add-to-cart
            >
              Comprar Pack 2×
            </button>

            <div class="phc-pack-cta-note">
              El descuento se aplica como promoción automática en Shopify (configurá en Descuentos → Descuento automático).
            </div>

          </div>
        </div>


        {% assign form_id = 'product-hero-form-' | append: section.id %}
        {%- form 'product', product, id: form_id, class: 'phc-form', novalidate: 'novalidate' -%}
          <input type="hidden" name="id" value="{{ current_variant.id }}" data-product-variant-id>

          {% if section.settings.show_quantity_selector %}
            <div class="phc-quantity">
              <span>{{ 'products.product.quantity.label' | t }}</span>
              <div class="phc-quantity-input" data-quantity-wrapper>
                <button type="button" data-quantity-minus aria-label="{{ 'products.product.quantity.decrease' | t }}">-</button>
                <input
                  type="number"
                  name="quantity"
                  min="1"
                  value="1"
                  inputmode="numeric"
                  data-quantity-input
                >
                <button type="button" data-quantity-plus aria-label="{{ 'products.product.quantity.increase' | t }}">+</button>
              </div>
            </div>
          {% endif %}

          <button
            type="submit"
            name="add"
            class="phc-cta-button"
            data-add-to-cart
            {% unless current_variant.available %}disabled{% endunless %}
          >
            <span>
              {% if current_variant.available %}
                {{ section.settings.cta_label | default: 'Quiero mi Calmi ✨' }}
              {% else %}
                {{ 'products.product.sold_out' | t }}
              {% endif %}
            </span>
          </button>

          {% if section.settings.show_cta_subtext and section.settings.cta_subtext != blank %}
            <p class="phc-cta-subtext">
              {{ section.settings.cta_subtext }}
            </p>
          {% endif %}
        {%- endform -%}

        {% if section.blocks.size > 0 %}
          <ul class="phc-benefits">
            {% for block in section.blocks %}
              {% if block.type == 'benefit' %}
                <li class="phc-benefit" {{ block.shopify_attributes }}>
                  <div class="phc-benefit__icon">
                    {% if block.settings.icon_svg != blank %}
                      {{ block.settings.icon_svg }}
                    {% else %}
                      <svg viewBox="0 0 16 16" aria-hidden="true" focusable="false">
                        <path
                          fill="currentColor"
                          d="M6.5 11.5L3 8l1.4-1.4L6.5 8.7l5.1-5.1L13 5l-6.5 6.5z"
                        />
                      </svg>
                    {% endif %}
                  </div>
                  <div>
                    {% if block.settings.title != blank %}
                      <p class="phc-benefit__title">{{ block.settings.title }}</p>
                    {% endif %}
                    {% if block.settings.text != blank %}
                      <p class="phc-benefit__text">{{ block.settings.text }}</p>
                    {% endif %}
                  </div>
                </li>
              {% endif %}
            {% endfor %}
          </ul>
        {% endif %}
      </div>
    </div>

    <div class="phc-zoom-backdrop" data-zoom-backdrop>
      <button class="phc-zoom-close" type="button" data-zoom-close>✕</button>
      <div class="phc-zoom-inner" data-zoom-inner></div>
    </div>

    <script type="application/json" id="ProductJson-{{ section.id }}">
      {{ product | json }}
    </script>

  </section>
{% endif %}
{% javascript %}
(function() {
  const section = document.querySelector('[data-product-hero-calmi]');
  if (!section) return;

  const productJsonId = section.dataset.productJsonId;
  const productJsonEl = document.getElementById(productJsonId);
  if (!productJsonEl) return;

  let productData;
  try {
    productData = JSON.parse(productJsonEl.textContent || productJsonEl.innerText);
  } catch (err) {
    console.error("Error loading product JSON", err);
    return;
  }

  const ctaDefault = section.dataset.ctaDefault;
  const ctaSoldout = section.dataset.ctaSoldout;
  const initialVariantId = parseInt(section.dataset.initialVariantId, 10);

  function formatARS(amount) {
    if (typeof amount !== "number") amount = parseInt(amount, 10);
    if (isNaN(amount)) return "$0";
    return "$" + amount.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ".");
  }

  function getVariantById(id) {
    id = parseInt(id, 10);
    return productData.variants.find(v => v.id === id) || null;
  }

  function updatePrice(variant) {
    const priceEl = section.querySelector('[data-price-current]');
    const compareEl = section.querySelector('[data-price-compare]');
    const discountEl = section.querySelector('[data-discount-badge]');

    priceEl.textContent = formatARS(variant.price);

    if (variant.compare_at_price && variant.compare_at_price > variant.price) {
      compareEl.textContent = formatARS(variant.compare_at_price);
      compareEl.style.display = "";
      const pct = Math.round((variant.compare_at_price - variant.price) * 100 / variant.compare_at_price);
      discountEl.textContent = `-${pct}%`;
      discountEl.classList.remove("phc-price-badge--hidden");
    } else {
      compareEl.style.display = "none";
      discountEl.classList.add("phc-price-badge--hidden");
    }
  }

  function updateVariant(variant) {
    const input = section.querySelector('[data-product-variant-id]');
    const btn = section.querySelector('[data-add-to-cart]');
    const span = btn.querySelector("span");

    input.value = variant.id;

    if (variant.available) {
      btn.disabled = false;
      span.textContent = ctaDefault;
    } else {
      btn.disabled = true;
      span.textContent = ctaSoldout;
    }

    updatePrice(variant);
  }

  const initialVariant = getVariantById(initialVariantId);
  if (initialVariant) updateVariant(initialVariant);

})();
{% endjavascript %}



