{% comment %}
  Sección: Por qué Calmi funciona
  - 3 columnas con íconos grandes (sin fondo)
  - Título + texto corto
  - Pensado para usar en plantilla de producto
{% endcomment %}

{% style %}

/* ===============================
   🎨 SISTEMA DE COLORES DINÁMICOS
   =============================== */

.why-works-{{ section.id }} {
  --why-bg: {{ section.settings.bg_color }};
  --why-title: {{ section.settings.heading_color }};
  --why-subtitle: {{ section.settings.subheading_color }};
  --why-item-title: {{ section.settings.item_title_color }};
  --why-item-text: {{ section.settings.item_text_color }};
  --why-icon-color: {{ section.settings.icon_color }};
  --why-card-bg: {{ section.settings.card_bg }};
}

/* Fondo general */
.why-works-{{ section.id }} {
  padding-top: {{ section.settings.padding_top }}px;
  padding-bottom: {{ section.settings.padding_bottom }}px;
  background: var(--why-bg);
}

.why-works-{{ section.id }}__inner {
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 20px;
  text-align: center;
}

/* ---------------------------------
   TITULAR
--------------------------------- */
.why-works-{{ section.id }}__heading {
  margin-bottom: 26px;
}

.why-works-{{ section.id }}__heading-title {
  margin: 0 0 10px;
  color: var(--why-title);
}

.why-works-{{ section.id }}__heading-subtitle {
  margin: 0 auto;
  max-width: 640px;
  color: var(--why-subtitle);
  font-size: 1.5rem;
  line-height: 1.5;
}

/* ---------------------------------
   GRID
--------------------------------- */
.why-works-{{ section.id }}__grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0,1fr));
  gap: 26px;
}

/* ---------------------------------
   ITEM
--------------------------------- */
.why-works-{{ section.id }}__item {
  text-align: center;
  background: var(--why-card-bg);
  padding: 8px;
  border-radius: 12px;
}

/* ---------------------------------
   ICONOS
--------------------------------- */
.why-works-{{ section.id }}__icon img {
  width: 94px;
  height: 94px;
  object-fit: contain;
  display: inline-block;
}

.why-works-{{ section.id }}__icon-fallback {
  font-size: 3rem;
  line-height: 1;
  color: var(--why-icon-color);
}

/* Si es SVG inline */
.why-works-{{ section.id }}__icon svg {
  width: 94px;
  height: 94px;
  fill: var(--why-icon-color) !important;
}

/* ---------------------------------
   TEXTOS
--------------------------------- */
.why-works-{{ section.id }}__title {
  font-weight: 700;
  font-size: 1.6rem;
  margin-bottom: 6px;
  color: var(--why-item-title);
}

.why-works-{{ section.id }}__text {
  font-size: 1.35rem;
  line-height: 1.45;
  color: var(--why-item-text);
  max-width: 320px;
  margin: 0 auto;
}

/* ---------------------------------
   MOBILE
--------------------------------- */
@media screen and (max-width: 749px) {
  .why-works-{{ section.id }} {
    padding-top: {{ section.settings.padding_top | times: 0.7 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.7 | round: 0 }}px;
  }

  .why-works-{{ section.id }}__grid {
    grid-template-columns: 1fr;
    gap: 24px;
  }

  .why-works-{{ section.id }}__heading-subtitle {
    font-size: 1.35rem;
  }

  .why-works-{{ section.id }}__icon img {
    width: 90px;
    height: 90px;
  }
}

{% endstyle %}


<section class="why-works-{{ section.id }}">
  <div class="why-works-{{ section.id }}__inner">

    {% if section.settings.heading != blank or section.settings.subheading != blank %}
      <div class="why-works-{{ section.id }}__heading">
        {% if section.settings.heading != blank %}
          <h2 class="why-works-{{ section.id }}__heading-title title {{ section.settings.heading_size }}">
            {{ section.settings.heading }}
          </h2>
        {% endif %}

        {% if section.settings.subheading != blank %}
          <p class="why-works-{{ section.id }}__heading-subtitle">
            {{ section.settings.subheading }}
          </p>
        {% endif %}
      </div>
    {% endif %}

    <div class="why-works-{{ section.id }}__grid">
      {% for block in section.blocks %}
        <div class="why-works-{{ section.id }}__item" {{ block.shopify_attributes }}>

          {% if block.settings.icon_image != blank %}
            <div class="why-works-{{ section.id }}__icon">
              {{ block.settings.icon_image | image_url: width: 160 | image_tag: loading: 'lazy' }}
            </div>
          {% elsif block.settings.icon_emoji != blank %}
            <div class="why-works-{{ section.id }}__icon-fallback">
              {{ block.settings.icon_emoji }}
            </div>
          {% endif %}

          {% if block.settings.title != blank %}
            <div class="why-works-{{ section.id }}__title">
              {{ block.settings.title }}
            </div>
          {% endif %}

          {% if block.settings.text != blank %}
            <div class="why-works-{{ section.id }}__text">
              {{ block.settings.text }}
            </div>
          {% endif %}

        </div>
      {% endfor %}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Por qué funciona Calmi",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Título",
      "default": "Por qué Calmi funciona tan bien"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Tamaño del título",
      "options": [
        { "value": "h2", "label": "H2" },
        { "value": "h1", "label": "H1" },
        { "value": "h0", "label": "H0" }
      ],
      "default": "h2"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subtítulo",
      "default": "No es un peluche común: imita respiración y latidos para generar sensación de compañía y seguridad."
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Color de fondo",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding superior",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 56
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding inferior",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 56
    },
    {
      "type": "header",
      "content": "🎨 Colores personalizados"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Color del título",
      "default": "#1C1C1C"
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Color del subtítulo",
      "default": "#4B5563"
    },
    {
      "type": "color",
      "id": "item_title_color",
      "label": "Color del título del ítem",
      "default": "#1C1C1C"
    },
    {
      "type": "color",
      "id": "item_text_color",
      "label": "Color del texto del ítem",
      "default": "#4B5563"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Color de íconos (fallback o SVG)",
      "default": "#2B4E52"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Color de fondo del ítem (optional)",
      "default": "transparent"
    }
  ],
  "blocks": [
    {
      "type": "reason",
      "name": "Motivo",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Ícono (opcional)"
        },
        {
          "type": "text",
          "id": "icon_emoji",
          "label": "Emoji (fallback si no hay imagen)",
          "default": "💜"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Título",
          "default": "Respira como vos"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Texto",
          "default": "Imita una respiración suave que transmite calma y seguridad."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Por qué funciona Calmi",
      "blocks": [
        {
          "type": "reason",
          "settings": {
            "icon_emoji": "💨",
            "title": "Respiración real",
            "text": "Simula un movimiento de respiración suave que calma al instante."
          }
        },
        {
          "type": "reason",
          "settings": {
            "icon_emoji": "💗",
            "title": "Latidos calmantes",
            "text": "Latidos rítmicos que transmiten sensación de compañía y protección."
          }
        },
        {
          "type": "reason",
          "settings": {
            "icon_emoji": "🛌",
            "title": "Sensación de compañía",
            "text": "Bebés y mascotas se sienten acompañados, duermen más tranquilos y por más tiempo."
          }
        }
      ]
    }
  ]
}
{% endschema %}
