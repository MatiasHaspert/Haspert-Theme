# Copiá este archivo a `.env` y completá los valores. El .env NO se commitea.
#
# Apps del Dev Dashboard (dev.shopify.com): NO dan token estático shpat_.
# Se usa client_credentials: Settings → Client ID + Client secret de la app
# (instalada en la tienda). El script pide un access token de 24h solo.
SHOPIFY_STORE=tu-tienda.myshopify.com
SHOPIFY_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SHOPIFY_CLIENT_SECRET=shpss_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
API_VERSION=2026-04

# Opcional: id de la location para set-stock (gid://shopify/Location/...).
# Si se omite, set-stock usa la primera location activa.
# LOCATION_ID=

# Alternativa (custom app clásica desde el admin): token directo. Si lo definís,
# tiene prioridad sobre client_credentials. Tiene que empezar con shpat_.
# ADMIN_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
